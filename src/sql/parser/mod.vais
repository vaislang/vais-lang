# SQL Parser Module
# Tokenizer, AST, and recursive descent parser
#
# Parser is split across multiple files for maintainability:
#   parser.vais          — Core: Parser struct, parse_statement dispatch, helpers, parse_sql
#   parser_select.vais   — SELECT, CTEs, FROM/JOIN, WHERE, GROUP BY, HAVING, ORDER BY, LIMIT
#   parser_dml.vais      — INSERT, UPDATE, DELETE
#   parser_ddl.vais      — CREATE/DROP/ALTER TABLE, CREATE/DROP INDEX
#   parser_command.vais  — SET, PREPARE, EXECUTE, VACUUM, REINDEX, BACKUP, RESTORE
#   parser_security.vais — Security DDL: USER, ROLE, GRANT, REVOKE, POLICY
#   parser_expr.vais     — Expression parsing (precedence climbing), CASE, CAST, window functions

U token
U ast
U parser
U parser_select
U parser_dml
U parser_ddl
U parser_command
U parser_security
U parser_expr
U prepared
