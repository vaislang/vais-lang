# B+Tree Key Encoding and Comparison
# Handles composite keys, type-aware encoding, and prefix compression
# Keys are stored as byte slices with type-aware comparison

U storage/error.{VaisError, err_internal};
U storage/btree/entry.{compare_keys, key_less_than, key_equal, KeyCmp};
U std/bytes.{ByteBuffer};

X F __strlen(s: str) -> i64

# Key types for type-aware comparison
E KeyType {
    Integer,
    Float,
    Str,
    Bytes,
    Composite,
}

# Encode an integer key (i64) as big-endian bytes for correct lexicographic order
# Flip the sign bit so negative sorts before positive
F encode_i64_key(value: i64) -> Vec<u8> {
    encoded := mut Vec.with_capacity(8);
    encoded.resize(8, 0u8);

    # Flip sign bit for correct sort order: XOR with 0x80 on high byte
    v := mut (value as u64) ^ (1u64 << 63);
    encoded[0] = ((v >> 56) & 255u64) as u8;
    encoded[1] = ((v >> 48) & 255u64) as u8;
    encoded[2] = ((v >> 40) & 255u64) as u8;
    encoded[3] = ((v >> 32) & 255u64) as u8;
    encoded[4] = ((v >> 24) & 255u64) as u8;
    encoded[5] = ((v >> 16) & 255u64) as u8;
    encoded[6] = ((v >> 8) & 255u64) as u8;
    encoded[7] = (v & 255u64) as u8;
    encoded
}

# Decode a big-endian encoded integer key back to i64
F decode_i64_key(data: &[u8]) -> i64 {
    v: u64 := mut 0;
    v |= (data[0] as u64) << 56;
    v |= (data[1] as u64) << 48;
    v |= (data[2] as u64) << 40;
    v |= (data[3] as u64) << 32;
    v |= (data[4] as u64) << 24;
    v |= (data[5] as u64) << 16;
    v |= (data[6] as u64) << 8;
    v |= data[7] as u64;
    # Flip sign bit back
    (v ^ (1u64 << 63)) as i64
}

# Encode a u64 key as big-endian bytes
F encode_u64_key(value: u64) -> Vec<u8> {
    encoded := mut Vec.with_capacity(8);
    encoded.resize(8, 0u8);
    encoded[0] = ((value >> 56) & 255u64) as u8;
    encoded[1] = ((value >> 48) & 255u64) as u8;
    encoded[2] = ((value >> 40) & 255u64) as u8;
    encoded[3] = ((value >> 32) & 255u64) as u8;
    encoded[4] = ((value >> 24) & 255u64) as u8;
    encoded[5] = ((value >> 16) & 255u64) as u8;
    encoded[6] = ((value >> 8) & 255u64) as u8;
    encoded[7] = (value & 255u64) as u8;
    encoded
}

# Decode a big-endian u64 key
F decode_u64_key(data: &[u8]) -> u64 {
    v: u64 := mut 0;
    v |= (data[0] as u64) << 56;
    v |= (data[1] as u64) << 48;
    v |= (data[2] as u64) << 40;
    v |= (data[3] as u64) << 32;
    v |= (data[4] as u64) << 24;
    v |= (data[5] as u64) << 16;
    v |= (data[6] as u64) << 8;
    v |= data[7] as u64;
    v
}

# Encode a string key with null-termination
# Strings sort lexicographically as raw bytes (UTF-8 preserves order for ASCII)
F encode_string_key(value: str) -> Vec<u8> {
    slen := mut __strlen(value) as u64;
    encoded := mut Vec.with_capacity(slen);
    L i: 0..slen {
        encoded.push(value[i]);
    }
    encoded
}

# Encode a composite key (multiple columns)
# Each component is length-prefixed: [u16 len][key bytes]
F encode_composite_key(components: &[&[u8]]) -> Vec<u8> {
    total_len: u64 := mut 0;
    L i: 0..components.len() {
        total_len += 2 + components[i].len();
    }

    encoded := mut Vec.with_capacity(total_len);
    L i: 0..components.len() {
        comp := mut &components[i];
        len := mut comp.len() as u16;
        encoded.push((len >> 8) as u8);
        encoded.push((len & 255u16) as u8);
        L j: 0..comp.len() {
            encoded.push(comp[j]);
        }
    }
    encoded
}

# Decode a composite key into its components
F decode_composite_key(data: &[u8]) -> Vec<Vec<u8>> {
    components := mut Vec.new();
    pos: u64 := mut 0;

    valid := mut true;
    L pos + 2 <= data.len() && valid {
        len := mut ((data[pos] as u16) << 8) | (data[pos + 1] as u16);
        pos += 2;
        I pos + len as u64 > data.len() {
            valid = false;
        } E {
            comp_end := mut pos + len as u64;
            comp := mut Vec.with_capacity(len as u64);
            L k: pos..comp_end {
                comp.push(data[k]);
            }
            components.push(comp);
            pos += len as u64;
        }
    }

    components
}

# Calculate common prefix length between two keys
F common_prefix_length(a: &[u8], b: &[u8]) -> u64 {
    min_len := mut I a.len() < b.len() { a.len() } E { b.len() };
    prefix_len: u64 := mut 0;
    prefix_done := mut false;
    L i: 0..min_len {
        I !prefix_done {
            I a[i] != b[i] {
                prefix_done = true;
            } E {
                prefix_len += 1;
            }
        }
    }
    prefix_len
}

# Strip prefix result struct
S StripPrefixResult {
    prefix_len: u16,
    suffix: Vec<u8>,
}

# Strip common prefix from a key (for prefix compression)
# Returns StripPrefixResult with prefix_len and suffix
F strip_prefix(key: &[u8], prev_key: &[u8]) -> StripPrefixResult {
    prefix_len := mut common_prefix_length(key, prev_key);
    suffix_start := mut prefix_len;
    suffix_end := mut key.len();
    suffix := mut Vec.with_capacity(suffix_end - suffix_start);
    L i: suffix_start..suffix_end {
        suffix.push(key[i]);
    }
    StripPrefixResult { prefix_len: prefix_len as u16, suffix }
}

# Reconstruct a key from prefix length and suffix
F reconstruct_key(prev_key: &[u8], prefix_len: u16, suffix: &[u8]) -> Vec<u8> {
    key := mut Vec.with_capacity(prefix_len as u64 + suffix.len());
    L i: 0..prefix_len as u64 {
        key.push(prev_key[i]);
    }
    L i: 0..suffix.len() {
        key.push(suffix[i]);
    }
    key
}

# Key range for scans
S KeyRange {
    start: Option<Vec<u8>>,    # None = negative infinity
    end: Option<Vec<u8>>,      # None = positive infinity
    start_inclusive: bool,
    end_inclusive: bool,
}

X KeyRange {
    # Full range (all keys)
    F all() -> KeyRange {
        KeyRange {
            start: None,
            end: None,
            start_inclusive: true,
            end_inclusive: true,
        }
    }

    # Range [start, end]
    F closed(start: Vec<u8>, end: Vec<u8>) -> KeyRange {
        KeyRange {
            start: Some(start),
            end: Some(end),
            start_inclusive: true,
            end_inclusive: true,
        }
    }

    # Range [start, end)
    F half_open(start: Vec<u8>, end: Vec<u8>) -> KeyRange {
        KeyRange {
            start: Some(start),
            end: Some(end),
            start_inclusive: true,
            end_inclusive: false,
        }
    }

    # Check if a key is within this range
    F contains(self, key: &[u8]) -> bool {
        # Check start bound
        M &self.start {
            Some(start_key) => {
                M compare_keys(key, start_key) {
                    KeyCmp.Less => { R false; },
                    KeyCmp.Equal => {
                        I !self.start_inclusive { R false; }
                    },
                    KeyCmp.Greater => {},
                }
            },
            None => {},
        }

        # Check end bound
        M &self.end {
            Some(end_key) => {
                M compare_keys(key, end_key) {
                    KeyCmp.Greater => { R false; },
                    KeyCmp.Equal => {
                        I !self.end_inclusive { R false; }
                    },
                    KeyCmp.Less => {},
                }
            },
            None => {},
        }

        true
    }

    # Check if key is past end of range
    F is_past_end(self, key: &[u8]) -> bool {
        M &self.end {
            Some(end_key) => {
                M compare_keys(key, end_key) {
                    KeyCmp.Greater => true,
                    KeyCmp.Equal => !self.end_inclusive,
                    KeyCmp.Less => false,
                }
            },
            None => false,
        }
    }
}
