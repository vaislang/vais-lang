{
  "name": "@vaisx/native",
  "version": "0.1.0",
  "description": "VaisX native renderer architecture — React Native style API without external native dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "sideEffects": false,
  "license": "MIT",
  "keywords": ["vaisx", "native", "renderer", "react-native", "stylesheet", "frontend"],
  "homepage": "https://github.com/vaislang/vais-web/tree/main/packages/native",
  "bugs": "https://github.com/vaislang/vais-web/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaislang/vais-web",
    "directory": "packages/native"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
