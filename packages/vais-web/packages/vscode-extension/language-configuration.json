{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] },
    { "open": "<!--", "close": "-->", "notIn": ["comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""],
    ["`", "`"],
    ["<", ">"]
  ],
  "onEnterRules": [
    {
      "beforeText": "^\\s*<!--",
      "afterText": "-->",
      "action": { "indent": "none" }
    },
    {
      "beforeText": "^((?!.*?\\/\\*).*\\*)?\\s*\\*",
      "action": { "indent": "none", "appendText": "* " }
    },
    {
      "beforeText": "^\\s*(\\*\\/|\\*/)",
      "action": { "indent": "none", "removeText": 1 }
    }
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\$\\^\\&\\*\\(\\)\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\s]+)",
  "folding": {
    "markers": {
      "start": "^\\s*<!--\\s*#region\\b",
      "end": "^\\s*<!--\\s*#endregion\\b"
    }
  }
}
