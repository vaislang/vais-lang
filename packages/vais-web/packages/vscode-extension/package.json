{
  "name": "vaisx-vscode",
  "displayName": "VaisX",
  "description": "VaisX language support for VS Code — syntax highlighting, completions, diagnostics",
  "version": "0.1.0",
  "publisher": "vaisx",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "keywords": ["vaisx", "vais", "language", "lsp"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaislang/vais-web",
    "directory": "packages/vscode-extension"
  },
  "contributes": {
    "languages": [
      {
        "id": "vaisx",
        "aliases": ["VaisX", "vaisx"],
        "extensions": [".vaisx"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vaisx",
        "scopeName": "source.vaisx",
        "path": "./syntaxes/vaisx.tmLanguage.json"
      }
    ]
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --out-dir dist --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
