{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VaisX",
  "scopeName": "source.vaisx",
  "fileTypes": [".vaisx"],
  "patterns": [
    { "include": "#script-block" },
    { "include": "#template-block" },
    { "include": "#style-block" },
    { "include": "#comments" }
  ],
  "repository": {
    "script-block": {
      "name": "meta.block.script.vaisx",
      "begin": "(<)(script)((?:\\s+lang=\"(?:ts|js|typescript|javascript)\")?(?:\\s+[^>]*)?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vaisx" },
        "2": { "name": "entity.name.tag.script.vaisx" },
        "3": { "name": "meta.tag.attributes.vaisx" },
        "4": { "name": "punctuation.definition.tag.end.vaisx" }
      },
      "end": "(</)(\\.?script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vaisx" },
        "2": { "name": "entity.name.tag.script.vaisx" },
        "3": { "name": "punctuation.definition.tag.end.vaisx" }
      },
      "contentName": "source.ts.embedded.vaisx",
      "patterns": [
        { "include": "#vaisx-apis" },
        { "include": "source.ts" }
      ]
    },
    "template-block": {
      "name": "meta.block.template.vaisx",
      "begin": "(<)(template)((?:\\s+[^>]*)?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vaisx" },
        "2": { "name": "entity.name.tag.template.vaisx" },
        "3": { "name": "meta.tag.attributes.vaisx" },
        "4": { "name": "punctuation.definition.tag.end.vaisx" }
      },
      "end": "(</)(\\.?template)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vaisx" },
        "2": { "name": "entity.name.tag.template.vaisx" },
        "3": { "name": "punctuation.definition.tag.end.vaisx" }
      },
      "contentName": "meta.embedded.template.vaisx",
      "patterns": [
        { "include": "#interpolation" },
        { "include": "#vaisx-directives" },
        { "include": "#builtin-components" },
        { "include": "#html-tags" },
        { "include": "#comments" }
      ]
    },
    "style-block": {
      "name": "meta.block.style.vaisx",
      "begin": "(<)(style)((?:\\s+lang=\"(?:css|scss|less)\")?(?:\\s+[^>]*)?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vaisx" },
        "2": { "name": "entity.name.tag.style.vaisx" },
        "3": { "name": "meta.tag.attributes.vaisx" },
        "4": { "name": "punctuation.definition.tag.end.vaisx" }
      },
      "end": "(</)(\\.?style)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vaisx" },
        "2": { "name": "entity.name.tag.style.vaisx" },
        "3": { "name": "punctuation.definition.tag.end.vaisx" }
      },
      "contentName": "source.css.embedded.vaisx",
      "patterns": [
        { "include": "source.css" }
      ]
    },
    "interpolation": {
      "name": "meta.interpolation.vaisx",
      "begin": "\\{\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.interpolation.begin.vaisx" }
      },
      "end": "\\}\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.interpolation.end.vaisx" }
      },
      "contentName": "source.ts.embedded.interpolation.vaisx",
      "patterns": [
        { "include": "source.ts" }
      ]
    },
    "vaisx-directives": {
      "patterns": [
        {
          "name": "meta.directive.vaisx",
          "match": "\\b(v-if|v-else-if|v-else|v-for|v-bind|v-on|v-show|v-model|v-slot)\\b(?::[\\w-]+)?",
          "captures": {
            "1": { "name": "keyword.control.directive.vaisx" }
          }
        },
        {
          "comment": "Shorthand :attr and @event",
          "match": "(?<=\\s)(:(?![:\\s])[@\\w][\\w.-]*|@[\\w][\\w.-]*)",
          "name": "keyword.control.directive.shorthand.vaisx"
        }
      ]
    },
    "vaisx-apis": {
      "patterns": [
        {
          "name": "support.function.vaisx",
          "match": "\\b(__vx_state|__vx_derived|__vx_effect|__vx_ref|__vx_computed)\\b"
        }
      ]
    },
    "builtin-components": {
      "patterns": [
        {
          "comment": "Opening tags for built-in components",
          "match": "(</?)(Button|Input|Link|Head|Modal|Dropdown|Table|Toast)(?=\\s|>|/>)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.begin.vaisx" },
            "2": { "name": "support.class.component.builtin.vaisx" }
          }
        }
      ]
    },
    "html-tags": {
      "patterns": [
        {
          "comment": "Opening HTML tag",
          "begin": "(<)((?:[a-z][a-z0-9:-]*))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.html.vaisx" },
            "2": { "name": "entity.name.tag.html.vaisx" }
          },
          "end": "(/?>)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.tag.end.html.vaisx" }
          },
          "patterns": [
            { "include": "#tag-attributes" }
          ]
        },
        {
          "comment": "Closing HTML tag",
          "match": "(</)([a-z][a-z0-9:-]*)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.begin.html.vaisx" },
            "2": { "name": "entity.name.tag.html.vaisx" },
            "3": { "name": "punctuation.definition.tag.end.html.vaisx" }
          }
        }
      ]
    },
    "tag-attributes": {
      "patterns": [
        { "include": "#vaisx-directives" },
        {
          "comment": "Attribute name",
          "match": "([a-zA-Z_:][a-zA-Z0-9_.:-]*)",
          "name": "entity.other.attribute-name.html.vaisx"
        },
        {
          "comment": "Attribute value (double-quoted)",
          "begin": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.html.vaisx" } },
          "end": "\"",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.html.vaisx" } },
          "name": "string.quoted.double.html.vaisx"
        },
        {
          "comment": "Attribute value (single-quoted)",
          "begin": "'",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.html.vaisx" } },
          "end": "'",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.html.vaisx" } },
          "name": "string.quoted.single.html.vaisx"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.html.vaisx",
          "begin": "<!--",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.vaisx" } },
          "end": "-->",
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.vaisx" } }
        },
        {
          "name": "comment.line.double-slash.vaisx",
          "match": "//.*$"
        },
        {
          "name": "comment.block.vaisx",
          "begin": "/\\*",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.vaisx" } },
          "end": "\\*/",
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.vaisx" } }
        }
      ]
    }
  }
}
