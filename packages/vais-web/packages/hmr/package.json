{
  "name": "@vaisx/hmr",
  "version": "0.1.0",
  "description": "VaisX Hot Module Replacement — client and server",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client.ts --format esm --dts --out-dir dist --clean",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": ["vaisx", "hmr", "hot-module-replacement", "dev-server", "websocket"],
  "homepage": "https://github.com/vaislang/vais-web/tree/main/packages/hmr",
  "bugs": "https://github.com/vaislang/vais-web/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaislang/vais-web",
    "directory": "packages/hmr"
  }
}
