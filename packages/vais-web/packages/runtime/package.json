{
  "name": "@vaisx/runtime",
  "version": "0.1.0",
  "description": "VaisX minimal runtime (< 3KB gzipped)",
  "type": "module",
  "main": "./dist/lib.js",
  "module": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/lib.ts --format esm --dts --out-dir dist --clean",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "size": "node scripts/check-size.mjs"
  },
  "sideEffects": false,
  "license": "MIT",
  "keywords": ["vaisx", "runtime", "frontend", "framework", "compiler"],
  "homepage": "https://github.com/vaislang/vais-web/tree/main/packages/runtime",
  "bugs": "https://github.com/vaislang/vais-web/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaislang/vais-web",
    "directory": "packages/runtime"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "jsdom": "^25.0.0"
  }
}
