{
  "name": "@vaisx/language-server",
  "version": "0.1.0",
  "description": "VaisX Language Server Protocol implementation",
  "type": "module",
  "main": "./dist/index.js",
  "bin": { "vaisx-language-server": "./dist/index.js" },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "license": "MIT",
  "keywords": ["vaisx", "language-server", "lsp", "ide"],
  "homepage": "https://github.com/vaislang/vais-web/tree/main/packages/language-server",
  "bugs": "https://github.com/vaislang/vais-web/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaislang/vais-web",
    "directory": "packages/language-server"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
