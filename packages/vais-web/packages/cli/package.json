{
  "name": "@vaisx/cli",
  "version": "0.1.0",
  "description": "VaisX CLI — build, dev, and project tools for .vaisx components",
  "type": "module",
  "bin": {
    "vaisx": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/bin.ts src/index.ts --format esm --dts --out-dir dist --clean",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "glob": "^11.0.0",
    "esbuild": "^0.25.0",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": ["vaisx", "cli", "build", "dev-server", "compiler"],
  "homepage": "https://github.com/vaislang/vais-web/tree/main/packages/cli",
  "bugs": "https://github.com/vaislang/vais-web/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaislang/vais-web",
    "directory": "packages/cli"
  }
}
