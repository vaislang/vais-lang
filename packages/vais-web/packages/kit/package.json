{
  "name": "@vaisx/kit",
  "version": "0.1.0",
  "description": "VaisX Kit — core types and shared interfaces for the VaisX framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "bench": "vitest bench",
    "bench:size": "tsx bench/bundle-size.ts"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@vaisx/runtime": "workspace:*",
    "@vaisx/cli": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@vaisx/runtime": {
      "optional": true
    },
    "@vaisx/cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": ["vaisx", "vaiskit", "ssr", "ssg", "router", "framework"],
  "homepage": "https://github.com/vaislang/vais-web/tree/main/packages/kit",
  "bugs": "https://github.com/vaislang/vais-web/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaislang/vais-web",
    "directory": "packages/kit"
  }
}
