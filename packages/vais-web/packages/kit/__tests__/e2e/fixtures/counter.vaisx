<!-- counter.vaisx — Client component with $state and @click -->
<script context="client">
  count := $state(0)
  doubled := $derived(count * 2)

  fn increment() {
    count = count + 1
  }

  fn decrement() {
    count = count - 1
  }
</script>

<template>
  <div class="counter">
    <p>Count: {count}</p>
    <p>Doubled: {doubled}</p>
    <button @click="decrement">-</button>
    <button @click="increment">+</button>
  </div>
</template>
