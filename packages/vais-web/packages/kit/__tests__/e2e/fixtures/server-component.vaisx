<!-- server-component.vaisx — Server component with context="server" -->
<script context="server">
  A F load(ctx) {
    data := await fetchData(ctx.params.id)
    return { data }
  }

  message := "Hello from server"
  items := ["alpha", "beta", "gamma"]
</script>

<template>
  <section class="server-component">
    <h2>{message}</h2>
    <ul>
      {#each items as item}
        <li>{item}</li>
      {/each}
    </ul>
  </section>
</template>
