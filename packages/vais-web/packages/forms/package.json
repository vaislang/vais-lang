{
  "name": "@vaisx/forms",
  "version": "0.1.0",
  "description": "VaisX form state management library (react-hook-form inspired, built on @vaisx/runtime signals)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "sideEffects": false,
  "license": "MIT",
  "keywords": ["vaisx", "forms", "validation", "state-management", "signals", "frontend"],
  "homepage": "https://github.com/vaislang/vais-web/tree/main/packages/forms",
  "bugs": "https://github.com/vaislang/vais-web/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaislang/vais-web",
    "directory": "packages/forms"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@vaisx/runtime": ">=0.1.0"
  },
  "devDependencies": {
    "@vaisx/runtime": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "jsdom": "^25.0.0"
  }
}
