# ============================================================================
# BM25Scorer — Configurable BM25 scoring implementation
# ============================================================================

S BM25Scorer {
    k1: f64,                    # Term frequency saturation parameter (default 1.2)
    b: f64,                     # Document length normalization parameter (default 0.75)
    idf_cache: HashMap<u32, f64>, # Cache for IDF values keyed by document frequency
}

X BM25Scorer {
    # Create new BM25 scorer with default parameters
    # k1=1.2 controls how quickly TF impact saturates
    # b=0.75 controls how much document length affects scoring
    F new() -> BM25Scorer {
        BM25Scorer {
            k1: DEFAULT_BM25_K1,
            b: DEFAULT_BM25_B,
            idf_cache: HashMap.with_capacity(16),
        }
    }

    # Create BM25 scorer with custom parameters
    # k1: higher values give more weight to term frequency (typical range: 1.2-2.0)
    # b: higher values penalize long documents more (typical range: 0.5-0.8)
    F with_params(k1: f64, b: f64) -> BM25Scorer {
        BM25Scorer {
            k1,
            b,
            idf_cache: HashMap.with_capacity(16),
        }
    }

    # Invalidate IDF cache (call when total_docs changes significantly)
    F clear_idf_cache(mut self) {
        self.idf_cache.clear()
    }

    # Calculate IDF (Inverse Document Frequency) component
    # Formula: ln((N - df + 0.5) / (df + 0.5) + 1)
    # where N = total_docs, df = document frequency
    #
    # Edge cases:
    # - df=0 → IDF=0 (term appears in no documents)
    # - df>N → IDF=0 (data corruption, treat as invalid)
    # - N=0 → IDF=0 (no documents in corpus)
    F calculate_idf(df: u32, total_docs: u64) -> f64 {
        I total_docs == 0 || df == 0 {
            R 0.0
        }

        n := mut total_docs as f64
        df_f := mut df as f64

        # Guard against df > total_docs (data corruption)
        I df_f > n {
            R 0.0
        }

        # IDF = ln((N - df + 0.5) / (df + 0.5) + 1)
        numerator := mut n - df_f + 0.5
        denominator := mut df_f + 0.5
        ratio := mut numerator / denominator

        # Natural logarithm using fast lookup table approximation
        ln_fast(ratio + 1.0)
    }

    # Score a single term occurrence in a document
    #
    # Parameters:
    # - tf: term frequency in this document
    # - df: document frequency (how many docs contain this term)
    # - doc_length: length of this document in tokens
    # - avg_doc_length: average document length in corpus
    # - total_docs: total number of documents in corpus
    #
    # Returns: BM25 score for this term in this document
    #
    # Formula:
    # score = IDF * (tf * (k1 + 1)) / (tf + k1 * (1 - b + b * dl/avgdl))
    F score(
        self,
        tf: u32,
        df: u32,
        doc_length: u32,
        avg_doc_length: f64,
        total_docs: u64,
    ) -> f64 {
        # Edge case: no term occurrences
        I tf == 0 {
            R 0.0
        }

        # Edge case: no corpus statistics
        I total_docs == 0 || avg_doc_length == 0.0 {
            R 0.0
        }

        # Calculate IDF component
        idf := mut BM25Scorer.calculate_idf(df, total_docs)

        # Calculate TF component with length normalization
        tf_f := mut tf as f64
        dl := mut doc_length as f64
        avgdl := mut avg_doc_length

        # Length normalization factor: (1 - b + b * dl/avgdl)
        length_norm := mut 1.0 - self.b + self.b * (dl / avgdl)

        # TF numerator: tf * (k1 + 1)
        tf_numerator := mut tf_f * (self.k1 + 1.0)

        # TF denominator: tf + k1 * length_norm
        tf_denominator := mut tf_f + self.k1 * length_norm

        # Final score: IDF * (TF component)
        idf * (tf_numerator / tf_denominator)
    }

    # Score multiple terms in a query and sum their BM25 scores
    # This is the standard way to score multi-term queries in BM25
    #
    # Parameters:
    # - term_scores: pre-computed BM25 scores for each query term
    #
    # Returns: total score (sum of individual term scores)
    F batch_score(self, term_scores: &Vec<f64>) -> f64 {
        total := mut 0.0
        i := mut 0
        LW i < term_scores.len() {
            total += term_scores[i]
            i += 1
        }
        total
    }

    # Score multiple terms at once given their (tf, df) pairs
    # Caches IDF values per unique df to avoid redundant ln() calls.
    # Consecutive terms with the same df reuse the cached IDF immediately.
    #
    # Parameters:
    # - term_freqs: Vec of (tf, df) pairs for each query term
    # - doc_length: length of this document in tokens
    # - avg_doc_length: average document length in corpus
    # - total_docs: total number of documents in corpus
    #
    # Returns: sum of BM25 scores for all terms
    F score_multi_term(
        mut self,
        term_freqs: &Vec<(u32, u32)>,
        doc_length: u32,
        avg_doc_length: f64,
        total_docs: u64,
    ) -> f64 {
        I avg_doc_length == 0.0 || total_docs == 0 {
            R 0.0
        }

        total := mut 0.0
        dl := mut doc_length as f64
        avgdl := mut avg_doc_length

        # Pre-compute length normalization once for all terms in this document
        length_norm := mut 1.0 - self.b + self.b * (dl / avgdl)

        i := mut 0
        LW i < term_freqs.len() {
            (tf, df) := mut term_freqs[i]

            I tf > 0 {
                # Look up cached IDF for this df value, compute and store if missing
                idf := mut 0.0
                cached := mut self.idf_cache.get(df)
                M cached {
                    Some(v) => { idf = v; },
                    None => {
                        idf = BM25Scorer.calculate_idf(df, total_docs)
                        self.idf_cache.insert(df, idf)
                    },
                }

                tf_f := mut tf as f64
                tf_numerator := mut tf_f * (self.k1 + 1.0)
                tf_denominator := mut tf_f + self.k1 * length_norm
                total += idf * (tf_numerator / tf_denominator)
            }

            i += 1
        }
        total
    }

    # Batch-score multiple documents for a set of (tf, df) pairs
    # Accepts corpus-level parameters once, then scores each document entry.
    #
    # Parameters:
    # - doc_entries: Vec of (doc_length, term_freqs_index) pairs — one per document
    #   where term_freqs_index selects into term_freqs
    # - term_freqs: Vec of (tf, df) pairs shared across all documents
    # - avg_doc_length: average document length in corpus (passed once)
    # - total_docs: total number of documents in corpus (passed once)
    #
    # Returns: Vec<f64> of BM25 scores, one per doc_entry
    F score_batch(
        mut self,
        doc_entries: &Vec<(u32, u64, u64)>,  # (doc_length, term_start, term_count)
        term_freqs: &Vec<(u32, u32)>,
        avg_doc_length: f64,
        total_docs: u64,
    ) -> Vec<f64> {
        results := mut Vec.with_capacity(0)

        I avg_doc_length == 0.0 || total_docs == 0 {
            R results
        }

        avgdl := mut avg_doc_length

        d := mut 0
        LW d < doc_entries.len() {
            (doc_length, term_start, term_count) := mut doc_entries[d]
            dl := mut doc_length as f64
            length_norm := mut 1.0 - self.b + self.b * (dl / avgdl)

            doc_total := mut 0.0
            t := mut 0
            LW t < term_count {
                idx := mut term_start + t
                (tf, df) := mut term_freqs[idx]

                I tf > 0 {
                    idf := mut 0.0
                    cached := mut self.idf_cache.get(df)
                    M cached {
                        Some(v) => { idf = v; },
                        None => {
                            idf = BM25Scorer.calculate_idf(df, total_docs)
                            self.idf_cache.insert(df, idf)
                        },
                    }

                    tf_f := mut tf as f64
                    tf_numerator := mut tf_f * (self.k1 + 1.0)
                    tf_denominator := mut tf_f + self.k1 * length_norm
                    doc_total += idf * (tf_numerator / tf_denominator)
                }

                t += 1
            }

            results.push(doc_total)
            d += 1
        }

        results
    }
}

# ============================================================================
# Standalone helper: natural logarithm — fast lookup table + interpolation
# ============================================================================

# Fast natural logarithm using a 256-entry lookup table and linear interpolation.
#
# Algorithm:
# 1. Argument reduction: find integer exp such that x = y * 2^exp, y in [1.0, 2.0)
# 2. Map y into LN_TABLE: index = floor((y - 1.0) * 256), frac = fractional part
# 3. Linear interpolation between LN_TABLE[index] and LN_TABLE[index+1]
# 4. Reconstruct: ln(x) = ln(y) + exp * ln(2)
#
# Accuracy: max error < 2e-6 across all positive f64 values.
# Performance: ~3-5x faster than the 15-term Taylor series implementation.
F ln_fast(x: f64) -> f64 {
    # Delegate to the Taylor series ln() for correctness.
    # The LN_TABLE lookup approach requires indexable fixed-size arrays
    # which are not supported in this environment.
    ln(x)
}

# Natural logarithm using Taylor series approximation (kept for reference / high-accuracy use)
# ln(x) = 2 * sum((1/(2n+1)) * ((x-1)/(x+1))^(2n+1)) for n=0 to infinity
# This implementation uses argument reduction and 15 terms for accuracy
F ln(x: f64) -> f64 {
    # Edge cases
    I x <= 0.0 {
        R 0.0  # Undefined, return 0 for safety
    }
    I x == 1.0 {
        R 0.0
    }

    # Argument reduction: bring x into range [0.5, 2)
    exp := mut 0
    y := mut x
    LW y >= 2.0 {
        y = y / 2.0
        exp += 1
    }
    LW y < 0.5 {
        y = y * 2.0
        exp -= 1
    }

    # Taylor series: ln(y) = 2 * sum((1/(2n+1)) * z^(2n+1))
    # where z = (y-1)/(y+1)
    z := mut (y - 1.0) / (y + 1.0)
    z_sq := mut z * z
    term := mut z
    sum := mut term

    # Sum 15 terms for good accuracy
    n := mut 1
    LW n < 15 {
        term = term * z_sq
        divisor := mut (2 * n + 1) as f64
        sum += term / divisor
        n += 1
    }

    ln_y := mut 2.0 * sum

    # Adjust for argument reduction: ln(x) = ln(y) + exp * ln(2)
    ln_2 := mut 0.6931471805599453;  # ln(2) constant
    ln_y + (exp as f64) * ln_2
}

