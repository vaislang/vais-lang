# Dirty Page Tracker
# Tracks which frames are dirty and need flushing during checkpoint
# Maintains a dirty page table for crash recovery

use std/sync
use storage/buffer/frame

# Entry in the dirty page table
struct DirtyPageEntry {
    location: PageLocation,
    first_dirty_lsn: u64,   # LSN when page first became dirty (for recovery)
    frame_id: u32,
}

# Dirty page tracker
struct DirtyTracker {
    entries: Vec<DirtyPageEntry>,
    lock: Mutex<()>,
}

impl DirtyTracker {
    fn new() -> DirtyTracker {
        DirtyTracker {
            entries: Vec.with_capacity(0),
            lock: Mutex.new(()),
        }
    }

    # Mark a page as dirty
    fn mark_dirty(mut self, frame_id: u32, location: PageLocation, lsn: u64) {
        guard := mut self.lock.lock()

        # Check if already tracked
        i := mut 0
        LW i < self.entries.len() {
            I self.entries[i].frame_id == frame_id {
                # Already dirty, keep the earlier first_dirty_lsn
                guard.unlock()
                return
            }
            i += 1
        }

        self.entries.push(DirtyPageEntry {
            location,
            first_dirty_lsn: lsn,
            frame_id,
        })

        guard.unlock()
    }

    # Mark a page as clean (flushed to disk)
    fn mark_clean(mut self, frame_id: u32) {
        guard := mut self.lock.lock()

        i := mut 0
        removed := mut false
        LW i < self.entries.len() && !removed {
            I self.entries[i].frame_id == frame_id {
                last_idx := mut self.entries.len() - 1
                I i != last_idx {
                    # Swap with last element before pop (manual swap-remove)
                    last_entry_loc := mut self.entries[last_idx].location
                    last_entry_lsn := mut self.entries[last_idx].first_dirty_lsn
                    last_entry_fid := mut self.entries[last_idx].frame_id
                    self.entries[i].location = last_entry_loc
                    self.entries[i].first_dirty_lsn = last_entry_lsn
                    self.entries[i].frame_id = last_entry_fid
                }
                self.entries.pop()
                removed = true
            } else {
                i += 1
            }
        }

        guard.unlock()
    }

    # Get all dirty page entries (for checkpoint)
    fn get_dirty_pages(self) -> Vec<DirtyPageEntry> {
        guard := mut self.lock.lock()
        result := mut self.entries.clone()
        guard.unlock()
        result
    }

    # Get count of dirty pages
    fn dirty_count(self) -> u32 {
        guard := mut self.lock.lock()
        count := mut self.entries.len() as u32
        guard.unlock()
        count
    }

    # Get the minimum first_dirty_lsn (for recovery start point)
    fn min_dirty_lsn(self) -> u64 {
        guard := mut self.lock.lock()
        min_lsn := mut 0u64
        has_min := mut false
        i := mut 0
        LW i < self.entries.len() {
            I !has_min {
                min_lsn = self.entries[i].first_dirty_lsn
                has_min = true
            } else I self.entries[i].first_dirty_lsn < min_lsn {
                min_lsn = self.entries[i].first_dirty_lsn
            }
            i += 1
        }
        guard.unlock()
        min_lsn
    }

    # Clear all entries (after full flush)
    fn clear(mut self) {
        guard := mut self.lock.lock()
        self.entries.clear()
        guard.unlock()
    }

    fn drop(mut self) {
        # self.entries.drop() # disabled for dev compiler
        # self.lock.drop() # disabled for dev compiler
    }

    # Check if a specific page is dirty
    fn is_dirty(self, file_id: u8, page_id: u32) -> bool {
        guard := mut self.lock.lock()
        i := mut 0
        LW i < self.entries.len() {
            I self.entries[i].location.file_id == file_id &&
              self.entries[i].location.page_id == page_id {
                guard.unlock()
                return true
            }
            i += 1
        }
        guard.unlock()
        false
    }
}
