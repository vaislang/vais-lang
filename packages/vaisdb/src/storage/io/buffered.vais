# Buffered I/O fallback for page access
# Uses pread/pwrite for positioned I/O (no seek needed)
# Fallback when mmap is unavailable or undesirable

use storage/file
use std/vec
use storage/constants
use storage/error

# Buffered I/O page access
struct BufferedIO {
    file: File,
    page_size: u32,
}

impl BufferedIO {
    # Create buffered I/O wrapper for a file
    fn new(file: File, page_size: u32) -> BufferedIO {
        BufferedIO { file, page_size }
    }

    fn clone(&self) -> BufferedIO {
        BufferedIO {
            file: self.file.clone(),
            page_size: self.page_size,
        }
    }

    # Read a page at the given page_id
    fn read_page(self, page_id: u32) -> Result<Vec<u8>, VaisError> {
        offset := mut (page_id as u64) * (self.page_size as u64)
        self.file.read_at(offset, self.page_size as u64)
    }

    # Write a page at the given page_id
    fn write_page(self, page_id: u32, data: &Vec<u8>) -> Result<(), VaisError> {
        offset := mut (page_id as u64) * (self.page_size as u64)
        self.file.write_vec_at(offset, data)?;
        Ok(())
    }

    # Sync written data to disk
    fn sync(self) -> Result<(), VaisError> {
        self.file.fsync()
    }

    # Sync data only (no metadata) - faster than fsync
    fn datasync(self) -> Result<(), VaisError> {
        self.file.fdatasync()
    }

    # Read multiple contiguous pages (for read-ahead)
    fn read_pages(self, start_page_id: u32, count: u32) -> Result<Vec<u8>, VaisError> {
        offset := mut (start_page_id as u64) * (self.page_size as u64)
        total_size := mut (count as u64) * (self.page_size as u64)
        self.file.read_at(offset, total_size as u64)
    }

    # Write multiple contiguous pages
    fn write_pages(self, start_page_id: u32, data: &[u8]) -> Result<(), VaisError> {
        offset := mut (start_page_id as u64) * (self.page_size as u64)
        self.file.write_at(offset, data)?;
        Ok(())
    }

    # Get file size in pages
    fn page_count(self) -> Result<u32, VaisError> {
        file_size := mut self.file.size()?;
        Ok((file_size / self.page_size as u64) as u32)
    }

    # Extend file by N pages
    fn extend(self, additional_pages: u32) -> Result<(), VaisError> {
        current_size := mut self.file.size()?;
        new_size := mut current_size + (additional_pages as u64) * (self.page_size as u64)
        self.file.truncate(new_size)?;
        Ok(())
    }

    # Get underlying file reference
    fn get_file(self) -> &File {
        &self.file
    }

    fn close(mut self) -> Result<(), VaisError> {
        self.file.close()
        Ok(())
    }
}
