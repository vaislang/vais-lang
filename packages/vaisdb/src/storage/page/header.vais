# Unified Page Header (48 bytes)
# All 4 engines share this header. Every page on disk begins with these 48 bytes.
# Fields ordered for natural alignment: u64 at 8-byte, u32 at 4-byte, u16 at 2-byte boundaries.

use storage/bytes
use storage/constants
use storage/error
use storage/checksum
use storage/page/types
use storage/page/flags
use std/hash

fn write_checksum_slice(page_data: &mut [u8], checksum: u32) {
    page_data[20] = (checksum & 255) as u8
    page_data[21] = ((checksum >> 8) & 255) as u8
    page_data[22] = ((checksum >> 16) & 255) as u8
    page_data[23] = ((checksum >> 24) & 255) as u8
}

fn write_checksum_vec(page_data: &Vec<u8>, checksum: u32) {
    page_data[20] = (checksum & 255) as u8
    page_data[21] = ((checksum >> 8) & 255) as u8
    page_data[22] = ((checksum >> 16) & 255) as u8
    page_data[23] = ((checksum >> 24) & 255) as u8
}

struct PageHeader {
    page_lsn: u64,           # LSN of last WAL record that modified this page
    txn_id: u64,             # Transaction that last modified this page
    page_id: u32,            # Unique page identifier (0 = meta page)
    checksum: u32,           # CRC32C of entire page (excluding this field during calc)
    prev_page: u32,          # Previous page in chain (0 = none)
    next_page: u32,          # Next page in chain (0 = none)
    overflow_page: u32,      # First overflow page (0 = none)
    free_space_offset: u16,  # Offset to start of free space within page
    item_count: u16,         # Number of items/tuples/entries in this page
    flags: u16,              # Bit flags (see page/flags.vais)
    reserved: u16,           # Reserved for future use (must be 0)
    page_type: u8,           # Page type (see page/types.vais)
    engine_tag: u8,          # Engine that owns this page
    compression_algo: u8,    # 0=none, 1=lz4, 2=zstd
    format_version: u8,      # Page format version (starts at 1)
}

impl PageHeader {
    # Create a new page header with defaults
    fn new(page_id: u32, page_type: u8, engine_tag: u8) -> PageHeader {
        PageHeader {
            page_lsn: 0,
            txn_id: 0,
            page_id,
            checksum: 0,
            prev_page: NULL_PAGE,
            next_page: NULL_PAGE,
            overflow_page: NULL_PAGE,
            free_space_offset: PAGE_HEADER_SIZE as u16,
            item_count: 0,
            flags: 0,
            reserved: 0,
            page_type,
            engine_tag,
            compression_algo: COMPRESSION_NONE,
            format_version: 1,
        }
    }

    # Create an unused/empty page header
    fn unused(page_id: u32) -> PageHeader {
        PageHeader.new(page_id, PAGE_TYPE_UNUSED, ENGINE_TAG_COMMON)
    }

    # Serialize page header to ByteBuffer (writes exactly 48 bytes)
    fn serialize(self, buf: &mut ByteBuffer) {
        buf.write_i64_le(self.page_lsn)
        buf.write_i64_le(self.txn_id)
        buf.write_i32_le(self.page_id)
        buf.write_i32_le(self.checksum)
        buf.write_i32_le(self.prev_page)
        buf.write_i32_le(self.next_page)
        buf.write_i32_le(self.overflow_page)
        buf.write_u16_le(self.free_space_offset)
        buf.write_u16_le(self.item_count)
        buf.write_u16_le(self.flags)
        buf.write_u16_le(self.reserved)
        buf.write_u8(self.page_type)
        buf.write_u8(self.engine_tag)
        buf.write_u8(self.compression_algo)
        buf.write_u8(self.format_version)
    }

    # Deserialize page header from ByteBuffer (reads exactly 48 bytes)
    fn deserialize(buf: &ByteBuffer) -> Result<PageHeader, VaisError> {
        Ok(PageHeader {
            page_lsn: read_i64_le_checked(buf)?,
            txn_id: read_i64_le_checked(buf)?,
            page_id: read_i32_le_checked(buf)?,
            checksum: read_i32_le_checked(buf)?,
            prev_page: read_i32_le_checked(buf)?,
            next_page: read_i32_le_checked(buf)?,
            overflow_page: read_i32_le_checked(buf)?,
            free_space_offset: read_u16_le_checked(buf)?,
            item_count: read_u16_le_checked(buf)?,
            flags: read_u16_le_checked(buf)?,
            reserved: read_u16_le_checked(buf)?,
            page_type: read_u8_checked(buf)?,
            engine_tag: read_u8_checked(buf)?,
            compression_algo: read_u8_checked(buf)?,
            format_version: read_u8_checked(buf)?,
        })
    }

    # Serialize page header directly into a page-sized byte array at offset 0
    fn write_to_page(self, page_data: &mut [u8]) {
        buf := mut ByteBuffer.with_capacity(PAGE_HEADER_SIZE as u64)
        self.serialize(&buf)
        header_bytes := mut buf.to_vec()
        LF i: 0..header_bytes.len() {
            page_data[i] = header_bytes[i]
        }
    }

    # Vec-backed variant for callers that hold a Vec<u8>.
    fn write_to_page_vec(self, page_data: &Vec<u8>) {
        buf := mut ByteBuffer.with_capacity(PAGE_HEADER_SIZE as u64)
        self.serialize(&buf)
        header_bytes := mut buf.to_vec()
        LF i: 0..header_bytes.len() {
            page_data[i] = header_bytes[i]
        }
    }

    # Read page header from a page-sized byte array at offset 0
    fn read_from_page(page_data: &[u8]) -> Result<PageHeader, VaisError> {
        buf := mut ByteBuffer.wrap_readonly(page_data);
        PageHeader.deserialize(&buf)
    }

    # Vec-backed variant for callers that hold a BufferPool page Vec.
    fn read_from_page_vec(page_data: &Vec<u8>) -> Result<PageHeader, VaisError> {
        PageHeader.read_from_page(page_data)
    }

    # Update the checksum field in a Vec-backed page buffer.
    # Must be called AFTER all page content is written.
    fn update_checksum(page_data: &Vec<u8>) {
        checksum := mut calculate_page_checksum(page_data)
        write_checksum_vec(page_data, checksum)
    }

    # Update the checksum field in any mutable page slice.
    fn update_checksum_slice(page_data: &mut [u8]) {
        checksum := mut calculate_page_checksum_mut(page_data)
        write_checksum_slice(page_data, checksum)
    }

    fn update_checksum_vec(page_data: &Vec<u8>) {
        PageHeader.update_checksum(page_data)
    }

    # Check if this page has a valid chain link
    fn has_next(self) -> bool {
        self.next_page != NULL_PAGE
    }

    fn has_prev(self) -> bool {
        self.prev_page != NULL_PAGE
    }

    fn has_overflow(self) -> bool {
        self.overflow_page != NULL_PAGE
    }

    # Get PageFlags wrapper
    fn get_flags(self) -> PageFlags {
        PageFlags.from_bits(self.flags)
    }

    # Set flags from PageFlags wrapper
    fn set_flags(mut self, flags: PageFlags) {
        self.flags = flags.to_bits()
    }
}
