# Table Scan and Index Scan Executors
# TableScan: sequential heap page scan with predicate pushdown + MVCC visibility
# IndexScan: B+Tree range scan → TID lookup → heap tuple fetch + MVCC visibility
# Both produce ExecutorRow one at a time (Volcano iterator model)

use storage/error
use storage/constants
use storage/buffer/pool
use storage/page/heap
use storage/page/tuple
use storage/page/mvcc
use storage/txn/visibility
use storage/txn/snapshot
use storage/txn/clog
use storage/btree/tree
use storage/btree/search
use storage/btree/cursor
use storage/btree/entry
use storage/btree/key
use storage/bytes
use sql/types
use sql/row
use sql/catalog/schema
use sql/executor/mod
use sql/executor/expr_eval
use sql/parser/ast

# ============================================================================
# TableScanExecutor — Full table scan
# ============================================================================

# Scans all heap pages for a table, checking MVCC visibility per tuple.
# Supports optional predicate pushdown (WHERE clause filter).
struct TableScanExecutor {
    table_info: TableInfo,
    columns: Vec<ColumnInfo>,
    schema: Vec<SqlType>,          # Column types for row decoding
    filter: Option<Expr>,          # Pushed-down WHERE predicate
    eval_ctx: EvalContext,         # Column bindings for expression evaluation

    # Iterator state
    current_page_id: u32,          # Current heap page being scanned
    current_slot: u16,             # Current slot within the page
    current_page: Option<HeapPage>,  # Loaded heap page
    is_open: bool,
    is_exhausted: bool,

    # Stats
    stats: ExecStats,
}

impl TableScanExecutor {
    # Create a new table scan executor
    fn new(
        table_info: TableInfo,
        columns: Vec<ColumnInfo>,
        filter: Option<Expr>,
    ) -> TableScanExecutor {
        # Build schema types array from columns
        schema := mut Vec.with_capacity(columns.len())
        LF col: &columns {
            schema.push(col.data_type)
        }

        # Build evaluation context
        eval_ctx := mut EvalContext.from_columns(&table_info.name, columns.as_slice())

        TableScanExecutor {
            table_info,
            columns,
            schema,
            filter,
            eval_ctx,
            current_page_id: 0,
            current_slot: 0,
            current_page: None,
            is_open: false,
            is_exhausted: false,
            stats: ExecStats.new(),
        }
    }

    # Open the executor — initialize to the first heap page
    fn open(mut self, ctx: &ExecContext) -> Result<(), VaisError> {
        self.current_page_id = self.table_info.first_page_id
        self.current_slot = 0
        self.is_open = true
        self.is_exhausted = false

        # Load the first page
        self.load_page(ctx)?;

        Ok(())
    }

    # Get next visible row matching the filter
    # Returns None when scan is exhausted
    fn next(mut self, ctx: &ExecContext) -> Result<Option<ExecutorRow>, VaisError> {
        I !self.is_open || self.is_exhausted {
            return Ok(None)
        }

        L {
            # Try to get a tuple from the current page
            _scan_next := self.try_next_from_current_page(ctx)?;
            match _scan_next {
                Some(row) => { return Ok(Some(row)) },
                None => {
                    # Current page exhausted, move to next page
                    advanced := self.advance_page(ctx)?;
                    I !advanced {
                        # No more pages
                        self.is_exhausted = true
                        return Ok(None)
                    }
                    # Continue loop with new page
                },
            }
        }
    }

    # Close the executor — release resources
    fn close(mut self) {
        self.current_page = None
        self.is_open = false
    }

    # Get execution statistics
    fn get_stats(self) -> &ExecStats {
        &self.stats
    }

    # ========================================================================
    # Internal methods
    # ========================================================================

    # Load the current page into memory
    fn load_page(mut self, ctx: &ExecContext) -> Result<(), VaisError> {
        I self.current_page_id == 0 || self.current_page_id == NULL_PAGE {
            self.is_exhausted = true
            return Ok(())
        }

        frame_id := mut ctx.pool.fetch_page(FILE_ID_DATA, self.current_page_id)?;
        page_data := mut ctx.pool.get_page(frame_id)
        heap := mut HeapPage.from_page_data(page_data, ctx.pool.page_size)?;
        ctx.pool.unpin_page(frame_id, false)

        self.current_page = Some(heap)
        self.current_slot = 0
        self.stats.add_page_read()

        Ok(())
    }

    # Try to get the next visible, filter-matching tuple from the current page
    fn try_next_from_current_page(mut self, ctx: &ExecContext) -> Result<Option<ExecutorRow>, VaisError> {
        heap := mut match &self.current_page {
            Some(h) => h,
            None => { return Ok(None); },
        }

        LW self.current_slot < heap.item_count() {
            slot_idx := mut self.current_slot
            self.current_slot += 1
            self.stats.add_scanned(1)

            # Try to read the tuple (skip dead slots)
            tuple_result := mut heap.read_tuple(slot_idx)
            match tuple_result {
                Ok(t) => {
                    # MVCC visibility check
                    mvcc := mut t.get_mvcc()
                    I is_tuple_visible(
                        mvcc.txn_id_create,
                        mvcc.txn_id_expire,
                        mvcc.cmd_id,
                        mvcc.expire_cmd_id,
                        ctx.snapshot,
                        ctx.clog,
                    ) {
                        # Decode tuple data into a Row
                        row := mut Row.decode(t.get_data().as_slice(), self.schema.as_slice())?;

                        # Apply pushed-down filter
                        passed_filter := mut true
                        match &self.filter {
                            Some(filter_expr) => {
                                _pred := eval_predicate(filter_expr, &row, &self.eval_ctx)?;
                                I !_pred {
                                    self.stats.add_rejected()
                                    passed_filter = false
                                }
                            },
                            None => {},
                        }

                        I passed_filter {
                            self.stats.add_produced()
                            return Ok(Some(ExecutorRow.with_alias(
                                row,
                                self.table_info.name.clone(),
                                self.current_page_id,
                                slot_idx,
                            )))
                        }
                    }
                },
                Err(_) => {},  # Dead or corrupt slot, skip
            }
        }

        Ok(None)
    }

    # Advance to the next heap page
    # Returns false if no more pages
    fn advance_page(mut self, ctx: &ExecContext) -> Result<bool, VaisError> {
        heap := mut match &self.current_page {
            Some(h) => h,
            None => { return Ok(false); },
        }

        # Follow the next_page link in the page header
        next := mut heap.get_header().next_page
        I next == 0 || next == NULL_PAGE {
            return Ok(false)
        }

        self.current_page_id = next
        self.load_page(ctx)?;

        Ok(!self.is_exhausted)
    }
}

# ============================================================================
# IndexScanExecutor — B+Tree index scan
# ============================================================================

# Scans a B+Tree index within a key range, fetches heap tuples by TID,
# checks MVCC visibility, and optionally applies a residual filter.
# Much faster than TableScan for selective queries (small result set).
struct IndexScanExecutor {
    table_info: TableInfo,
    columns: Vec<ColumnInfo>,
    schema: Vec<SqlType>,          # Column types for row decoding
    index_info: IndexInfo,         # Index being scanned
    key_range: KeyRange,           # Scan bounds
    residual_filter: Option<Expr>, # Filter for conditions not covered by index
    eval_ctx: EvalContext,

    # Iterator state
    cursor: Option<BTreeCursor>,   # Current position in B+Tree
    is_open: bool,
    is_exhausted: bool,

    # Stats
    stats: ExecStats,
}

impl IndexScanExecutor {
    # Create a new index scan executor
    fn new(
        table_info: TableInfo,
        columns: Vec<ColumnInfo>,
        index_info: IndexInfo,
        key_range: KeyRange,
        residual_filter: Option<Expr>,
    ) -> IndexScanExecutor {
        schema := mut Vec.with_capacity(columns.len())
        LF col: &columns {
            schema.push(col.data_type)
        }

        eval_ctx := mut EvalContext.from_columns(&table_info.name, columns.as_slice())

        IndexScanExecutor {
            table_info,
            columns,
            schema,
            index_info,
            key_range,
            residual_filter,
            eval_ctx,
            cursor: None,
            is_open: false,
            is_exhausted: false,
            stats: ExecStats.new(),
        }
    }

    # Open the executor — position the B+Tree cursor at the start of the range
    fn open(mut self, ctx: &ExecContext) -> Result<(), VaisError> {
        # Step 13 A4-10: explicit init of all required BTree fields.
        # Previously entry_count + latch_table relied on silent zero-init.
        tree := mut BTree {
            file_id: FILE_ID_DATA,
            root_page_id: self.index_info.root_page_id,
            page_size: ctx.pool.page_size,
            height: 0,  # Will be determined during traversal
            entry_count: 0,
            latch_table: LatchTable::new(DEFAULT_LATCH_CAPACITY),
        }

        cursor := mut match &self.key_range.start {
            Some(start_key) => {
                search_lower_bound(&tree, start_key, ctx.pool)?;
            },
            None => {
                search_first(&tree, ctx.pool)?;
            },
        }

        # If start is exclusive, skip entries equal to start key
        I cursor.valid() && !self.key_range.start_inclusive {
            match &self.key_range.start {
                Some(start_key) => {
                    entry := mut cursor.current(ctx.pool)?;
                    key := mut entry.key
                    match compare_keys(&key, start_key) {
                        Equal => {
                            cursor.next(ctx.pool)?;
                        },
                        _ => {},
                    }
                },
                None => {},
            }
        }

        self.cursor = Some(cursor)
        self.is_open = true
        self.is_exhausted = false

        Ok(())
    }

    # Get next visible row matching the filter
    fn next(mut self, ctx: &ExecContext) -> Result<Option<ExecutorRow>, VaisError> {
        I !self.is_open || self.is_exhausted {
            return Ok(None)
        }

        cursor := mut match &self.cursor {
            Some(c) => c,
            None => { return Ok(None); },
        }

        LW cursor.valid() {
            entry := mut cursor.current(ctx.pool)?;
            key := mut entry.key
            tid := mut entry.tid

            # Check if we've passed the end of the range
            I self.key_range.is_past_end(&key) {
                self.is_exhausted = true
                return Ok(None)
            }

            self.stats.add_scanned(1)

            # Decode TID to locate the heap tuple
            decoded_tid := mut decode_tid(tid)
            page_id := mut decoded_tid.page_id
            slot_id := mut decoded_tid.slot_id

            # Fetch the heap page and read the tuple
            frame_id := mut ctx.pool.fetch_page(FILE_ID_DATA, page_id)?;
            page_data := mut ctx.pool.get_page(frame_id)
            heap := mut HeapPage.from_page_data(page_data, ctx.pool.page_size)?;
            tuple_result := mut heap.read_tuple(slot_id)
            ctx.pool.unpin_page(frame_id, false)
            self.stats.add_page_read()

            match tuple_result {
                Ok(t) => {
                    # MVCC visibility check
                    mvcc := mut t.get_mvcc()
                    I is_tuple_visible(
                        mvcc.txn_id_create,
                        mvcc.txn_id_expire,
                        mvcc.cmd_id,
                        mvcc.expire_cmd_id,
                        ctx.snapshot,
                        ctx.clog,
                    ) {
                        # Decode tuple data into a Row
                        row := mut Row.decode(t.get_data().as_slice(), self.schema.as_slice())?;

                        # Apply residual filter (for conditions not covered by the index)
                        passed_filter := mut true
                        match &self.residual_filter {
                            Some(filter_expr) => {
                                _pred := eval_predicate(filter_expr, &row, &self.eval_ctx)?;
                                I !_pred {
                                    self.stats.add_rejected()
                                    passed_filter = false
                                }
                            },
                            None => {},
                        }

                        I passed_filter {
                            self.stats.add_produced()
                            cursor.next(ctx.pool)?;

                            return Ok(Some(ExecutorRow.with_alias(
                                row,
                                self.table_info.name.clone(),
                                page_id,
                                slot_id,
                            )))
                        }
                    }
                },
                Err(_) => {},  # Dead tuple, skip
            }

            cursor.next(ctx.pool)?;
        }

        self.is_exhausted = true
        Ok(None)
    }

    # Close the executor
    fn close(mut self, ctx: &ExecContext) {
        match &self.cursor {
            Some(c) => { c.close(ctx.pool); },
            None => {},
        }
        self.cursor = None
        self.is_open = false
    }

    # Get execution statistics
    fn get_stats(self) -> &ExecStats {
        &self.stats
    }
}

# ============================================================================
# Index Key Builders — convert SqlValues to B+Tree key bytes
# ============================================================================

# Build a B+Tree index key from one or more SqlValues (composite key support)
# Key format: concatenation of each value's byte encoding (type-tagged for sort correctness)
# Ordering: type_tag(1B) + value_bytes (big-endian for correct lexicographic order)
fn exe_build_index_key(values: &[SqlValue]) -> Vec<u8> {
    key := mut Vec.with_capacity(32)
    LF val: values {
        encode_key_value(&key, val)
    }
    key
}

# Encode a single SqlValue into index key bytes
# Uses big-endian encoding so that byte comparison matches value comparison
fn encode_key_value(key: &mut Vec<u8>, val: &SqlValue) {
    match val {
        Null => {
            key.push(0);  # NULL sorts lowest
        },
        SqlValue.IntVal { v } => {
            key.push(1);  # INT tag
            # Encode i64 as big-endian with sign bit flipped for correct unsigned ordering
            unsigned := mut (*v as u64) ^ (1u64 << 63)
            key.push(((unsigned >> 56) & 255) as u8)
            key.push(((unsigned >> 48) & 255) as u8)
            key.push(((unsigned >> 40) & 255) as u8)
            key.push(((unsigned >> 32) & 255) as u8)
            key.push(((unsigned >> 24) & 255) as u8)
            key.push(((unsigned >> 16) & 255) as u8)
            key.push(((unsigned >> 8) & 255) as u8)
            key.push((unsigned & 255) as u8)
        },
        SqlValue.FloatVal { v } => {
            key.push(2);  # FLOAT tag
            # IEEE 754 double: flip sign bit; if negative, flip all bits
            bits := mut v.to_bits()
            I (*v) < 0.0 {
                bits = ~bits
            } else {
                bits = bits ^ (1u64 << 63)
            }
            key.push(((bits >> 56) & 255) as u8)
            key.push(((bits >> 48) & 255) as u8)
            key.push(((bits >> 40) & 255) as u8)
            key.push(((bits >> 32) & 255) as u8)
            key.push(((bits >> 24) & 255) as u8)
            key.push(((bits >> 16) & 255) as u8)
            key.push(((bits >> 8) & 255) as u8)
            key.push((bits & 255) as u8)
        },
        SqlValue.BoolVal { v } => {
            key.push(3);  # BOOL tag
            key.push(I *v { 1 } else { 0 })
        },
        SqlValue.StringVal { v } => {
            key.push(4);  # STRING tag
            # Store string bytes directly (UTF-8 preserves lexicographic order for ASCII)
            LF b: v.as_bytes() {
                key.push(*b)
            }
            key.push(0);  # Null terminator for correct prefix comparison
        },
        SqlValue.DateVal { v } => {
            key.push(5);  # DATE tag
            unsigned := mut (*v as u32) ^ 2147483648
            key.push(((unsigned >> 24) & 255) as u8)
            key.push(((unsigned >> 16) & 255) as u8)
            key.push(((unsigned >> 8) & 255) as u8)
            key.push((unsigned & 255) as u8)
        },
        SqlValue.TimestampVal { v } => {
            key.push(6);  # TIMESTAMP tag
            unsigned := mut (*v as u64) ^ (1u64 << 63)
            key.push(((unsigned >> 56) & 255) as u8)
            key.push(((unsigned >> 48) & 255) as u8)
            key.push(((unsigned >> 40) & 255) as u8)
            key.push(((unsigned >> 32) & 255) as u8)
            key.push(((unsigned >> 24) & 255) as u8)
            key.push(((unsigned >> 16) & 255) as u8)
            key.push(((unsigned >> 8) & 255) as u8)
            key.push((unsigned & 255) as u8)
        },
        SqlValue.BlobVal { v } => {
            key.push(7);  # BLOB tag
            LF b: v {
                key.push(*b)
            }
            key.push(0);  # Null terminator
        },
        SqlValue.VectorVal { .. } => {
            # Vectors are not indexable in B+Tree (use HNSW)
            key.push(255)
        },
    }
}

# Build index key from a Row using the index's column positions
# column_indices maps index columns to row column positions
fn build_index_key_from_row(row: &Row, column_indices: &[u64]) -> Vec<u8> {
    values := mut Vec.with_capacity(column_indices.len())
    LF idx: column_indices {
        values.push(row.get(*idx).clone())
    }
    exe_build_index_key(values.as_slice())
}

# Resolve index column names to row column indices
fn resolve_index_columns(
    index_columns: &[str],
    table_columns: &[ColumnInfo],
) -> Result<Vec<u64>, VaisError> {
    indices := mut Vec.with_capacity(index_columns.len())
    LF idx_col: index_columns {
        found := mut false
        LF i: 0..table_columns.len() {
            I !found && &table_columns[i].name == idx_col {
                indices.push(i)
                found = true
            }
        }
        I !found {
            return Err(err_internal("Index column '{idx_col}' not found in table"))
        }
    }
    Ok(indices)
}

# ============================================================================
# ProjectionExecutor — SELECT list column projection
# ============================================================================

# Projects specific columns or expressions from input rows
# Wraps any scan executor to produce the desired output schema
struct ProjectionExecutor {
    # Indices into the input row for simple column references
    # For expression-based projections, use expr_eval
    projections: Vec<ProjectionItem>,
    eval_ctx: EvalContext,
}

enum ProjectionItem {
    ColumnIndex { idx: u64 },
    Expression { expr: Expr, alias: Option<str> },
}

impl ProjectionExecutor {
    fn new(projections: Vec<ProjectionItem>, eval_ctx: EvalContext) -> ProjectionExecutor {
        ProjectionExecutor {
            projections,
            eval_ctx,
        }
    }

    # Project a single input row to the output schema
    fn project(self, input: &ExecutorRow) -> Result<Row, VaisError> {
        values := mut Vec.with_capacity(self.projections.len())
        LF proj: &self.projections {
            match proj {
                ColumnIndex { idx } => {
                    values.push(input.get(*idx).clone())
                },
                Expression { expr, alias: _ } => {
                    val := mut eval_expr(expr, input.get_row(), &self.eval_ctx)?;
                    values.push(val)
                },
            }
        }
        Ok(Row.new(values))
    }
}

use sql/executor/expr_eval
