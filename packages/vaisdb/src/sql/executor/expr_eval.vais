# Expression Evaluator
# Evaluates AST Expr nodes against a row to produce SqlValue results
# Used by WHERE clause filtering, SELECT list projection, and other contexts
# Supports NULL propagation per SQL 3-valued logic

U storage/error
U sql/types
U sql/row
U sql/parser/ast

# ============================================================================
# Column Binding — maps column references to row positions
# ============================================================================

S ColumnBinding {
    table: Option<str>,
    column: str,
    index: u64,          # Position in the row's values array
    data_type: SqlType,
}

X ColumnBinding {
    F new(column: str, index: u64, data_type: SqlType) -> ColumnBinding {
        ColumnBinding {
            table: None,
            column,
            index,
            data_type,
        }
    }

    F with_table(table: str, column: str, index: u64, data_type: SqlType) -> ColumnBinding {
        ColumnBinding {
            table: Some(table),
            column,
            index,
            data_type,
        }
    }
}

# ============================================================================
# EvalContext — bindings available during expression evaluation
# ============================================================================

S EvalContext {
    bindings: Vec<ColumnBinding>,
}

X EvalContext {
    F new() -> EvalContext {
        EvalContext {
            bindings: Vec.with_capacity(0),
        }
    }

    F add_binding(mut self, binding: ColumnBinding) {
        self.bindings.push(binding)
    }

    # Resolve a column reference to a row index
    # Handles both qualified (table.column) and unqualified (column) references
    F resolve(self, table: &Option<str>, column: &str) -> Result<u64, VaisError> {
        M table {
            Some(tbl) => {
                # Qualified reference: M both table and column
                LF b: &self.bindings {
                    M &b.table {
                        Some(bt) => {
                            I bt == tbl && &b.column == column {
                                R Ok(b.index)
                            }
                        },
                        None => {},
                    }
                }
                Err(VaisError.new(
                    "VAIS-0110002",
                    "Column '{tbl}.{column}' not found"
                ))
            },
            None => {
                # Unqualified reference: M column name only
                found := mut None
                ambiguous := mut false
                LF b: &self.bindings {
                    I &b.column == column {
                        M found {
                            Some(_) => { ambiguous = true; },
                            None => { found = Some(b.index); },
                        }
                    }
                }
                I ambiguous {
                    R Err(VaisError.new(
                        "VAIS-0101001",
                        "Column reference '{column}' is ambiguous"
                    ))
                }
                M found {
                    Some(idx) => Ok(idx),
                    None => Err(VaisError.new(
                        "VAIS-0110002",
                        "Column '{column}' not found"
                    )),
                }
            },
        }
    }

    # Build context from a table's column list
    F from_columns(table_name: &str, columns: &[ColumnInfo]) -> EvalContext {
        ctx := mut EvalContext.new()
        LF i: 0..columns.len() {
            col := mut &columns[i]
            ctx.add_binding(ColumnBinding.with_table(
                table_name.clone(),
                col.name.clone(),
                i,
                col.data_type,
            ))
        }
        ctx
    }
}

U sql/catalog/schema

# ============================================================================
# Expression Evaluation — main entry point
# ============================================================================

# Evaluate an expression against a row, returning a SqlValue
F eval_expr(expr: &Expr, row: &Row, ctx: &EvalContext) -> Result<SqlValue, VaisError> {
    M expr {
        # Literal value
        Literal { value } => {
            Ok(value.clone())
        },

        # Column reference
        ColumnRef { table, column } => {
            idx := mut ctx.resolve(table, column)?;
            Ok(row.get(idx).clone())
        },

        # Binary operation
        BinaryOp { left, op, right } => {
            eval_binary_op(left, op, right, row, ctx)
        },

        # Unary operation
        UnaryOp { op, operand } => {
            eval_unary_op(op, operand, row, ctx)
        },

        # IS NULL / IS NOT NULL
        IsNull { expr: inner, negated } => {
            val := mut eval_expr(inner, row, ctx)?;
            result := mut val.is_null()
            I *negated { result = !result; }
            Ok(BoolVal { v: result })
        },

        # BETWEEN
        Between { expr: inner, low, high, negated } => {
            val := mut eval_expr(inner, row, ctx)?;
            low_val := mut eval_expr(low, row, ctx)?;
            high_val := mut eval_expr(high, row, ctx)?;
            result := mut val.between(&low_val, &high_val)
            I *negated {
                Ok(result.not_bool())
            } EL {
                Ok(result)
            }
        },

        # IN list
        InList { expr: inner, list, negated } => {
            val := mut eval_expr(inner, row, ctx)?;
            list_vals := mut Vec.with_capacity(list.len())
            LF item: list {
                list_vals.push(eval_expr(item, row, ctx)?)
            }
            result := mut val.in_list(list_vals.as_slice())
            I *negated {
                Ok(result.not_bool())
            } EL {
                Ok(result)
            }
        },

        # LIKE
        Like { expr: inner, pattern, negated } => {
            val := mut eval_expr(inner, row, ctx)?;
            pat := mut eval_expr(pattern, row, ctx)?;
            result := mut val.like_match(&pat)
            I *negated {
                Ok(result.not_bool())
            } EL {
                Ok(result)
            }
        },

        # CASE WHEN
        Case { operand, when_clauses, else_result } => {
            eval_case(operand, when_clauses, else_result, row, ctx)
        },

        # CAST
        Cast { expr: inner, target_type } => {
            val := mut eval_expr(inner, row, ctx)?;
            val.cast_to(target_type)
        },

        # Function call (aggregate functions handled separately in aggregation executor)
        FunctionCall { name, args, distinct: _ } => {
            eval_scalar_function(name, args, row, ctx)
        },

        # String concatenation
        Concat { left, right } => {
            lv := mut eval_expr(left, row, ctx)?;
            rv := mut eval_expr(right, row, ctx)?;

            # NULL propagation
            I lv.is_null() || rv.is_null() {
                R Ok(Null)
            }

            ls := mut lv.to_string()
            rs := mut rv.to_string()
            # Remove surrounding quotes from to_string output for StringVal
            left_str := mut M &lv {
                StringVal { v } => v.clone(),
                _ => ls,
            }
            right_str := mut M &rv {
                StringVal { v } => v.clone(),
                _ => rs,
            }
            Ok(StringVal { v: "{left_str}{right_str}" })
        },

        # Star (*) — used in COUNT(*), returns a non-null marker
        Star => {
            Ok(BoolVal { v: true })
        },

        # Parameter — should have been substituted by prepared statement binding
        Parameter { idx } => {
            Err(VaisError.new(
                "VAIS-0105001",
                "Unbound parameter ${idx}"
            ))
        },

        # Subquery expressions — evaluated by higher-level executor
        Subquery { .. } | InSubquery { .. } | Exists { .. } => {
            Err(VaisError.new(
                "VAIS-0105002",
                "Subquery evaluation not yet supported in expression evaluator"
            ))
        },

        # Window functions — handled by window executor
        WindowFunc { .. } => {
            Err(VaisError.new(
                "VAIS-0105003",
                "Window function cannot be evaluated in expression context"
            ))
        },
    }
}

# ============================================================================
# Binary Operation Evaluation
# ============================================================================

F eval_binary_op(
    left: &Expr,
    op: &BinOp,
    right: &Expr,
    row: &Row,
    ctx: &EvalContext,
) -> Result<SqlValue, VaisError> {
    lv := mut eval_expr(left, row, ctx)?;
    rv := mut eval_expr(right, row, ctx)?;

    M op {
        # Arithmetic
        Add => lv.add(&rv),
        Sub => lv.sub(&rv),
        Mul => lv.mul(&rv),
        Div => lv.div(&rv),
        Mod => {
            # NULL propagation
            I lv.is_null() || rv.is_null() {
                R Ok(Null)
            }
            M (&lv, &rv) {
                (IntVal { v: a }, IntVal { v: b }) => {
                    I *b == 0 {
                        R Err(VaisError.new("VAIS-0109003", "Division by zero"))
                    }
                    Ok(IntVal { v: *a % *b })
                },
                _ => Err(err_incompatible_types("modulo", lv.get_type().name(), rv.get_type().name())),
            }
        },

        # Comparison
        Eq => Ok(lv.equals(&rv)),
        Neq => {
            eq := mut lv.equals(&rv)
            Ok(eq.not_bool())
        },
        Lt => {
            I lv.is_null() || rv.is_null() {
                R Ok(Null)
            }
            cmp := mut lv.compare(&rv)?;
            Ok(BoolVal { v: cmp < 0 })
        },
        Gt => {
            I lv.is_null() || rv.is_null() {
                R Ok(Null)
            }
            cmp := mut lv.compare(&rv)?;
            Ok(BoolVal { v: cmp > 0 })
        },
        Le => {
            I lv.is_null() || rv.is_null() {
                R Ok(Null)
            }
            cmp := mut lv.compare(&rv)?;
            Ok(BoolVal { v: cmp <= 0 })
        },
        Ge => {
            I lv.is_null() || rv.is_null() {
                R Ok(Null)
            }
            cmp := mut lv.compare(&rv)?;
            Ok(BoolVal { v: cmp >= 0 })
        },

        # Logical (3-valued with NULL propagation)
        And => Ok(lv.and_bool(&rv)),
        Or => Ok(lv.or_bool(&rv)),
    }
}

# ============================================================================
# Unary Operation Evaluation
# ============================================================================

F eval_unary_op(
    op: &UnaryOp,
    operand: &Expr,
    row: &Row,
    ctx: &EvalContext,
) -> Result<SqlValue, VaisError> {
    val := mut eval_expr(operand, row, ctx)?;

    M op {
        Neg => val.negate(),
        Not => Ok(val.not_bool()),
    }
}

# ============================================================================
# CASE WHEN Evaluation
# ============================================================================

F eval_case(
    operand: &Option<Box<Expr>>,
    when_clauses: &[WhenClause],
    else_result: &Option<Box<Expr>>,
    row: &Row,
    ctx: &EvalContext,
) -> Result<SqlValue, VaisError> {
    M operand {
        Some(op_expr) => {
            # Simple CASE: CASE expr WHEN val THEN result ...
            op_val := mut eval_expr(op_expr, row, ctx)?;
            LF wc: when_clauses {
                when_val := mut eval_expr(&wc.condition, row, ctx)?;
                eq := mut op_val.equals(&when_val)
                M eq {
                    BoolVal { v: true } => {
                        R eval_expr(&wc.result, row, ctx)
                    },
                    _ => {},
                }
            }
        },
        None => {
            # Searched CASE: CASE WHEN condition THEN result ...
            LF wc: when_clauses {
                cond := mut eval_expr(&wc.condition, row, ctx)?;
                M cond {
                    BoolVal { v: true } => {
                        R eval_expr(&wc.result, row, ctx)
                    },
                    _ => {},
                }
            }
        },
    }

    # No WHEN clause matched — return ELSE or NULL
    M else_result {
        Some(else_expr) => eval_expr(else_expr, row, ctx),
        None => Ok(Null),
    }
}

# ============================================================================
# Scalar Function Evaluation
# ============================================================================

F eval_scalar_function(
    name: &str,
    args: &[Expr],
    row: &Row,
    ctx: &EvalContext,
) -> Result<SqlValue, VaisError> {
    upper_name := mut name.to_uppercase()

    M upper_name.as_str() {
        "COALESCE" => {
            # COALESCE(a, b, c, ...) returns first non-NULL
            LF arg: args {
                val := mut eval_expr(arg, row, ctx)?;
                I !val.is_null() {
                    R Ok(val)
                }
            }
            Ok(Null)
        },

        "NULLIF" => {
            # NULLIF(a, b) returns NULL if a = b, else a
            I args.len() != 2 {
                R Err(VaisError.new("VAIS-0101002", "NULLIF requires exactly 2 arguments"))
            }
            a := mut eval_expr(&args[0], row, ctx)?;
            b := mut eval_expr(&args[1], row, ctx)?;
            M a.equals(&b) {
                BoolVal { v: true } => Ok(Null),
                _ => Ok(a),
            }
        },

        "ABS" => {
            I args.len() != 1 {
                R Err(VaisError.new("VAIS-0101002", "ABS requires exactly 1 argument"))
            }
            val := mut eval_expr(&args[0], row, ctx)?;
            I val.is_null() { R Ok(Null); }
            M val {
                IntVal { v } => Ok(IntVal { v: I v < 0 { -v } EL { v } }),
                FloatVal { v } => Ok(FloatVal { v: I v < 0.0 { -v } EL { v } }),
                _ => Err(err_type_mismatch("numeric", val.get_type().name())),
            }
        },

        "UPPER" => {
            I args.len() != 1 {
                R Err(VaisError.new("VAIS-0101002", "UPPER requires exactly 1 argument"))
            }
            val := mut eval_expr(&args[0], row, ctx)?;
            I val.is_null() { R Ok(Null); }
            M val {
                StringVal { v } => Ok(StringVal { v: v.to_uppercase() }),
                _ => Err(err_type_mismatch("string", val.get_type().name())),
            }
        },

        "LOWER" => {
            I args.len() != 1 {
                R Err(VaisError.new("VAIS-0101002", "LOWER requires exactly 1 argument"))
            }
            val := mut eval_expr(&args[0], row, ctx)?;
            I val.is_null() { R Ok(Null); }
            M val {
                StringVal { v } => Ok(StringVal { v: v.to_lowercase() }),
                _ => Err(err_type_mismatch("string", val.get_type().name())),
            }
        },

        "LENGTH" => {
            I args.len() != 1 {
                R Err(VaisError.new("VAIS-0101002", "LENGTH requires exactly 1 argument"))
            }
            val := mut eval_expr(&args[0], row, ctx)?;
            I val.is_null() { R Ok(Null); }
            M val {
                StringVal { v } => Ok(IntVal { v: v.len() as i64 }),
                BlobVal { v } => Ok(IntVal { v: v.len() as i64 }),
                _ => Err(err_type_mismatch("string or blob", val.get_type().name())),
            }
        },

        "SUBSTR" | "SUBSTRING" => {
            I args.len() < 2 || args.len() > 3 {
                R Err(VaisError.new("VAIS-0101002", "SUBSTR requires 2 or 3 arguments"))
            }
            val := mut eval_expr(&args[0], row, ctx)?;
            start := mut eval_expr(&args[1], row, ctx)?;
            I val.is_null() || start.is_null() { R Ok(Null); }

            M (&val, &start) {
                (StringVal { v: s }, IntVal { v: pos }) => {
                    # SQL SUBSTR is 1-based
                    start_idx := mut I *pos < 1 { 0u64 } EL { (*pos - 1) as u64 }
                    chars := mut s.chars().collect()
                    I start_idx >= chars.len() {
                        R Ok(StringVal { v: "" })
                    }

                    end_idx := mut I args.len() == 3 {
                        len_val := mut eval_expr(&args[2], row, ctx)?;
                        I len_val.is_null() { R Ok(Null); }
                        M len_val {
                            IntVal { v: l } => {
                                end := mut start_idx + (I l < 0 { 0u64 } EL { l as u64 })
                                I end > chars.len() { chars.len() } EL { end }
                            },
                            _ => chars.len(),
                        }
                    } EL {
                        chars.len()
                    }

                    # TODO: implement substring extraction
                    result := mut ""
                    Ok(StringVal { v: result })
                },
                _ => Err(err_type_mismatch("string, integer", val.get_type().name())),
            }
        },

        _ => {
            Err(VaisError.new(
                "VAIS-0110003",
                "Unknown function '{name}'"
            ))
        },
    }
}

# ============================================================================
# Predicate Evaluation Helper
# ============================================================================

# Evaluate an expression and interpret the result as a boolean
# NULL is treated as false (for WHERE clause semantics)
F eval_predicate(expr: &Expr, row: &Row, ctx: &EvalContext) -> Result<bool, VaisError> {
    val := mut eval_expr(expr, row, ctx)?;
    M val {
        BoolVal { v } => Ok(v),
        Null => Ok(false),  # NULL in WHERE -> false
        _ => Err(VaisError.new(
            "VAIS-0109001",
            "WHERE clause must evaluate to boolean, got {val.get_type().name()}"
        )),
    }
}
