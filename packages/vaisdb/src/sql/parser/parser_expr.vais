# SQL Parser — Expression parsing
# Handles: precedence climbing (OR < AND < NOT < comparison < addition < multiplication < unary < primary),
#          literals, function calls, CASE, CAST, window functions, subqueries

U storage/error
U sql/types
U sql/parser/token
U sql/parser/ast
U sql/parser/parser

X Parser {
    # Entry point for expression parsing
    F parse_expr(mut self) -> Result<Expr, VaisError> {
        self.parse_or_expr()
    }

    # OR (lowest precedence)
    F parse_or_expr(mut self) -> Result<Expr, VaisError> {
        left := mut self.parse_and_expr()?;

        L self.match_token(Or) {
            right := self.parse_and_expr()?;
            left = BinaryOp {
                left: Box.new(left),
                op: Or,
                right: Box.new(right),
            }
        }

        Ok(left)
    }

    # AND
    F parse_and_expr(mut self) -> Result<Expr, VaisError> {
        left := mut self.parse_not_expr()?;

        L self.match_token(And) {
            right := self.parse_not_expr()?;
            left = BinaryOp {
                left: Box.new(left),
                op: And,
                right: Box.new(right),
            }
        }

        Ok(left)
    }

    # NOT (prefix unary)
    F parse_not_expr(mut self) -> Result<Expr, VaisError> {
        I self.match_token(Not) {
            operand := self.parse_not_expr()?;
            Ok(UnaryOp { op: Not, operand: Box.new(operand) })
        } E {
            self.parse_comparison()
        }
    }

    # Comparison: =, <>, <, >, <=, >=, IS [NOT] NULL, BETWEEN, IN, LIKE, EXISTS
    F parse_comparison(mut self) -> Result<Expr, VaisError> {
        # Handle EXISTS (subquery) at comparison level
        I self.match_token(Exists) {
            self.expect(LParen)?;
            query := self.parse_select()?;
            self.expect(RParen)?;
            R Ok(Exists { query: Box.new(query), negated: false })
        }

        # Handle NOT EXISTS (subquery)
        I self.check(Not) {
            saved_pos := self.pos
            self.advance()
            I self.match_token(Exists) {
                self.expect(LParen)?;
                query := self.parse_select()?;
                self.expect(RParen)?;
                R Ok(Exists { query: Box.new(query), negated: true })
            }
            # Not NOT EXISTS, backtrack
            self.pos = saved_pos
        }

        expr := mut self.parse_addition()?;

        # Check for comparison operators and postfix operators
        more_ops := mut true
        L more_ops {
            M self.peek() {
                Eq => {
                    self.advance()
                    right := self.parse_addition()?;
                    expr = BinaryOp { left: Box.new(expr), op: Eq, right: Box.new(right) }
                },
                Neq => {
                    self.advance()
                    right := self.parse_addition()?;
                    expr = BinaryOp { left: Box.new(expr), op: Neq, right: Box.new(right) }
                },
                Lt => {
                    self.advance()
                    right := self.parse_addition()?;
                    expr = BinaryOp { left: Box.new(expr), op: Lt, right: Box.new(right) }
                },
                Gt => {
                    self.advance()
                    right := self.parse_addition()?;
                    expr = BinaryOp { left: Box.new(expr), op: Gt, right: Box.new(right) }
                },
                Le => {
                    self.advance()
                    right := self.parse_addition()?;
                    expr = BinaryOp { left: Box.new(expr), op: Le, right: Box.new(right) }
                },
                Ge => {
                    self.advance()
                    right := self.parse_addition()?;
                    expr = BinaryOp { left: Box.new(expr), op: Ge, right: Box.new(right) }
                },
                Is => {
                    self.advance()
                    negated := mut false
                    I self.match_token(Not) {
                        negated = true
                    }
                    self.expect(Null)?;
                    expr = IsNull { expr: Box.new(expr), negated }
                },
                Between => {
                    self.advance()
                    low := self.parse_addition()?;
                    self.expect(And)?;
                    high := self.parse_addition()?;
                    expr = Between {
                        expr: Box.new(expr),
                        low: Box.new(low),
                        high: Box.new(high),
                        negated: false,
                    }
                },
                Not => {
                    # NOT BETWEEN, NOT IN, NOT LIKE
                    saved_pos := self.pos
                    self.advance()
                    M self.peek() {
                        Between => {
                            self.advance()
                            low := self.parse_addition()?;
                            self.expect(And)?;
                            high := self.parse_addition()?;
                            expr = Between {
                                expr: Box.new(expr),
                                low: Box.new(low),
                                high: Box.new(high),
                                negated: true,
                            }
                        },
                        In => {
                            self.advance()
                            expr = self.parse_in_expr(expr, true)?;
                        },
                        Like => {
                            self.advance()
                            pattern := self.parse_addition()?;
                            expr = Like {
                                expr: Box.new(expr),
                                pattern: Box.new(pattern),
                                negated: true,
                            }
                        },
                        _ => {
                            # Not a postfix NOT, backtrack
                            self.pos = saved_pos
                            more_ops = false
                        },
                    }
                },
                In => {
                    self.advance()
                    expr = self.parse_in_expr(expr, false)?;
                },
                Like => {
                    self.advance()
                    pattern := self.parse_addition()?;
                    expr = Like {
                        expr: Box.new(expr),
                        pattern: Box.new(pattern),
                        negated: false,
                    }
                },
                _ => {
                    more_ops = false
                },
            }
        }

        Ok(expr)
    }

    # Parse IN (list) or IN (subquery) after the IN keyword
    F parse_in_expr(mut self, left: Expr, negated: bool) -> Result<Expr, VaisError> {
        self.expect(LParen)?;

        # Distinguish subquery from value list by checking for SELECT/WITH
        M self.peek() {
            Select | With => {
                query := self.parse_select()?;
                self.expect(RParen)?;
                Ok(InSubquery {
                    expr: Box.new(left),
                    query: Box.new(query),
                    negated,
                })
            },
            _ => {
                list := mut Vec.with_capacity(0)
                I !self.check(RParen) {
                    more_list := mut true
                    L more_list {
                        expr := self.parse_expr()?;
                        list.push(expr)
                        I !self.match_token(Comma) {
                            more_list = false
                        }
                    }
                }
                self.expect(RParen)?;
                Ok(InList {
                    expr: Box.new(left),
                    list,
                    negated,
                })
            },
        }
    }

    # Addition/subtraction and string concatenation (||)
    F parse_addition(mut self) -> Result<Expr, VaisError> {
        left := mut self.parse_multiplication()?;

        more_add := mut true
        L more_add {
            M self.peek() {
                Plus => {
                    self.advance()
                    right := self.parse_multiplication()?;
                    left = BinaryOp { left: Box.new(left), op: Add, right: Box.new(right) }
                },
                Minus => {
                    self.advance()
                    right := self.parse_multiplication()?;
                    left = BinaryOp { left: Box.new(left), op: Sub, right: Box.new(right) }
                },
                Pipe => {
                    self.advance()
                    right := self.parse_multiplication()?;
                    left = Concat { left: Box.new(left), right: Box.new(right) }
                },
                _ => {
                    more_add = false
                },
            }
        }

        Ok(left)
    }

    # Multiplication, division, modulo
    F parse_multiplication(mut self) -> Result<Expr, VaisError> {
        left := mut self.parse_unary()?;

        more_mul := mut true
        L more_mul {
            M self.peek() {
                Star => {
                    self.advance()
                    right := self.parse_unary()?;
                    left = BinaryOp { left: Box.new(left), op: Mul, right: Box.new(right) }
                },
                Slash => {
                    self.advance()
                    right := self.parse_unary()?;
                    left = BinaryOp { left: Box.new(left), op: Div, right: Box.new(right) }
                },
                Percent => {
                    self.advance()
                    right := self.parse_unary()?;
                    left = BinaryOp { left: Box.new(left), op: Mod, right: Box.new(right) }
                },
                _ => {
                    more_mul = false
                },
            }
        }

        Ok(left)
    }

    # Unary minus and NOT
    F parse_unary(mut self) -> Result<Expr, VaisError> {
        I self.match_token(Minus) {
            operand := self.parse_unary()?;
            R Ok(UnaryOp { op: Neg, operand: Box.new(operand) })
        }

        self.parse_primary()
    }

    # Primary expressions: literals, identifiers, function calls, parenthesized
    # expressions, CASE, CAST, subquery, parameter marker, star
    F parse_primary(mut self) -> Result<Expr, VaisError> {
        M self.peek() {
            # Integer literal
            IntLit { .. } => {
                tok := self.advance()
                M tok.kind {
                    IntLit { v } => Ok(Literal { value: IntVal { v } }),
                    _ => Err(self.parse_error("internal error: expected integer literal")),
                }
            },
            # Float literal
            FloatLit { .. } => {
                tok := self.advance()
                M tok.kind {
                    FloatLit { v } => Ok(Literal { value: FloatVal { v } }),
                    _ => Err(self.parse_error("internal error: expected float literal")),
                }
            },
            # String literal
            StringLit { .. } => {
                tok := self.advance()
                M tok.kind {
                    StringLit { v } => Ok(Literal { value: StringVal { v } }),
                    _ => Err(self.parse_error("internal error: expected string literal")),
                }
            },
            # TRUE literal
            True_Kw => {
                self.advance()
                Ok(Literal { value: BoolVal { v: true } })
            },
            # FALSE literal
            False_Kw => {
                self.advance()
                Ok(Literal { value: BoolVal { v: false } })
            },
            # NULL literal
            Null => {
                self.advance()
                Ok(Literal { value: Null })
            },
            # Parameter marker ($1, $2, ...)
            Parameter { .. } => {
                tok := self.advance()
                M tok.kind {
                    Parameter { idx } => Ok(Parameter { idx }),
                    _ => Err(self.parse_error("internal error: expected parameter")),
                }
            },
            # Star (for COUNT(*))
            Star => {
                self.advance()
                Ok(Star)
            },
            # CASE expression
            Case => {
                self.parse_case_expr()
            },
            # CAST expression
            Cast => {
                self.parse_cast_expr()
            },
            # EXISTS (subquery) -- also handled in comparison, but can appear as primary
            Exists => {
                self.advance()
                self.expect(LParen)?;
                query := self.parse_select()?;
                self.expect(RParen)?;
                Ok(Exists { query: Box.new(query), negated: false })
            },
            # Aggregate / window function keywords: COUNT, SUM, AVG, MIN, MAX
            Count | Sum | Avg |
            Min | Max => {
                self.parse_aggregate_function()
            },
            # Window function keywords: ROW_NUMBER, RANK, DENSE_RANK
            Row_Number | Rank | Dense_Rank => {
                self.parse_window_function_keyword()
            },
            # Parenthesized expression or scalar subquery
            LParen => {
                self.advance()
                # Check if it is a subquery
                M self.peek() {
                    Select | With => {
                        query := self.parse_select()?;
                        self.expect(RParen)?;
                        Ok(Subquery { query: Box.new(query) })
                    },
                    _ => {
                        expr := self.parse_expr()?;
                        self.expect(RParen)?;
                        Ok(expr)
                    },
                }
            },
            # Identifier: column reference, table.column, or function call
            Identifier { .. } => {
                self.parse_identifier_expr()
            },
            _ => {
                Err(self.parse_error("expected expression"))
            },
        }
    }

    # Parse an identifier expression: column ref, table.column, or function call
    F parse_identifier_expr(mut self) -> Result<Expr, VaisError> {
        name := self.expect_identifier()?;

        # Check for function call: name(...)
        I self.check(LParen) {
            R self.parse_function_call(name)
        }

        # Check for table.column reference
        I self.match_token(Dot) {
            column := self.expect_identifier()?;
            R Ok(ColumnRef { table: Option.Some(name), column })
        }

        # Plain column reference
        Ok(ColumnRef { table: Option.None, column: name })
    }

    # Parse a function call: name(args...) with optional DISTINCT and OVER clause
    F parse_function_call(mut self, name: str) -> Result<Expr, VaisError> {
        self.expect(LParen)?;

        # Check for empty arg list
        I self.match_token(RParen) {
            func_expr := FunctionCall { name, args: Vec.with_capacity(0), distinct: false }
            # Check for OVER clause (window function)
            R self.maybe_parse_over(func_expr)
        }

        # Check for DISTINCT keyword
        distinct := mut false
        I self.match_token(Distinct) {
            distinct = true
        }

        # Check for * (e.g., COUNT(*))
        I self.match_token(Star) {
            self.expect(RParen)?;
            func_expr := FunctionCall {
                name,
                args: Vec.from([Star]),
                distinct: false,
            }
            R self.maybe_parse_over(func_expr)
        }

        # Parse argument list
        args := mut Vec.with_capacity(0)
        more_args := mut true
        L more_args {
            arg := self.parse_expr()?;
            args.push(arg)
            I !self.match_token(Comma) {
                more_args = false
            }
        }
        self.expect(RParen)?;

        func_expr := FunctionCall { name, args, distinct }
        # Check for OVER clause (window function)
        self.maybe_parse_over(func_expr)
    }

    # Parse an aggregate function keyword (COUNT, SUM, AVG, MIN, MAX)
    F parse_aggregate_function(mut self) -> Result<Expr, VaisError> {
        tok := self.advance()
        name := M tok.kind {
            Count => "COUNT",
            Sum => "SUM",
            Avg => "AVG",
            Min => "MIN",
            Max => "MAX",
            _ => "UNKNOWN",
        }
        self.parse_function_call(name.to_string())
    }

    # Parse a window function keyword (ROW_NUMBER, RANK, DENSE_RANK)
    F parse_window_function_keyword(mut self) -> Result<Expr, VaisError> {
        tok := self.advance()
        name := M tok.kind {
            Row_Number => "ROW_NUMBER",
            Rank => "RANK",
            Dense_Rank => "DENSE_RANK",
            _ => "UNKNOWN",
        }
        self.parse_function_call(name.to_string())
    }

    # If an OVER clause follows, wrap the expression as a WindowFunc
    F maybe_parse_over(mut self, func: Expr) -> Result<Expr, VaisError> {
        I !self.match_token(Over) {
            R Ok(func)
        }

        self.expect(LParen)?;

        # Parse optional PARTITION BY
        partition_by := mut Vec.with_capacity(0)
        I self.match_token(Partition) {
            self.expect(By)?;
            more_parts := mut true
            L more_parts {
                expr := self.parse_expr()?;
                partition_by.push(expr)
                I !self.match_token(Comma) {
                    more_parts = false
                }
            }
        }

        # Parse optional ORDER BY
        order_by := mut Vec.with_capacity(0)
        I self.match_token(Order) {
            self.expect(By)?;
            more_order := mut true
            L more_order {
                expr := self.parse_expr()?;
                asc := mut true
                I self.match_token(Asc) {
                    asc = true
                } E I self.match_token(Desc) {
                    asc = false
                }
                nulls_first := mut Option.None
                I self.match_token(Nulls) {
                    I self.match_token(First) {
                        nulls_first = Option.Some(true)
                    } E I self.match_token(Last) {
                        nulls_first = Option.Some(false)
                    } E {
                        R Err(self.parse_error("expected FIRST or LAST after NULLS"))
                    }
                }
                order_by.push(OrderByItem { expr, asc, nulls_first })
                I !self.match_token(Comma) {
                    more_order = false
                }
            }
        }

        self.expect(RParen)?;

        Ok(WindowFunc {
            func: Box.new(func),
            partition_by,
            order_by,
        })
    }

    # Parse CASE [operand] WHEN condition THEN result ... [ELSE result] END
    F parse_case_expr(mut self) -> Result<Expr, VaisError> {
        self.expect(Case)?;

        # Check for simple CASE (CASE expr WHEN ...) vs searched CASE (CASE WHEN ...)
        operand := mut Option.None
        I !self.check(When) {
            expr := self.parse_expr()?;
            operand = Option.Some(Box.new(expr))
        }

        # Parse WHEN clauses
        when_clauses := mut Vec.with_capacity(0)
        L self.match_token(When) {
            condition := self.parse_expr()?;
            self.expect(Then)?;
            result := self.parse_expr()?;
            when_clauses.push(WhenClause { condition, result })
        }

        I when_clauses.len() == 0 {
            R Err(self.parse_error("CASE expression must have at least one WHEN clause"))
        }

        # Parse optional ELSE
        else_result := mut Option.None
        I self.match_token(Else) {
            expr := self.parse_expr()?;
            else_result = Option.Some(Box.new(expr))
        }

        self.expect(End)?;

        Ok(Case { operand, when_clauses, else_result })
    }

    # Parse CAST(expr AS type)
    F parse_cast_expr(mut self) -> Result<Expr, VaisError> {
        self.expect(Cast)?;
        self.expect(LParen)?;
        expr := self.parse_expr()?;
        self.expect(As)?;
        target_type := self.parse_data_type()?;
        self.expect(RParen)?;
        Ok(Cast { expr: Box.new(expr), target_type })
    }
}
