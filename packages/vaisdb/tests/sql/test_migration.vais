# Migration Framework Tests
# Tests: Migration.new(), MigrationRunner.add(), MigrationTracker.record_applied(),
#         MigrationRunner.apply_all(), rollback_last(), status()

U std/test.{assert_eq, assert_true, assert_false, describe, it};

U sql/migrate/migration.{Migration, MigrationRecord, MigrationStatus};
U sql/migrate/tracker.{MigrationTracker};
U sql/migrate/runner.{MigrationRunner};

# ============================================================================
# Migration.new() — struct creation
# ============================================================================

describe("Migration.new") {
    it("should create a migration with correct fields") {
        m := mut Migration.new(
            1,
            "create_users_table",
            "CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT)",
            "DROP TABLE users"
        )
        assert_eq(m.version, 1)
        assert_eq(m.name, "create_users_table")
        assert_eq(m.up_sql, "CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT)")
        assert_eq(m.down_sql, "DROP TABLE users")
        assert_eq(m.timestamp, 0)
    }

    it("should create multiple migrations with different versions") {
        m1 := mut Migration.new(1, "add_users", "CREATE TABLE users (id INTEGER)", "DROP TABLE users")
        m2 := mut Migration.new(2, "add_posts", "CREATE TABLE posts (id INTEGER)", "DROP TABLE posts")
        assert_eq(m1.version, 1)
        assert_eq(m2.version, 2)
        assert_eq(m1.name, "add_users")
        assert_eq(m2.name, "add_posts")
    }
}

# ============================================================================
# MigrationRunner.add() — migration registration
# ============================================================================

describe("MigrationRunner.add") {
    it("should register a migration") {
        runner := mut MigrationRunner.new()
        m := mut Migration.new(1, "init_schema", "CREATE TABLE t (id INTEGER)", "DROP TABLE t")
        runner.add(m)
        assert_eq(runner.migrations.len(), 1)
    }

    it("should register multiple migrations") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.add(Migration.new(2, "m2", "CREATE TABLE b (id INTEGER)", "DROP TABLE b"))
        runner.add(Migration.new(3, "m3", "CREATE TABLE c (id INTEGER)", "DROP TABLE c"))
        assert_eq(runner.migrations.len(), 3)
    }
}

# ============================================================================
# MigrationTracker — record_applied, is_applied, get_applied_versions
# ============================================================================

describe("MigrationTracker") {
    it("should start with no applied versions") {
        tracker := mut MigrationTracker.new()
        versions := mut tracker.get_applied_versions()
        assert_eq(versions.len(), 0)
    }

    it("should record_applied and detect with is_applied") {
        tracker := mut MigrationTracker.new()
        tracker.record_applied(1, "create_users")
        assert_true(tracker.is_applied(1))
        assert_false(tracker.is_applied(2))
    }

    it("should record multiple applied versions") {
        tracker := mut MigrationTracker.new()
        tracker.record_applied(1, "m1")
        tracker.record_applied(2, "m2")
        tracker.record_applied(3, "m3")
        versions := mut tracker.get_applied_versions()
        assert_eq(versions.len(), 3)
        assert_true(tracker.is_applied(1))
        assert_true(tracker.is_applied(2))
        assert_true(tracker.is_applied(3))
    }

    it("should record_failed and not count as applied") {
        tracker := mut MigrationTracker.new()
        tracker.record_failed(5, "bad_migration")
        assert_false(tracker.is_applied(5))
        versions := mut tracker.get_applied_versions()
        assert_eq(versions.len(), 0)
    }

    it("should remove_record and update is_applied") {
        tracker := mut MigrationTracker.new()
        tracker.record_applied(1, "m1")
        tracker.record_applied(2, "m2")
        assert_true(tracker.is_applied(1))
        tracker.remove_record(1)
        assert_false(tracker.is_applied(1))
        assert_true(tracker.is_applied(2))
    }

    it("should return correct max_applied_version") {
        tracker := mut MigrationTracker.new()
        assert_eq(tracker.max_applied_version(), -1)
        tracker.record_applied(3, "m3")
        tracker.record_applied(1, "m1")
        tracker.record_applied(7, "m7")
        assert_eq(tracker.max_applied_version(), 7)
    }

    it("should generate init SQL") {
        tracker := mut MigrationTracker.new()
        sql := mut tracker.init()
        assert_eq(sql, "CREATE TABLE IF NOT EXISTS _vaisdb_migrations (version INTEGER PRIMARY KEY, name TEXT NOT NULL, applied_at INTEGER NOT NULL, status TEXT NOT NULL)")
    }
}

# ============================================================================
# MigrationRunner.apply_all() — sequential apply
# ============================================================================

describe("MigrationRunner.apply_all") {
    it("should apply all pending migrations in version order") {
        runner := mut MigrationRunner.new()
        # Register out of order to verify sort
        runner.add(Migration.new(3, "m3", "CREATE TABLE c (id INTEGER)", "DROP TABLE c"))
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.add(Migration.new(2, "m2", "CREATE TABLE b (id INTEGER)", "DROP TABLE b"))

        result := mut runner.apply_all()
        assert_true(result.is_ok())
        count := mut result!
        assert_eq(count, 3)

        assert_true(runner.tracker.is_applied(1))
        assert_true(runner.tracker.is_applied(2))
        assert_true(runner.tracker.is_applied(3))
    }

    it("should return 0 when all migrations already applied") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.apply_all()
        result := mut runner.apply_all()
        assert_true(result.is_ok())
        count := mut result!
        assert_eq(count, 0)
    }

    it("should return error for migration with empty up_sql") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "bad_migration", "", "DROP TABLE something"))
        result := mut runner.apply_all()
        assert_true(result.is_err())
    }
}

# ============================================================================
# MigrationRunner.apply_one() — single apply
# ============================================================================

describe("MigrationRunner.apply_one") {
    it("should apply a specific pending migration") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.add(Migration.new(2, "m2", "CREATE TABLE b (id INTEGER)", "DROP TABLE b"))

        result := mut runner.apply_one(2)
        assert_true(result.is_ok())
        applied := mut result!
        assert_true(applied)
        assert_true(runner.tracker.is_applied(2))
        assert_false(runner.tracker.is_applied(1))
    }

    it("should return false if already applied") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.apply_one(1)
        result := mut runner.apply_one(1)
        assert_true(result.is_ok())
        applied := mut result!
        assert_false(applied)
    }

    it("should return error for unknown version") {
        runner := mut MigrationRunner.new()
        result := mut runner.apply_one(99)
        assert_true(result.is_err())
    }
}

# ============================================================================
# MigrationRunner.rollback_last() — rollback most recent
# ============================================================================

describe("MigrationRunner.rollback_last") {
    it("should rollback the most recently applied migration") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.add(Migration.new(2, "m2", "CREATE TABLE b (id INTEGER)", "DROP TABLE b"))
        runner.apply_all()

        result := mut runner.rollback_last()
        assert_true(result.is_ok())
        did_rollback := mut result!
        assert_true(did_rollback)

        # Version 2 should now be gone; version 1 should still be applied
        assert_false(runner.tracker.is_applied(2))
        assert_true(runner.tracker.is_applied(1))
    }

    it("should return false when nothing is applied") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        result := mut runner.rollback_last()
        assert_true(result.is_ok())
        did_rollback := mut result!
        assert_false(did_rollback)
    }

    it("should return error for migration with empty down_sql") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", ""))
        runner.apply_one(1)
        result := mut runner.rollback_last()
        assert_true(result.is_err())
    }
}

# ============================================================================
# MigrationRunner.rollback_to() — rollback to version
# ============================================================================

describe("MigrationRunner.rollback_to") {
    it("should rollback down to the target version") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.add(Migration.new(2, "m2", "CREATE TABLE b (id INTEGER)", "DROP TABLE b"))
        runner.add(Migration.new(3, "m3", "CREATE TABLE c (id INTEGER)", "DROP TABLE c"))
        runner.apply_all()

        result := mut runner.rollback_to(1)
        assert_true(result.is_ok())
        count := mut result!
        assert_eq(count, 2)

        assert_true(runner.tracker.is_applied(1))
        assert_false(runner.tracker.is_applied(2))
        assert_false(runner.tracker.is_applied(3))
    }
}

# ============================================================================
# MigrationRunner.status() — migration status listing
# ============================================================================

describe("MigrationRunner.status") {
    it("should show all migrations as Pending before any apply") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.add(Migration.new(2, "m2", "CREATE TABLE b (id INTEGER)", "DROP TABLE b"))

        records := mut runner.status()
        assert_eq(records.len(), 2)

        r0 := mut records[0]
        M r0.status {
            MigrationStatus.Pending => {},
            _ => assert_true(false),
        }
        r1 := mut records[1]
        M r1.status {
            MigrationStatus.Pending => {},
            _ => assert_true(false),
        }
    }

    it("should show Applied status after apply_all") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.add(Migration.new(2, "m2", "CREATE TABLE b (id INTEGER)", "DROP TABLE b"))
        runner.apply_all()

        records := mut runner.status()
        assert_eq(records.len(), 2)

        i := mut 0
        L i < records.len() {
            rec := mut records[i]
            M rec.status {
                MigrationStatus.Applied => {},
                _ => assert_true(false),
            }
            i = i + 1
        }
    }

    it("should show mixed Applied and Pending after partial apply") {
        runner := mut MigrationRunner.new()
        runner.add(Migration.new(1, "m1", "CREATE TABLE a (id INTEGER)", "DROP TABLE a"))
        runner.add(Migration.new(2, "m2", "CREATE TABLE b (id INTEGER)", "DROP TABLE b"))
        runner.apply_one(1)

        records := mut runner.status()
        assert_eq(records.len(), 2)

        # Find the record for version 1 (Applied) and version 2 (Pending)
        applied_count := mut 0
        pending_count := mut 0
        i := mut 0
        L i < records.len() {
            rec := mut records[i]
            M rec.status {
                MigrationStatus.Applied => { applied_count = applied_count + 1 },
                MigrationStatus.Pending => { pending_count = pending_count + 1 },
                _ => {},
            }
            i = i + 1
        }
        assert_eq(applied_count, 1)
        assert_eq(pending_count, 1)
    }
}
