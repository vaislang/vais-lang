# Stage 1: Page Manager Integration Tests
# Tests: page header R/W, checksum verification, heap page ops,
#         freelist allocation, meta page bootstrap, overflow pages

U std/test.{assert_eq, assert_ne, assert_true, assert_false, describe, it};
U std/bytes.{ByteBuffer};

U storage/constants.{
    DEFAULT_PAGE_SIZE, PAGE_HEADER_SIZE, NULL_PAGE, MVCC_TUPLE_META_SIZE,
    FLAG_IS_LEAF, FLAG_IS_ROOT, VAISDB_MAGIC, DB_FORMAT_VERSION,
    PAGE_BODY_SIZE_8K,
};
U storage/page/header.{PageHeader};
U storage/page/types.{PAGE_TYPE_DATA, PAGE_TYPE_BTREE_LEAF, ENGINE_TAG_SQL};
U storage/page/flags.{PageFlags};
U storage/page/meta.{MetaPageHeader};
U storage/page/freelist.{FreelistBitmap};
U storage/page/heap.{HeapPage};
U storage/page/slot.{HeapPageSlot};
U storage/page/mvcc.{MvccTupleMeta};
U storage/page/tuple.{Tuple};
U storage/checksum.{calculate_page_checksum, verify_page_checksum};

describe("Page Header") {
    it("should serialize and deserialize correctly") {
        header := mut PageHeader.new(42, PAGE_TYPE_DATA, ENGINE_TAG_SQL);
        header.item_count = 5;
        header.free_space_offset = 100;

        buf := mut Vec.with_capacity(DEFAULT_PAGE_SIZE as u64);
        buf.resize(DEFAULT_PAGE_SIZE as u64, 0u8);
        bb := mut ByteBuffer.wrap(&buf);
        header.serialize(&bb);

        restored := mut PageHeader.read_from_page(&buf)!;
        assert_eq(restored.page_id, 42);
        assert_eq(restored.page_type, PAGE_TYPE_DATA);
        assert_eq(restored.item_count, 5);
        assert_eq(restored.free_space_offset, 100);
    }

    it("should compute CRC32C checksum over full page") {
        buf := mut Vec.with_capacity(DEFAULT_PAGE_SIZE as u64);
        buf.resize(DEFAULT_PAGE_SIZE as u64, 0u8);

        header := mut PageHeader.new(1, PAGE_TYPE_DATA, ENGINE_TAG_SQL);
        bb := mut ByteBuffer.wrap(&buf);
        header.serialize(&bb);
        PageHeader.update_checksum(&buf);

        assert_true(verify_page_checksum(&buf) as i64);

        # Corrupt a byte → checksum should fail
        buf[100] = 0xFF;
        assert_false(verify_page_checksum(&buf) as i64);
    }

    it("should set and get flags correctly") {
        flags := mut PageFlags.new();
        assert_false(flags.is_leaf() as i64);
        assert_false(flags.is_root() as i64);

        flags.set_leaf(true);
        flags.set_root(true);
        assert_true(flags.is_leaf() as i64);
        assert_true(flags.is_root() as i64);
    }
}

describe("Meta Page") {
    it("should bootstrap with magic number") {
        uuid_data := mut Vec.with_capacity(16);
        uuid_data.resize(16, 1u8);
        meta := mut MetaPageHeader.new(DEFAULT_PAGE_SIZE, uuid_data, 0);
        assert_eq(meta.magic, VAISDB_MAGIC);
        assert_eq(meta.db_format_version, DB_FORMAT_VERSION);
    }

    it("should serialize and deserialize round-trip") {
        uuid_data := mut Vec.with_capacity(16);
        uuid_data.resize(16, 42u8);
        original := mut MetaPageHeader.new(DEFAULT_PAGE_SIZE, uuid_data, 12345);

        # Serialize to a ByteBuffer then deserialize
        bb := mut ByteBuffer.with_capacity(256);
        original.serialize(&bb);
        bb.seek(0);

        restored := mut MetaPageHeader.deserialize(&bb)!;
        assert_eq(restored.magic, original.magic);
        assert_eq(restored.db_format_version, original.db_format_version);
        assert_eq(restored.db_uuid[0], original.db_uuid[0]);
    }
}

describe("Freelist Bitmap") {
    it("should allocate and deallocate pages") {
        pages_per_bitmap := mut PAGE_BODY_SIZE_8K * 8;
        freelist := mut FreelistBitmap.new_all_free();

        # Allocate a page
        page_id_opt := mut freelist.allocate(pages_per_bitmap, 0);
        page_id := mut M page_id_opt {
            Some(v) => v,
            None => 0u32,
        };
        assert_true(freelist.is_allocated(page_id, pages_per_bitmap) as i64);

        # Deallocate
        freelist.deallocate(page_id, pages_per_bitmap);
        assert_false(freelist.is_allocated(page_id, pages_per_bitmap) as i64);
    }

    it("should track free page count") {
        pages_per_bitmap := mut PAGE_BODY_SIZE_8K * 8;
        freelist := mut FreelistBitmap.new_all_free();
        initial_free := mut freelist.free_count(pages_per_bitmap);

        p1_opt := mut freelist.allocate(pages_per_bitmap, 0);
        p1 := mut M p1_opt { Some(v) => v, None => 0u32, };
        p2_opt := mut freelist.allocate(pages_per_bitmap, 0);
        p2 := mut M p2_opt { Some(v) => v, None => 0u32, };
        assert_eq(freelist.free_count(pages_per_bitmap), initial_free - 2);

        freelist.deallocate(p1, pages_per_bitmap);
        assert_eq(freelist.free_count(pages_per_bitmap), initial_free - 1);
    }
}

describe("Heap Page (Slotted)") {
    it("should insert and retrieve tuples") {
        heap := mut HeapPage.new(1, DEFAULT_PAGE_SIZE);
        user_data := mut Vec.with_capacity(8);
        user_data.push(1u8);
        user_data.push(2u8);
        user_data.push(3u8);
        user_data.push(4u8);
        user_data.push(5u8);
        user_data.push(6u8);
        user_data.push(7u8);
        user_data.push(8u8);
        mvcc := mut MvccTupleMeta.new_insert(1, 0);
        tuple := mut Tuple.new(mvcc, user_data);

        slot := mut heap.insert_tuple(&tuple)!;
        retrieved := mut heap.read_tuple(slot)!;
        assert_eq(retrieved.user_data[0], 1u8);
        assert_eq(retrieved.user_data[7], 8u8);
    }

    it("should delete tuples and reclaim space") {
        heap := mut HeapPage.new(1, DEFAULT_PAGE_SIZE);
        data1 := mut Vec.with_capacity(32);
        data1.resize(32, 10u8);
        data2 := mut Vec.with_capacity(32);
        data2.resize(32, 20u8);

        mvcc1 := mut MvccTupleMeta.new_insert(1, 0);
        tuple1 := mut Tuple.new(mvcc1, data1);
        mvcc2 := mut MvccTupleMeta.new_insert(1, 1);
        tuple2 := mut Tuple.new(mvcc2, data2);

        s1 := mut heap.insert_tuple(&tuple1)!;
        s2 := mut heap.insert_tuple(&tuple2)!;
        free_before := mut heap.free_space();

        heap.delete_tuple(s1, 2, 0)!;
        free_after := mut heap.free_space();
        # After deletion, live tuple count is same (tombstone not compacted yet),
        # so free_space may not change until compact. Just check no error.
        assert_true((s2 >= 0) as i64);
    }

    it("should handle MVCC tuple metadata") {
        mvcc := mut MvccTupleMeta.new_insert(100, 0);
        assert_eq(mvcc.txn_id_create, 100);
        assert_eq(mvcc.txn_id_expire, 0);
        assert_eq(mvcc.undo_ptr, 0);

        mvcc.set_expired(200, 1);
        assert_eq(mvcc.txn_id_expire, 200);
        assert_eq(mvcc.expire_cmd_id, 1);
    }
}

describe("Page I/O Round Trip") {
    it("should write and read 10K pages with checksum integrity") {
        # Simulate 10K page writes
        LF i: 0..10000u32 {
            buf := mut Vec.with_capacity(DEFAULT_PAGE_SIZE as u64);
            buf.resize(DEFAULT_PAGE_SIZE as u64, 0u8);

            header := mut PageHeader.new(i, PAGE_TYPE_DATA, ENGINE_TAG_SQL);
            header.item_count = (i % 100) as u16;
            bb := mut ByteBuffer.wrap(&buf);
            header.serialize(&bb);
            PageHeader.update_checksum(&buf);

            # Verify checksum
            assert_true(verify_page_checksum(&buf) as i64);

            # Read back
            restored := mut PageHeader.read_from_page(&buf)!;
            assert_eq(restored.page_id, i);
            assert_eq(restored.item_count, (i % 100) as u16);
        }
    }
}
