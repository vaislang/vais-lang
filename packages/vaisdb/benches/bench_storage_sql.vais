# Storage & SQL Engine Benchmarks
# Benchmarks for B+Tree, buffer pool, WAL, page allocation, SQL DML, JOIN, aggregation, transactions
#
# ROADMAP targets:
# - TPC-B (transactions): Within 2x of SQLite
# - TPC-H (analytics, simplified): Functional correctness
# - Durability: Crash recovery 100% data integrity
# - Concurrency: 64 clients mixed workload

U benches/harness
U std/vec
U std/string
U std/hash

U storage/bytes
U storage/file
U storage/constants
U storage/btree/node
U storage/btree/key
U storage/buffer/pool
U storage/page/manager
U storage/page/allocator
U storage/page/freelist
U storage/page/types
U storage/wal/header
U storage/wal/record_types
U storage/wal/writer

F bench_open_db_file(path: str, size_pages: u32) -> File {
    file := mut File.create(&path)!
    file.truncate((DEFAULT_PAGE_SIZE as u64) * (size_pages as u64))!
    file
}

F bench_page_manager(name: str) -> PageManager {
    base := mut "/tmp/vaisdb_bench_" + &name
    files := mut Vec.new()
    files.push(bench_open_db_file(base.clone() + "_data.vdb", 4096))
    files.push(bench_open_db_file(base.clone() + "_vectors.vdb", 512))
    files.push(bench_open_db_file(base.clone() + "_graph.vdb", 512))
    files.push(bench_open_db_file(base.clone() + "_fulltext.vdb", 512))
    files.push(bench_open_db_file(base.clone() + "_undo.vdb", 512))
    PageManager.new(files, DEFAULT_PAGE_SIZE)
}

F bench_seed_pages(mut pm: &mut PageManager, page_count: u64) {
    i := mut 0
    W i < page_count {
        page := mut pm.allocate_page(FILE_ID_DATA, i as u32, PAGE_TYPE_DATA, ENGINE_TAG_SQL)!
        page.drop()
        i += 1
    }
}

F bench_wal_writer(name: str) -> WalWriter {
    wal_dir := mut "/tmp/vaisdb_bench_wal_" + &name
    create_dir_all(&wal_dir)!
    M read_dir(&wal_dir) {
        Ok(entries) => {
            L entry: &entries {
                remove_file(&entry.path);
            }
        },
        Err(_) => {},
    }
    writer := mut WalWriter.new(wal_dir, DEFAULT_WAL_SEGMENT_SIZE)!
    writer.open()!
    writer
}

F bench_config(name: str, iterations: u64) -> BenchmarkConfig {
    capped := mut I iterations > 3 { 3 } EL { iterations }
    config := mut BenchmarkConfig.quick(name)
    config = config.with_warmup(1)
    config = config.with_cooldown_ms(0)
    config.with_iterations(capped)
}

F bench_noop() {}

F bench_run_simple(
    mut harness: &mut BenchmarkHarness,
    config: &BenchmarkConfig,
    bench_fn: fn() -> u64
) -> BenchmarkResult {
    harness.run(config, bench_noop, bench_fn, bench_noop)
}

F bench_repeat_byte(len: u64, value: u8) -> Vec<u8> {
    buf := mut Vec.with_capacity(len)
    i := mut 0
    W i < len {
        buf.push(value)
        i += 1
    }
    buf
}

# ============================================================================
# B+Tree Benchmarks
# ============================================================================

F bench_btree_insert_1k_iter() -> u64 {
    leaf := mut BTreeLeafNode.new(1, DEFAULT_PAGE_SIZE, true);
    inserted: u64 := mut 0;
    i: u64 := mut 0;
    W i < 1000 {
        key := mut encode_i64_key(i as i64);
        M leaf.insert(&key, i as u32) {
            Ok(()) => { inserted += 1; },
            Err(_) => {},
        }
        i += 1;
    }
    inserted
}

# Benchmark: B+Tree sequential insert (1K keys)
F bench_btree_insert_1k(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("btree_insert_1k", 50);

    bench_run_simple(harness, &config, bench_btree_insert_1k_iter)
}

F bench_btree_insert_10k_iter() -> u64 {
    leaf := mut BTreeLeafNode.new(1, DEFAULT_PAGE_SIZE, true);
    inserted: u64 := mut 0;
    i: u64 := mut 0;
    W i < 10000 {
        key := mut encode_i64_key(i as i64);
        M leaf.insert(&key, i as u32) {
            Ok(()) => { inserted += 1; },
            Err(_) => {},
        }
        i += 1;
    }
    inserted
}

# Benchmark: B+Tree sequential insert (10K keys)
F bench_btree_insert_10k(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("btree_insert_10k", 20);

    bench_run_simple(harness, &config, bench_btree_insert_10k_iter)
}

F bench_btree_insert_100k_iter() -> u64 {
    # Use multiple leaf nodes to hold 100K keys
    total_inserted: u64 := mut 0;
    leaf_count: u64 := mut 0;
    i: u64 := mut 0;

    leaf := mut BTreeLeafNode.new(leaf_count as u32 + 1, DEFAULT_PAGE_SIZE, true);
    W i < 100000 {
        key := mut encode_i64_key(i as i64);
        M leaf.insert(&key, i as u32) {
            Ok(()) => { total_inserted += 1; },
            Err(_) => {
                # Leaf full, create new leaf
                leaf_count += 1;
                leaf = BTreeLeafNode.new(leaf_count as u32 + 1, DEFAULT_PAGE_SIZE, true);
                M leaf.insert(&key, i as u32) {
                    Ok(()) => { total_inserted += 1; },
                    Err(_) => {},
                }
            },
        }
        i += 1;
    }
    total_inserted
}

# Benchmark: B+Tree sequential insert (100K keys, leaf-level only)
F bench_btree_insert_100k(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("btree_insert_100k", 10);

    bench_run_simple(harness, &config, bench_btree_insert_100k_iter)
}

F bench_btree_search_iter(leaf: &BTreeLeafNode, max_keys: u64) -> u64 {
    found: u64 := mut 0;
    i: u64 := mut 0;
    W i < max_keys {
        key := mut encode_i64_key(i as i64);
        M leaf.get_tid(&key) {
            Some(_) => { found += 1; },
            None => {},
        }
        i += 1;
    }
    found
}

F bench_build_full_leaf() -> BTreeLeafNode {
    leaf := mut BTreeLeafNode.new(1, DEFAULT_PAGE_SIZE, true);
    k: u64 := mut 0;
    filled := mut false;
    W !filled {
        key := mut encode_i64_key(k as i64);
        M leaf.insert(&key, k as u32) {
            Ok(()) => { k += 1; },
            Err(_) => { filled = true; },
        }
    }
    leaf
}

F bench_btree_search_full_iter() -> u64 {
    leaf := mut bench_build_full_leaf();
    bench_btree_search_iter(&leaf, leaf.entry_count() as u64)
}

# Benchmark: B+Tree point search (after filling leaf)
F bench_btree_search(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("btree_search_point", 100);

    bench_run_simple(harness, &config, bench_btree_search_full_iter)
}

F bench_btree_range_scan_iter(leaf: &BTreeLeafNode, max_keys: u64) -> u64 {
    # Scan all entries sequentially via lower_bound
    scanned: u64 := mut 0;
    i: u64 := mut 0;
    W i < max_keys {
        key := mut leaf.get_key(i);
        scanned += 1;
        i += 1;
    }
    scanned
}

F bench_btree_range_scan_full_iter() -> u64 {
    leaf := mut bench_build_full_leaf();
    bench_btree_range_scan_iter(&leaf, leaf.entry_count() as u64)
}

# Benchmark: B+Tree range scan (iterate all entries in leaf order)
F bench_btree_range_scan(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("btree_range_scan", 100);

    bench_run_simple(harness, &config, bench_btree_range_scan_full_iter)
}

# ============================================================================
# Buffer Pool Benchmarks
# ============================================================================

F bench_buffer_pool_sequential_iter() -> u64 {
    pages: u64 := mut 100;
    pm := mut bench_page_manager("bufpool_seq");
    bench_seed_pages(&mut pm, pages);
    pool := mut BufferPool.new(pm, DEFAULT_PAGE_SIZE, 256);

    i: u64 := mut 0;
    
    accesses: u64 := mut 0;
    pass: u64 := mut 0;
    W pass < 5 {
        i = 0;
        W i < pages {
            frame := mut pool.fetch_page(FILE_ID_DATA, i as u32)!;
            pool.unpin_page(frame, false);
            accesses += 1;
            i += 1;
        }
        pass += 1;
    }
    pool.close()!;
    pm.close()!;
    accesses
}

# Benchmark: Buffer pool sequential page access (simulated hit rate)
F bench_buffer_pool_sequential(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("bufpool_sequential_access", 50);

    bench_run_simple(harness, &config, bench_buffer_pool_sequential_iter)
}

F bench_buffer_pool_random_iter() -> u64 {
    total_pages: u64 := mut 256;
    pm := mut bench_page_manager("bufpool_rand");
    bench_seed_pages(&mut pm, total_pages);
    pool := mut BufferPool.new(pm, DEFAULT_PAGE_SIZE, 64);  # Small pool to force evictions

    i: u64 := mut 0;
    state: u64 := mut 42;
    accesses: u64 := mut 0;
    i = 0;
    W i < 100 {
        state = state * 6364136223846793005 + 1442695040888963407;
        page_id := mut (state >> 33) % total_pages;
        frame := mut pool.fetch_page(FILE_ID_DATA, page_id as u32)!;
        pool.unpin_page(frame, false);
        accesses += 1;
        i += 1;
    }
    pool.close()!;
    pm.close()!;
    accesses
}

# Benchmark: Buffer pool random page access (stress eviction)
F bench_buffer_pool_random(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("bufpool_random_access", 50);

    bench_run_simple(harness, &config, bench_buffer_pool_random_iter)
}

# ============================================================================
# WAL Benchmarks
# ============================================================================

F bench_wal_write_sync_iter() -> u64 {
    writer := mut bench_wal_writer("sync");
    writes: u64 := mut 0;
    i: u64 := mut 0;
    W i < 20 {
        # Simulate a typical WAL record (tuple insert ~64 bytes)
        payload := mut bench_repeat_byte(64, (i % 256) as u8);
        writer.write_record(i + 1, TUPLE_INSERT, ENGINE_RELATIONAL, &payload)!;
        writer.sync()!;
        writes += 1;
        i += 1;
    }
    writer.close()!;
    writer.drop();
    writes
}

# Benchmark: WAL write throughput (simulated sync writes)
F bench_wal_write_sync(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("wal_write_sync", 50);

    bench_run_simple(harness, &config, bench_wal_write_sync_iter)
}

F bench_wal_write_async_iter() -> u64 {
    writer := mut bench_wal_writer("async");
    writes: u64 := mut 0;
    i: u64 := mut 0;
    W i < 20 {
        payload := mut bench_repeat_byte(64, (i % 256) as u8);
        writer.write_record(i + 1, TUPLE_INSERT, ENGINE_RELATIONAL, &payload)!;
        I ((i + 1) % 10) == 0 {
            writer.flush()!;
        }
        writes += 1;
        i += 1;
    }
    writer.flush()!;
    writer.close()!;
    writer.drop();
    writes
}

# Benchmark: WAL write throughput (async / group commit)
F bench_wal_write_async(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("wal_write_async_group", 50);

    bench_run_simple(harness, &config, bench_wal_write_async_iter)
}

# ============================================================================
# Page Allocation Benchmarks
# ============================================================================

F bench_page_alloc_iter() -> u64 {
    allocator := mut PageAllocator.new(DEFAULT_PAGE_SIZE);
    bitmap := mut FreelistBitmap.new_all_free();

    allocated: u64 := mut 0;
    i: u64 := mut 0;
    W i < 500 {
        allocator.allocate_page(FILE_ID_DATA, &mut bitmap)!;
        allocated += 1;
        i += 1;
    }
    allocated
}

# Benchmark: Page allocation throughput
F bench_page_alloc(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("page_alloc_throughput", 50);

    bench_run_simple(harness, &config, bench_page_alloc_iter)
}

F bench_page_alloc_dealloc_iter() -> u64 {
    allocator := mut PageAllocator.new(DEFAULT_PAGE_SIZE);
    bitmap := mut FreelistBitmap.new_all_free();

    ops: u64 := mut 0;

    # Allocate 200 pages
    i: u64 := mut 0;
    W i < 200 {
        allocator.allocate_page(FILE_ID_DATA, &mut bitmap)!;
        ops += 1;
        i += 1;
    }

    # Free even-numbered pages
    i = 0;
    W i < 200 {
        I i % 2 == 0 {
            allocator.deallocate_page(FILE_ID_DATA, i as u32, &mut bitmap)!;
            ops += 1;
        }
        i += 1;
    }

    # Reallocate (should reuse freed pages)
    i = 0;
    W i < 100 {
        allocator.allocate_page(FILE_ID_DATA, &mut bitmap)!;
        ops += 1;
        i += 1;
    }

    ops
}

# Benchmark: Page allocation + deallocation (mixed pattern)
F bench_page_alloc_dealloc(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("page_alloc_dealloc_mixed", 50);

    bench_run_simple(harness, &config, bench_page_alloc_dealloc_iter)
}

