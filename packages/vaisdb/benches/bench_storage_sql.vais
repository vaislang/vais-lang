F bench_sql_update_throughput_iter() -> u64 {
    leaf := mut BTreeLeafNode.new(1, DEFAULT_PAGE_SIZE, true);
    # Fill with 100 entries
    i: u64 := mut 0;
    W i < 100 {
        key := mut encode_i64_key(i as i64);
        leaf.insert(&key, i as u32)!;
        i += 1;
    }

    # Update each entry (delete + re-insert with new TID)
    updated: u64 := mut 0;
    i = 0;
    W i < 100 {
        key := mut encode_i64_key(i as i64);
        leaf.delete(&key);
        leaf.insert(&key, (i + 1000) as u32)!;
        updated += 1;
        i += 1;
    }
    updated
}

# Benchmark: Simulated SQL UPDATE (delete + re-insert)
F bench_sql_update_throughput(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("sql_update_single_row", 50);

    bench_run_simple(harness, &config, bench_sql_update_throughput_iter)
}

F bench_sql_delete_throughput_iter() -> u64 {
    leaf := mut BTreeLeafNode.new(1, DEFAULT_PAGE_SIZE, true);
    # Fill with entries
    max_keys: u64 := mut 0;
    i: u64 := mut 0;
    full := mut false;
    W !full {
        key := mut encode_i64_key(i as i64);
        M leaf.insert(&key, i as u32) {
            Ok(()) => { max_keys += 1; i += 1; },
            Err(_) => { full = true; },
        }
    }

    # Delete all entries
    deleted: u64 := mut 0;
    i = 0;
    W i < max_keys {
        key := mut encode_i64_key(i as i64);
        M leaf.delete(&key) {
            Some(_) => { deleted += 1; },
            None => {},
        }
        i += 1;
    }
    deleted
}

# Benchmark: Simulated SQL DELETE throughput
F bench_sql_delete_throughput(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("sql_delete_single_row", 50);

    bench_run_simple(harness, &config, bench_sql_delete_throughput_iter)
}

# ============================================================================
# SQL JOIN Benchmarks
# ============================================================================

F bench_sql_join_nlj_iter() -> u64 {
    # Build two "tables" as sorted key arrays
    left_size: u64 := mut 100;
    right_size: u64 := mut 100;

    # NLJ: for each left row, scan right table for matches
    matched: u64 := mut 0;
    li: u64 := mut 0;
    W li < left_size {
        left_key := mut li as i64;
        ri: u64 := mut 0;
        W ri < right_size {
            right_key := mut (ri + 50) as i64;
            I left_key == right_key {
                matched += 1;
            }
            ri += 1;
        }
        li += 1;
    }
    matched
}

# Benchmark: Nested Loop Join simulation
# Simulates NLJ over two key sets
F bench_sql_join_nlj(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("sql_join_nlj", 30);

    bench_run_simple(harness, &config, bench_sql_join_nlj_iter)
}

F bench_sql_join_hash_iter() -> u64 {
    left_size: u64 := mut 500;
    right_size: u64 := mut 500;
    left_size_i64 := mut left_size as i64;

    # Build phase: hash the smaller (left) side into a synthetic fingerprint
    build_fingerprint: i64 := mut 0;
    i: u64 := mut 0;
    W i < left_size {
        build_key := mut i as i64;
        build_fingerprint = build_fingerprint ^ hash_i64(build_key);
        i += 1;
    }

    # Probe phase: scan right side and simulate hash probes
    matched: u64 := mut 0;
    probe_fingerprint: i64 := mut build_fingerprint;
    i = 0;
    W i < right_size {
        key := mut (i + 250) as i64;  # Overlap at 250
        probe_fingerprint = probe_fingerprint ^ hash_i64(key);
        I key >= 0 && key < left_size_i64 {
            matched += 1;
        }
        i += 1;
    }
    matched + (((probe_fingerprint ^ build_fingerprint) as u64) & 0)
}

# Benchmark: Hash Join simulation
# Simulates hash join over two key sets
F bench_sql_join_hash(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("sql_join_hash", 30);

    bench_run_simple(harness, &config, bench_sql_join_hash_iter)
}

F bench_sql_join_scaling_iter() -> u64 {
    size: u64 := mut 1000;
    size_i64 := mut size as i64;

    # Synthetic hash build at 1K x 1K
    build_fingerprint: i64 := mut 0;
    i: u64 := mut 0;
    W i < size {
        build_fingerprint = build_fingerprint ^ hash_i64(i as i64);
        i += 1;
    }

    matched: u64 := mut 0;
    probe_fingerprint: i64 := mut build_fingerprint;
    i = 0;
    W i < size {
        key := mut (i + 500) as i64;
        probe_fingerprint = probe_fingerprint ^ hash_i64(key);
        I key >= 0 && key < size_i64 {
            matched += 1;
        }
        i += 1;
    }
    matched + (((probe_fingerprint ^ build_fingerprint) as u64) & 0)
}

# Benchmark: Join scaling (NLJ vs Hash at different sizes)
F bench_sql_join_scaling(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("sql_join_scaling_1k", 10);

    bench_run_simple(harness, &config, bench_sql_join_scaling_iter)
}

# ============================================================================
# SQL Aggregation Benchmark
# ============================================================================

F bench_sql_groupby_iter() -> u64 {
    # Simulate GROUP BY on 10K rows with 100 distinct groups
    groups: u64 := mut 100;
    rows: u64 := mut 10000;
    hash_acc: i64 := mut 0;
    sum_acc: i64 := mut 0;
    i: u64 := mut 0;
    W i < rows {
        group_key := mut i % groups;
        bucket := mut hash_i64(group_key as i64) % (groups as i64);
        value := mut i as i64;
        hash_acc = hash_acc ^ bucket;
        sum_acc += value + bucket;
        i += 1;
    }
    rows + (((hash_acc ^ sum_acc) as u64) & 0)
}

# Benchmark: GROUP BY aggregation (hash-based)
F bench_sql_groupby(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("sql_groupby_hash", 50);

    bench_run_simple(harness, &config, bench_sql_groupby_iter)
}

# ============================================================================
# Transaction Benchmarks
# ============================================================================

F bench_txn_commit_iter() -> u64 {
    writer := mut bench_wal_writer("txn_commit");

    committed: u64 := mut 0;
    i: u64 := mut 0;
    W i < 20 {
        # Simulate: begin txn + write + commit
        txn_id := mut i + 1;

        # Write a tuple insert WAL record
        payload := mut bench_repeat_byte(32, (i % 256) as u8);
        writer.write_record(txn_id, TUPLE_INSERT, ENGINE_RELATIONAL, &payload)!;

        # Write commit record
        commit_payload: Vec<u8> := mut Vec.new();
        writer.write_record(txn_id, TXN_COMMIT, ENGINE_META, &commit_payload)!;
        writer.clear_txn(txn_id);
        I ((i + 1) % 10) == 0 {
            writer.flush()!;
        }

        committed += 1;
        i += 1;
    }
    writer.flush()!;
    writer.close()!;
    writer.drop();
    committed
}

# Benchmark: Transaction commit throughput (simulated)
F bench_txn_commit(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("txn_commit_throughput", 50);

    bench_run_simple(harness, &config, bench_txn_commit_iter)
}

F bench_txn_rollback_iter() -> u64 {
    writer := mut bench_wal_writer("txn_abort");

    rolled_back: u64 := mut 0;
    i: u64 := mut 0;
    W i < 20 {
        txn_id := mut i + 1;

        # Write a tuple insert WAL record
        payload := mut bench_repeat_byte(32, (i % 256) as u8);
        writer.write_record(txn_id, TUPLE_INSERT, ENGINE_RELATIONAL, &payload)!;

        # Write abort record
        abort_payload: Vec<u8> := mut Vec.new();
        writer.write_record(txn_id, TXN_ABORT, ENGINE_META, &abort_payload)!;
        writer.clear_txn(txn_id);
        I ((i + 1) % 10) == 0 {
            writer.flush()!;
        }

        rolled_back += 1;
        i += 1;
    }
    writer.flush()!;
    writer.close()!;
    writer.drop();
    rolled_back
}

# Benchmark: Transaction rollback throughput (simulated)
F bench_txn_rollback(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut bench_config("txn_rollback_throughput", 50);

    bench_run_simple(harness, &config, bench_txn_rollback_iter)
}

# ============================================================================
# Suite Runner
# ============================================================================

# Run all storage and SQL benchmarks
F run_storage_sql_benchmarks() -> BenchmarkHarness {
    harness := mut BenchmarkHarness.new("Storage & SQL");
    harness.start();

    # B+Tree benchmarks
    bench_btree_insert_1k(&mut harness);
    bench_btree_insert_10k(&mut harness);
    bench_btree_insert_100k(&mut harness);
    bench_btree_search(&mut harness);
    bench_btree_range_scan(&mut harness);

    # Buffer pool benchmarks
    bench_buffer_pool_sequential(&mut harness);
    bench_buffer_pool_random(&mut harness);

    # WAL benchmarks
    bench_wal_write_sync(&mut harness);
    bench_wal_write_async(&mut harness);

    # Page allocation benchmarks
    bench_page_alloc(&mut harness);
    bench_page_alloc_dealloc(&mut harness);

    # SQL DML benchmarks
    bench_sql_insert_throughput(&mut harness);
    bench_sql_select_throughput(&mut harness);
    bench_sql_update_throughput(&mut harness);
    bench_sql_delete_throughput(&mut harness);

    # SQL JOIN benchmarks
    bench_sql_join_nlj(&mut harness);
    bench_sql_join_hash(&mut harness);
    bench_sql_join_scaling(&mut harness);

    # SQL aggregation
    bench_sql_groupby(&mut harness);

    # Transaction benchmarks
    bench_txn_commit(&mut harness);
    bench_txn_rollback(&mut harness);

    harness.print_report();
    harness
}

F main() -> i64 {
    run_storage_sql_benchmarks()
    0
}
