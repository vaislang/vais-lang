F bench_sql_insert_throughput_iter() -> u64 {
    # Simulate INSERT by encoding keys and inserting into B+Tree leaf
    leaf := mut BTreeLeafNode.new(1, DEFAULT_PAGE_SIZE, true);
    inserted: u64 := mut 0;
    i: u64 := mut 0;
    full := mut false;
    W i < 5000 && !full {
        key := mut encode_i64_key(i as i64);
        M leaf.insert(&key, i as u32) {
            Ok(()) => { inserted += 1; },
            Err(_) => { full = true; },
        }
        i += 1;
    }
    inserted
}

# Benchmark: Simulated SQL INSERT single-row throughput
