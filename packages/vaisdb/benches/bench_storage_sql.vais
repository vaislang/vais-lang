    i: u64 := mut 0;
    W i < max_keys {
        key := mut encode_i64_key(i as i64);
        M leaf.get_tid(&key) {
            Some(_) => { found += 1; },
            None => {},
        }
        i += 1;
    }
    found
}

F bench_sql_select_throughput_full_iter() -> u64 {
