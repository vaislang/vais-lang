# Benchmark: Boolean query parsing
F bench_boolean_parse(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("ft_boolean_parse"));
    config = config.with_iterations(100);

    queries: Vec<Str> := mut Vec.new();
    queries.push(Str.from("database AND vector"));
    queries.push(Str.from("search OR query"));
    queries.push(Str.from("insert AND NOT delete"));
    queries.push(Str.from("\"full text search\""));
    queries.push(Str.from("graph AND (traversal OR path)"));
    queries.push(Str.from("vector AND database AND NOT slow"));
    queries.push(Str.from("\"hybrid search\" AND performance"));
    queries.push(Str.from("btree OR hnsw OR inverted"));

    harness.run_simple(&config, || {
        parsed: u64 := mut 0;
        i: u64 := mut 0;
        W i < queries.len() {
            M BooleanQueryParser.parse(&queries[i]) {
                Ok(_) => { parsed += 1; },
                Err(_) => {},
            }
            i += 1;
        }
        parsed
    })
}

# Benchmark: Phrase search position matching
F bench_phrase_search(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("ft_phrase_search"));
    config = config.with_iterations(50);

    # Build simulated posting entries with positions
    term_postings: Vec<Vec<PostingEntry>> := mut Vec.new();

    # Term 1: "full" — appears in docs 1,3,5,7,9,...
    postings1: Vec<PostingEntry> := mut Vec.new();
    i: u64 := mut 0;
    W i < 500 {
        positions: Vec<u32> := mut Vec.new();
        positions.push((i % 20) as u32);
        positions.push((i % 20 + 10) as u32);
        entry := mut PostingEntry.new(i * 2 + 1, 2, positions, i + 1, 0);
        postings1.push(entry);
        i += 1;
    }
    term_postings.push(postings1);

    # Term 2: "text" — appears in docs 1,2,3,...
    postings2: Vec<PostingEntry> := mut Vec.new();
    i = 0;
    W i < 1000 {
        positions: Vec<u32> := mut Vec.new();
        positions.push((i % 20 + 1) as u32);
        entry := mut PostingEntry.new(i + 1, 1, positions, i + 1, 0);
        postings2.push(entry);
        i += 1;
    }
    term_postings.push(postings2);

    terms: Vec<Str> := mut Vec.new();
    terms.push(Str.from("full"));
    terms.push(Str.from("text"));

    harness.run_simple(&config, || {
        searcher := mut PhraseSearcher.new(0);
        # Note: phrase search requires snapshot/clog for MVCC filtering;
        # in benchmarks we simulate by passing dummy snapshot/clog
        # In practice this calls searcher.search_phrase which does position matching
        matched: u64 := mut 0;

        # Manual position-based phrase matching simulation
        pi: u64 := mut 0;
        W pi < term_postings[0].len() {
            doc_id := mut term_postings[0][pi].doc_id;
            # Find same doc in second term's postings
            found_in_t2 := mut false;
            qi: u64 := mut 0;
            W qi < term_postings[1].len() && !found_in_t2 {
                I term_postings[1][qi].doc_id == doc_id {
                    # Check position adjacency
                    p1 := mut term_postings[0][pi].positions[0];
                    p2 := mut term_postings[1][qi].positions[0];
                    I p2 == p1 + 1 {
                        matched += 1;
                    }
                    found_in_t2 = true;
                }
                qi += 1;
            }
            pi += 1;
        }
        matched
    })
}

# ============================================================================
# FullText: Compression Benchmarks
# ============================================================================

# Benchmark: VByte encoding throughput
F bench_vbyte_encode(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("ft_vbyte_encode"));
    config = config.with_iterations(100);

    harness.run_simple(&config, || {
        encoded: u64 := mut 0;
        i: u64 := mut 0;
        W i < 10000 {
            buf: Vec<u8> := mut Vec.new();
            vbyte_encode(i * 7 + 13, &mut buf);
            encoded += 1;
            i += 1;
        }
        encoded
    })
}

# Benchmark: Delta encoding for doc_id lists
F bench_delta_encode(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("ft_delta_encode"));
    config = config.with_iterations(100);

    # Generate sorted doc IDs
    doc_ids: Vec<u64> := mut Vec.new();
    i: u64 := mut 0;
    W i < 1000 {
        doc_ids.push(i * 3 + 1);
        i += 1;
    }

    harness.run_simple(&config, || {
        encoded := mut delta_encode_doc_ids(&doc_ids);
        decoded := mut delta_decode_doc_ids(&encoded);
        doc_ids.len()
    })
}

# ============================================================================
# Suite Runner
# ============================================================================

# Run all vector, graph, and full-text engine benchmarks
F run_engine_benchmarks() -> BenchmarkHarness {
    harness := mut BenchmarkHarness.new(Str.from("Vector, Graph & FullText Engines"));
    harness.start();

    # Vector: Distance computation
    bench_distance_cosine_128(&mut harness);
    bench_distance_cosine_256(&mut harness);
    bench_distance_cosine_1536(&mut harness);
    bench_distance_l2_128(&mut harness);
    bench_distance_dot_128(&mut harness);

    # Vector: HNSW insert
    bench_hnsw_insert_128d(&mut harness);
    bench_hnsw_insert_1536d(&mut harness);

    # Vector: HNSW search
    bench_hnsw_search_recall(&mut harness);

    # Vector: Quantization
    bench_sq_encode(&mut harness);
    bench_sq_distance(&mut harness);

    # Graph: Node/Edge creation
    bench_graph_node_create(&mut harness);
    bench_graph_edge_create(&mut harness);

    # Graph: Traversal
    bench_graph_bfs(&mut harness);
    bench_graph_dfs(&mut harness);

    # Graph: Shortest path
    bench_graph_shortest_path(&mut harness);

    # FullText: Tokenization
    bench_tokenize_throughput(&mut harness);
    bench_tokenize_with_freqs(&mut harness);

    # FullText: BM25
    bench_bm25_scoring(&mut harness);

    # FullText: Boolean/Phrase
    bench_boolean_parse(&mut harness);
    bench_phrase_search(&mut harness);

    # FullText: Compression
    bench_vbyte_encode(&mut harness);
    bench_delta_encode(&mut harness);

    harness.print_report();
    harness
}
