        created: u64 := mut 0;
        i: u64 := mut 0;
        W i < 10000 {
            entry := mut AdjEntry.new(
                (i + 1) % 10000,  # target_node
                i,                 # edge_id
                (i % 5) as u16,   # edge_type_id
                i + 1,            # txn_id
                0,                 # cmd_id
            );
            edges.push(entry);
            created += 1;
            i += 1;
        }
        created
    })
}

# ============================================================================
# Graph: BFS/DFS Traversal Benchmarks
# ============================================================================

# Benchmark: BFS traversal simulation (depth 1-5 on adjacency list)
# Simulates BFS over an in-memory adjacency list structure
F bench_graph_bfs(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("graph_bfs_depth5"));
    config = config.with_iterations(30);

    # Build adjacency list: each node has ~5 outgoing edges
    node_count: u64 := mut 10000;
    adj_list: Vec<Vec<u64>> := mut Vec.new();
    i: u64 := mut 0;
    W i < node_count {
        neighbors: Vec<u64> := mut Vec.new();
        state := mut i * 6364136223846793005 + 1442695040888963407;
        j: u64 := mut 0;
        W j < 5 {
            state = state * 6364136223846793005 + 1442695040888963407;
            target := mut (state >> 33) % node_count;
            neighbors.push(target);
            j += 1;
        }
        adj_list.push(neighbors);
        i += 1;
    }

    harness.run_simple(&config, || {
        # BFS from node 0, max depth 5
        U std/hashmap.HashMap;

        visited: HashMap<u64, bool> := mut HashMap.new();
        queue: Vec<(u64, u64)> := mut Vec.new();  # (node_id, depth)
        queue.push((0, 0));
        visited.insert(0, true);
        nodes_visited: u64 := mut 0;

        W queue.len() > 0 {
            (current, depth) := mut queue[0];
            # Remove front (shift)
            new_queue: Vec<(u64, u64)> := mut Vec.new();
            qi: u64 := mut 1;
            W qi < queue.len() {
                new_queue.push(queue[qi]);
                qi += 1;
            }
            queue = new_queue;

            nodes_visited += 1;

            I depth < 5 {
                ni: u64 := mut 0;
                W ni < adj_list[current].len() {
                    neighbor := mut adj_list[current][ni];
                    I !visited.contains_key(&neighbor) {
                        visited.insert(neighbor, true);
                        queue.push((neighbor, depth + 1));
                    }
                    ni += 1;
                }
            }
        }
        nodes_visited
    })
}

# Benchmark: DFS traversal simulation (depth 1-5)
F bench_graph_dfs(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("graph_dfs_depth5"));
    config = config.with_iterations(30);

    # Build adjacency list (same as BFS)
    node_count: u64 := mut 10000;
    adj_list: Vec<Vec<u64>> := mut Vec.new();
    i: u64 := mut 0;
    W i < node_count {
        neighbors: Vec<u64> := mut Vec.new();
        state := mut i * 6364136223846793005 + 1442695040888963407;
        j: u64 := mut 0;
        W j < 5 {
            state = state * 6364136223846793005 + 1442695040888963407;
            target := mut (state >> 33) % node_count;
            neighbors.push(target);
            j += 1;
        }
        adj_list.push(neighbors);
        i += 1;
    }

    harness.run_simple(&config, || {
        # DFS from node 0, max depth 5
        U std/hashmap.HashMap;

        visited: HashMap<u64, bool> := mut HashMap.new();
        stack: Vec<(u64, u64)> := mut Vec.new();  # (node_id, depth)
        stack.push((0, 0));
        nodes_visited: u64 := mut 0;

        W stack.len() > 0 {
            last_idx := mut stack.len() - 1;
            (current, depth) := mut stack[last_idx];
            stack.truncate(last_idx);

            I visited.contains_key(&current) {
                # Skip already visited
            } EL {
                visited.insert(current, true);
                nodes_visited += 1;

                I depth < 5 {
                    ni: u64 := mut 0;
                    W ni < adj_list[current].len() {
                        neighbor := mut adj_list[current][ni];
                        I !visited.contains_key(&neighbor) {
                            stack.push((neighbor, depth + 1));
                        }
                        ni += 1;
                    }
                }
            }
        }
        nodes_visited
    })
}

# ============================================================================
# Graph: Shortest Path (Dijkstra) Benchmark
# ============================================================================

# Benchmark: Dijkstra shortest path simulation
F bench_graph_shortest_path(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("graph_dijkstra_10k"));
    config = config.with_iterations(20);

    # Build weighted adjacency list
    node_count: u64 := mut 10000;
    adj_list: Vec<Vec<(u64, f64)>> := mut Vec.new();  # (target, weight)
    i: u64 := mut 0;
    W i < node_count {
        neighbors: Vec<(u64, f64)> := mut Vec.new();
        state := mut i * 6364136223846793005 + 1442695040888963407;
        j: u64 := mut 0;
        W j < 5 {
            state = state * 6364136223846793005 + 1442695040888963407;
            target := mut (state >> 33) % node_count;
            weight := mut ((state >> 48) % 100 + 1) as f64;
            neighbors.push((target, weight));
            j += 1;
        }
        adj_list.push(neighbors);
        i += 1;
    }

    harness.run_simple(&config, || {
        # Dijkstra from node 0 to node 5000
        U std/hashmap.HashMap;

        dist: HashMap<u64, f64> := mut HashMap.new();
        processed: HashMap<u64, bool> := mut HashMap.new();
        dist.insert(0, 0.0);

        # Simple Dijkstra (linear scan for min — not heap, just benchmark)
        found := mut false;
        iterations: u64 := mut 0;
        max_iterations: u64 := mut 5000;  # Limit to prevent excessive runtime

        W !found && iterations < max_iterations {
            # Find unprocessed node with minimum distance
            min_node: u64 := mut 0;
            min_dist: f64 := mut 999999999.0;
            has_candidate := mut false;

            LF item: &dist {
                node := item.0;
                d := item.1;
                I !processed.contains_key(node) && *d < min_dist {
                    min_node = *node;
                    min_dist = *d;
                    has_candidate = true;
                }
            }

            I !has_candidate {
                found = true;
            } EL {
                I min_node == 5000 {
                    found = true;
                } EL {
                    processed.insert(min_node, true);

                    # Relax neighbors
                    ni: u64 := mut 0;
                    W ni < adj_list[min_node].len() {
                        (target, weight) := mut adj_list[min_node][ni];
                        new_dist := mut min_dist + weight;
                        current_dist := mut M dist.get(&target) {
                            Some(mut d) => *d,
                            None => 999999999.0,
                        };
                        I new_dist < current_dist {
                            dist.insert(target, new_dist);
                        }
                        ni += 1;
                    }
                }
            }
            iterations += 1;
        }
        iterations
    })
}

# ============================================================================
# FullText: Tokenization Benchmarks
