# Benchmark: Tokenization throughput (documents per second)
F bench_tokenize_throughput(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("ft_tokenize_docs"));
    config = config.with_iterations(50);

    ft_config := mut FullTextConfig.default();
    tokenizer := mut Tokenizer.from_config(&ft_config);

    # Pre-generate documents
    docs: Vec<Str> := mut Vec.new();
    i: u64 := mut 0;
    W i < 100 {
        docs.push(generate_random_text(200, i + 1));
        i += 1;
    }

    harness.run_simple(&config, || {
        tokenized: u64 := mut 0;
        i: u64 := mut 0;
        W i < docs.len() {
            tokenizer.tokenize(&docs[i]);
            tokenized += 1;
            i += 1;
        }
        tokenized
    })
}

# Benchmark: Tokenization with frequency counting
F bench_tokenize_with_freqs(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("ft_tokenize_freqs"));
    config = config.with_iterations(50);

    ft_config := mut FullTextConfig.default();
    tokenizer := mut Tokenizer.from_config(&ft_config);

    docs: Vec<Str> := mut Vec.new();
    i: u64 := mut 0;
    W i < 100 {
        docs.push(generate_random_text(200, i + 1));
        i += 1;
    }

    harness.run_simple(&config, || {
        tokenized: u64 := mut 0;
        i: u64 := mut 0;
        W i < docs.len() {
            tokenizer.tokenize_with_freqs(&docs[i]);
            tokenized += 1;
            i += 1;
        }
        tokenized
    })
}

# ============================================================================
# FullText: BM25 Scoring Benchmark
# ============================================================================

# Benchmark: BM25 score computation throughput
F bench_bm25_scoring(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("ft_bm25_scoring"));
    config = config.with_iterations(100);

    scorer := mut BM25Scorer.with_params(1.2, 0.75);

    harness.run_simple(&config, || {
        scored: u64 := mut 0;
        i: u64 := mut 0;
        W i < 10000 {
            # Simulate scoring a document for a query term
            tf := mut (i % 10 + 1) as u32;        # term frequency 1-10
            df := mut (i % 1000 + 1) as u64;       # document frequency
            doc_len := mut (i % 500 + 50) as u32;  # document length 50-549
            avg_len: f64 := mut 300.0;             # average doc length
            total_docs: u64 := mut 100000;         # corpus size

            scorer.score(tf, df, doc_len, avg_len, total_docs);
            scored += 1;
            i += 1;
        }
        scored
    })
}

