    config := mut BenchmarkConfig.default(Str.from("graph_node_create"));
    config = config.with_iterations(50);

    harness.run_simple(&config, || {
        nodes: Vec<GraphNode> := mut Vec.new();
        created: u64 := mut 0;
        i: u64 := mut 0;
        W i < 10000 {
            labels: Vec<u16> := mut Vec.new();
            labels.push((i % 10) as u16);
            node := mut GraphNode.new(i, labels, i + 1, 0);
            nodes.push(node);
            created += 1;
            i += 1;
        }
        created
    })
}

# Benchmark: Graph edge creation throughput (adjacency entry creation)
