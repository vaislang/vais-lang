# ============================================================================
# Vector: HNSW Insert Benchmarks
# ============================================================================

# Benchmark: HNSW-like node insertion throughput at 128d
# Simulates the node allocation and neighbor list construction
F bench_hnsw_insert_128d(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("hnsw_insert_128d"));
    config = config.with_iterations(30);

    harness.run_simple(&config, || {
        # Simulate HNSW insert: generate vectors, compute distances, build neighbor lists
        vectors := mut generate_random_vectors(1000, 128, 42);
        nodes: Vec<HnswNode> := mut Vec.new();
        inserted: u64 := mut 0;

        i: u64 := mut 0;
        W i < vectors.len() {
            node := mut HnswNode.new(i, 0, 0, 0, i + 1, 0);
            nodes.push(node);

            # Simulate nearest neighbor search for first 16 neighbors
            I i > 0 {
                best_dist: f64 := mut 999999.0;
                j: u64 := mut 0;
                search_limit := mut I i < 16 { i } EL { 16 };
                W j < search_limit {
                    dist := mut cosine_distance(&vectors[i], &vectors[j])!;
                    I dist < best_dist { best_dist = dist; }
                    j += 1;
                }
            }

            inserted += 1;
            i += 1;
        }
        inserted
    })
}

# Benchmark: HNSW-like node insertion throughput at 1536d
F bench_hnsw_insert_1536d(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("hnsw_insert_1536d"));
    config = config.with_iterations(10);

    harness.run_simple(&config, || {
        vectors := mut generate_random_vectors(200, 1536, 42);
        inserted: u64 := mut 0;

        i: u64 := mut 0;
        W i < vectors.len() {
            I i > 0 {
                best_dist: f64 := mut 999999.0;
                j: u64 := mut 0;
                search_limit := mut I i < 16 { i } EL { 16 };
                W j < search_limit {
                    dist := mut cosine_distance(&vectors[i], &vectors[j])!;
                    I dist < best_dist { best_dist = dist; }
                    j += 1;
                }
            }
            inserted += 1;
            i += 1;
        }
        inserted
    })
}

# ============================================================================
# Vector: HNSW Search (Recall vs Latency)
# ============================================================================

# Benchmark: HNSW-like search simulation (brute-force kNN as baseline)
F bench_hnsw_search_recall(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("hnsw_search_brute_knn"));
    config = config.with_iterations(50);

    # Pre-build dataset
    dataset := mut generate_random_vectors(5000, 128, 42);

    harness.run_simple(&config, || {
        # Brute-force kNN for recall@10 baseline
        query := mut generate_random_vector(128, 9999);
        k: u64 := mut 10;

        # Compute all distances
        dists: Vec<(u64, f64)> := mut Vec.new();
        i: u64 := mut 0;
        W i < dataset.len() {
            d := mut cosine_distance(&query, &dataset[i])!;
            dists.push((i, d));
            i += 1;
        }

        # Partial sort to find top-k (selection sort on first k elements)
        ki: u64 := mut 0;
        W ki < k && ki < dists.len() {
            min_idx := mut ki;
            j: u64 := mut ki + 1;
            W j < dists.len() {
                I dists[j].1 < dists[min_idx].1 {
                    min_idx = j;
                }
                j += 1;
            }
            I min_idx != ki {
                tmp := mut dists[ki];
                dists[ki] = dists[min_idx];
                dists[min_idx] = tmp;
            }
            ki += 1;
        }

        k
    })
}

# ============================================================================
# Vector: Quantization Benchmarks
# ============================================================================

# Benchmark: Scalar quantization encode throughput
F bench_sq_encode(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("vec_sq_encode_128d"));
    config = config.with_iterations(100);

    # Train quantizer
    train_vectors := mut generate_random_vectors(100, 128, 42);
    quantizer := mut ScalarQuantizer.new(128);
    train_refs: Vec<&[f32]> := mut Vec.new();
    i: u64 := mut 0;
    W i < train_vectors.len() {
        train_refs.push(&train_vectors[i]);
        i += 1;
    }
    quantizer.train(&train_refs)!;

    test_vector := mut generate_random_vector(128, 999);

    harness.run_simple(&config, || {
        ops: u64 := mut 0;
        i: u64 := mut 0;
        W i < 10000 {
            quantizer.encode(&test_vector)!;
            ops += 1;
            i += 1;
        }
        ops
    })
}

# Benchmark: Scalar quantization distance computation
F bench_sq_distance(harness: &mut BenchmarkHarness) -> BenchmarkResult {
    config := mut BenchmarkConfig.default(Str.from("vec_sq_distance_128d"));
    config = config.with_iterations(100);

    # Train and encode two vectors
    train_vectors := mut generate_random_vectors(100, 128, 42);
    quantizer := mut ScalarQuantizer.new(128);
    train_refs: Vec<&[f32]> := mut Vec.new();
    i: u64 := mut 0;
    W i < train_vectors.len() {
        train_refs.push(&train_vectors[i]);
        i += 1;
    }
    quantizer.train(&train_refs)!;

    a := mut generate_random_vector(128, 1);
    b := mut generate_random_vector(128, 2);
    qa := mut quantizer.encode(&a)!;
    qb := mut quantizer.encode(&b)!;

    harness.run_simple(&config, || {
        ops: u64 := mut 0;
        i: u64 := mut 0;
        W i < 10000 {
            quantizer.quantized_distance(&qa, &qb)!;
            ops += 1;
            i += 1;
        }
        ops
    })
}

