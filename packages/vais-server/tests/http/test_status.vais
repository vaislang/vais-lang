# test_status.vais — Unit tests for StatusCode constants and category methods

U http/status

# ============================================================================
# Tests
# ============================================================================

F test_2xx_is_success() -> i64 {
    I STATUS_OK.is_success() != 1 {
        println("FAIL test_2xx_is_success: STATUS_OK should be success")
        R 1
    }
    I STATUS_CREATED.is_success() != 1 {
        println("FAIL test_2xx_is_success: STATUS_CREATED should be success")
        R 1
    }
    I STATUS_NO_CONTENT.is_success() != 1 {
        println("FAIL test_2xx_is_success: STATUS_NO_CONTENT should be success")
        R 1
    }
    println("PASS test_2xx_is_success")
    0
}

F test_4xx_is_client_error() -> i64 {
    I STATUS_BAD_REQUEST.is_client_error() != 1 {
        println("FAIL test_4xx_is_client_error: STATUS_BAD_REQUEST should be client error")
        R 1
    }
    I STATUS_UNAUTHORIZED.is_client_error() != 1 {
        println("FAIL test_4xx_is_client_error: STATUS_UNAUTHORIZED should be client error")
        R 1
    }
    I STATUS_FORBIDDEN.is_client_error() != 1 {
        println("FAIL test_4xx_is_client_error: STATUS_FORBIDDEN should be client error")
        R 1
    }
    I STATUS_NOT_FOUND.is_client_error() != 1 {
        println("FAIL test_4xx_is_client_error: STATUS_NOT_FOUND should be client error")
        R 1
    }
    I STATUS_METHOD_NOT_ALLOWED.is_client_error() != 1 {
        println("FAIL test_4xx_is_client_error: STATUS_METHOD_NOT_ALLOWED should be client error")
        R 1
    }
    I STATUS_CONFLICT.is_client_error() != 1 {
        println("FAIL test_4xx_is_client_error: STATUS_CONFLICT should be client error")
        R 1
    }
    println("PASS test_4xx_is_client_error")
    0
}

F test_5xx_is_server_error() -> i64 {
    I STATUS_INTERNAL.is_server_error() != 1 {
        println("FAIL test_5xx_is_server_error: STATUS_INTERNAL should be server error")
        R 1
    }
    I STATUS_BAD_GATEWAY.is_server_error() != 1 {
        println("FAIL test_5xx_is_server_error: STATUS_BAD_GATEWAY should be server error")
        R 1
    }
    I STATUS_SERVICE_UNAVAILABLE.is_server_error() != 1 {
        println("FAIL test_5xx_is_server_error: STATUS_SERVICE_UNAVAILABLE should be server error")
        R 1
    }
    println("PASS test_5xx_is_server_error")
    0
}

F test_3xx_is_redirect() -> i64 {
    I STATUS_MOVED.is_redirect() != 1 {
        println("FAIL test_3xx_is_redirect: STATUS_MOVED should be redirect")
        R 1
    }
    println("PASS test_3xx_is_redirect")
    0
}

F test_category_exclusivity() -> i64 {
    # 200 is success but not client/server error
    I STATUS_OK.is_client_error() != 0 {
        println("FAIL test_category_exclusivity: 200 should not be client error")
        R 1
    }
    I STATUS_OK.is_server_error() != 0 {
        println("FAIL test_category_exclusivity: 200 should not be server error")
        R 1
    }
    # 404 is client error but not success or server error
    I STATUS_NOT_FOUND.is_success() != 0 {
        println("FAIL test_category_exclusivity: 404 should not be success")
        R 1
    }
    I STATUS_NOT_FOUND.is_server_error() != 0 {
        println("FAIL test_category_exclusivity: 404 should not be server error")
        R 1
    }
    println("PASS test_category_exclusivity")
    0
}

F test_status_code_values() -> i64 {
    I STATUS_OK.code != 200 {
        println("FAIL test_status_code_values: STATUS_OK code should be 200")
        R 1
    }
    I STATUS_NOT_FOUND.code != 404 {
        println("FAIL test_status_code_values: STATUS_NOT_FOUND code should be 404")
        R 1
    }
    I STATUS_INTERNAL.code != 500 {
        println("FAIL test_status_code_values: STATUS_INTERNAL code should be 500")
        R 1
    }
    println("PASS test_status_code_values")
    0
}

F test_status_custom_new() -> i64 {
    s := StatusCode.new(422, "Unprocessable Entity")
    I s.code != 422 {
        println("FAIL test_status_custom_new: expected code=422, got {s.code}")
        R 1
    }
    I s.is_client_error() != 1 {
        println("FAIL test_status_custom_new: 422 should be client error")
        R 1
    }
    println("PASS test_status_custom_new")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_2xx_is_success()
    failures += test_4xx_is_client_error()
    failures += test_5xx_is_server_error()
    failures += test_3xx_is_redirect()
    failures += test_category_exclusivity()
    failures += test_status_code_values()
    failures += test_status_custom_new()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_status)")
    0
}
