# test_method.vais — Unit tests for HttpMethod

U http/method

# ============================================================================
# Tests
# ============================================================================

F test_method_from_str_known() -> i64 {
    cases := [
        ["GET",     "Get"],
        ["POST",    "Post"],
        ["PUT",     "Put"],
        ["DELETE",  "Delete"],
        ["PATCH",   "Patch"],
        ["OPTIONS", "Options"],
        ["HEAD",    "Head"],
    ]

    # Verify from_str → to_str round-trip for each known method
    m_get     := HttpMethod.from_str("GET")
    m_post    := HttpMethod.from_str("POST")
    m_put     := HttpMethod.from_str("PUT")
    m_delete  := HttpMethod.from_str("DELETE")
    m_patch   := HttpMethod.from_str("PATCH")
    m_options := HttpMethod.from_str("OPTIONS")
    m_head    := HttpMethod.from_str("HEAD")

    I m_get.to_str()     != "GET"     { println("FAIL test_method_from_str_known: GET");     R 1 }
    I m_post.to_str()    != "POST"    { println("FAIL test_method_from_str_known: POST");    R 1 }
    I m_put.to_str()     != "PUT"     { println("FAIL test_method_from_str_known: PUT");     R 1 }
    I m_delete.to_str()  != "DELETE"  { println("FAIL test_method_from_str_known: DELETE");  R 1 }
    I m_patch.to_str()   != "PATCH"   { println("FAIL test_method_from_str_known: PATCH");   R 1 }
    I m_options.to_str() != "OPTIONS" { println("FAIL test_method_from_str_known: OPTIONS"); R 1 }
    I m_head.to_str()    != "HEAD"    { println("FAIL test_method_from_str_known: HEAD");    R 1 }

    println("PASS test_method_from_str_known")
    0
}

F test_method_from_str_unknown() -> i64 {
    # Unknown method should default to Get
    m := HttpMethod.from_str("BREW")
    I m.to_str() != "GET" {
        println("FAIL test_method_from_str_unknown: expected GET fallback, got {m.to_str()}")
        R 1
    }
    println("PASS test_method_from_str_unknown")
    0
}

F test_method_to_str_round_trip() -> i64 {
    methods := ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
    I i = 0; i < methods.len(); i = i + 1 {
        s := methods.get(i)
        m := HttpMethod.from_str(s)
        I m.to_str() != s {
            println("FAIL test_method_to_str_round_trip: {s} -> {m.to_str()}")
            R 1
        }
    }
    println("PASS test_method_to_str_round_trip")
    0
}

F test_global_helpers() -> i64 {
    # Verify the module-level functions match the struct methods
    m := http_method_from_str("POST")
    s := http_method_to_str(m)
    I s != "POST" {
        println("FAIL test_global_helpers: expected POST, got {s}")
        R 1
    }
    println("PASS test_global_helpers")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_method_from_str_known()
    failures += test_method_from_str_unknown()
    failures += test_method_to_str_round_trip()
    failures += test_global_helpers()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_method)")
    0
}
