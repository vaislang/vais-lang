# test_response.vais — Unit tests for Response builder

U core/context

# ============================================================================
# Tests
# ============================================================================

F test_response_text() -> i64 {
    ctx := Context.new("GET", "/")
    res := ctx.text(200, "Hello, World!")

    I res.status != 200 {
        println("FAIL test_response_text: expected status=200, got {res.status}")
        R 1
    }
    I res.body != "Hello, World!" {
        println("FAIL test_response_text: unexpected body: {res.body}")
        R 1
    }
    I res.content_type != "text/plain; charset=utf-8" {
        println("FAIL test_response_text: unexpected content_type: {res.content_type}")
        R 1
    }
    println("PASS test_response_text")
    0
}

F test_response_json() -> i64 {
    ctx  := Context.new("GET", "/")
    body := "{\"key\":\"value\"}"
    res  := ctx.json(200, body)

    I res.status != 200 {
        println("FAIL test_response_json: expected status=200, got {res.status}")
        R 1
    }
    I res.body != body {
        println("FAIL test_response_json: unexpected body: {res.body}")
        R 1
    }
    I res.content_type != "application/json; charset=utf-8" {
        println("FAIL test_response_json: unexpected content_type: {res.content_type}")
        R 1
    }
    println("PASS test_response_json")
    0
}

F test_response_html() -> i64 {
    ctx  := Context.new("GET", "/")
    res  := ctx.html(200, "<h1>Hello</h1>")

    I res.content_type != "text/html; charset=utf-8" {
        println("FAIL test_response_html: unexpected content_type: {res.content_type}")
        R 1
    }
    I res.body != "<h1>Hello</h1>" {
        println("FAIL test_response_html: unexpected body")
        R 1
    }
    println("PASS test_response_html")
    0
}

F test_response_status_only() -> i64 {
    ctx := Context.new("DELETE", "/users/1")
    res := ctx.status(204)

    I res.status != 204 {
        println("FAIL test_response_status_only: expected status=204, got {res.status}")
        R 1
    }
    I res.body != "" {
        println("FAIL test_response_status_only: expected empty body")
        R 1
    }
    println("PASS test_response_status_only")
    0
}

F test_response_redirect() -> i64 {
    ctx := Context.new("GET", "/old")
    res := ctx.redirect("/new")

    I res.status != 302 {
        println("FAIL test_response_redirect: expected status=302, got {res.status}")
        R 1
    }
    I res.redirect_url != "/new" {
        println("FAIL test_response_redirect: expected redirect_url=/new, got {res.redirect_url}")
        R 1
    }
    println("PASS test_response_redirect")
    0
}

F test_response_4xx_codes() -> i64 {
    ctx := Context.new("POST", "/")
    res400 := ctx.json(400, "{\"error\":\"bad input\"}")
    res401 := ctx.text(401, "Unauthorized")
    res404 := ctx.text(404, "Not Found")

    I res400.status != 400 { println("FAIL test_response_4xx_codes: 400"); R 1 }
    I res401.status != 401 { println("FAIL test_response_4xx_codes: 401"); R 1 }
    I res404.status != 404 { println("FAIL test_response_4xx_codes: 404"); R 1 }

    println("PASS test_response_4xx_codes")
    0
}

F test_response_set_header() -> i64 {
    ctx := mut Context.new("GET", "/")
    ctx = ctx.set_header("X-Request-Id", "abc-123")
    res := ctx.text(200, "ok")

    I res.headers == "" {
        println("FAIL test_response_set_header: expected headers to be set")
        R 1
    }
    println("PASS test_response_set_header")
    0
}

F test_response_created() -> i64 {
    ctx := Context.new("POST", "/users")
    res := ctx.json(201, "{\"id\":\"1\"}")
    I res.status != 201 {
        println("FAIL test_response_created: expected status=201, got {res.status}")
        R 1
    }
    println("PASS test_response_created")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_response_text()
    failures += test_response_json()
    failures += test_response_html()
    failures += test_response_status_only()
    failures += test_response_redirect()
    failures += test_response_4xx_codes()
    failures += test_response_set_header()
    failures += test_response_created()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_response)")
    0
}
