# test_yaml.vais — Unit tests for the minimal YAML parser and ServerConfig YAML loading

U util/yaml
U core/config

# ============================================================================
# Helper — build a small YAML string in code rather than reading a file
# ============================================================================

# ============================================================================
# YamlNode accessor tests
# ============================================================================

F test_parse_simple_key_value() -> i64 {
    content := "host: 127.0.0.1\nport: 9000\nenabled: true"

    M parse_yaml(content) {
        Err(e) => {
            println("FAIL test_parse_simple_key_value: parse error: {e}")
            R 1
        },
        Ok(root) => {
            M root.yaml_get_str("host") {
                Err(e) => {
                    println("FAIL test_parse_simple_key_value: yaml_get_str host: {e}")
                    R 1
                },
                Ok(v) => {
                    I v != "127.0.0.1" {
                        println("FAIL test_parse_simple_key_value: expected host=127.0.0.1, got {v}")
                        R 1
                    }
                },
            }

            M root.yaml_get_int("port") {
                Err(e) => {
                    println("FAIL test_parse_simple_key_value: yaml_get_int port: {e}")
                    R 1
                },
                Ok(v) => {
                    I v != 9000 {
                        println("FAIL test_parse_simple_key_value: expected port=9000, got {v}")
                        R 1
                    }
                },
            }

            M root.yaml_get_str("enabled") {
                Err(e) => {
                    println("FAIL test_parse_simple_key_value: yaml_get_str enabled: {e}")
                    R 1
                },
                Ok(v) => {
                    I v != "true" {
                        println("FAIL test_parse_simple_key_value: expected enabled=true, got {v}")
                        R 1
                    }
                },
            }
        },
    }

    println("PASS test_parse_simple_key_value")
    0
}

F test_parse_nested_map() -> i64 {
    content := "server:\n  host: 0.0.0.0\n  port: 8080\n  log_level: debug"

    M parse_yaml(content) {
        Err(e) => {
            println("FAIL test_parse_nested_map: parse error: {e}")
            R 1
        },
        Ok(root) => {
            M root.yaml_get_nested("server.host") {
                Err(e) => {
                    println("FAIL test_parse_nested_map: yaml_get_nested server.host: {e}")
                    R 1
                },
                Ok(node) => {
                    I node.str_val != "0.0.0.0" {
                        println("FAIL test_parse_nested_map: expected server.host=0.0.0.0, got {node.str_val}")
                        R 1
                    }
                },
            }

            M root.yaml_get_nested("server.port") {
                Err(e) => {
                    println("FAIL test_parse_nested_map: yaml_get_nested server.port: {e}")
                    R 1
                },
                Ok(node) => {
                    I node.int_val != 8080 {
                        println("FAIL test_parse_nested_map: expected server.port=8080, got {node.int_val}")
                        R 1
                    }
                },
            }

            M root.yaml_get_nested("server.log_level") {
                Err(e) => {
                    println("FAIL test_parse_nested_map: yaml_get_nested server.log_level: {e}")
                    R 1
                },
                Ok(node) => {
                    I node.str_val != "debug" {
                        println("FAIL test_parse_nested_map: expected server.log_level=debug, got {node.str_val}")
                        R 1
                    }
                },
            }
        },
    }

    println("PASS test_parse_nested_map")
    0
}

F test_parse_list() -> i64 {
    content := "items:\n  - alpha\n  - beta\n  - gamma"

    M parse_yaml(content) {
        Err(e) => {
            println("FAIL test_parse_list: parse error: {e}")
            R 1
        },
        Ok(root) => {
            M root.yaml_get_nested("items") {
                Err(e) => {
                    println("FAIL test_parse_list: yaml_get_nested items: {e}")
                    R 1
                },
                Ok(list_node) => {
                    count := list_node.list_items.len()
                    I count != 3 {
                        println("FAIL test_parse_list: expected 3 items, got {count}")
                        R 1
                    }
                    first := list_node.list_items.get(0)
                    I first.str_val != "alpha" {
                        println("FAIL test_parse_list: expected items[0]=alpha, got {first.str_val}")
                        R 1
                    }
                    second := list_node.list_items.get(1)
                    I second.str_val != "beta" {
                        println("FAIL test_parse_list: expected items[1]=beta, got {second.str_val}")
                        R 1
                    }
                    third := list_node.list_items.get(2)
                    I third.str_val != "gamma" {
                        println("FAIL test_parse_list: expected items[2]=gamma, got {third.str_val}")
                        R 1
                    }
                },
            }
        },
    }

    println("PASS test_parse_list")
    0
}

F test_comments_and_blank_lines() -> i64 {
    # Lines that are blank or start with '#' should be silently skipped
    content := "# this is a comment\n\nname: myapp\n# another comment\nversion: 2"

    M parse_yaml(content) {
        Err(e) => {
            println("FAIL test_comments_and_blank_lines: parse error: {e}")
            R 1
        },
        Ok(root) => {
            M root.yaml_get_str("name") {
                Err(e) => {
                    println("FAIL test_comments_and_blank_lines: yaml_get_str name: {e}")
                    R 1
                },
                Ok(v) => {
                    I v != "myapp" {
                        println("FAIL test_comments_and_blank_lines: expected name=myapp, got {v}")
                        R 1
                    }
                },
            }

            M root.yaml_get_int("version") {
                Err(e) => {
                    println("FAIL test_comments_and_blank_lines: yaml_get_int version: {e}")
                    R 1
                },
                Ok(v) => {
                    I v != 2 {
                        println("FAIL test_comments_and_blank_lines: expected version=2, got {v}")
                        R 1
                    }
                },
            }
        },
    }

    println("PASS test_comments_and_blank_lines")
    0
}

F test_yaml_get_str_missing_key() -> i64 {
    content := "foo: bar"

    M parse_yaml(content) {
        Err(e) => {
            println("FAIL test_yaml_get_str_missing_key: parse error: {e}")
            R 1
        },
        Ok(root) => {
            M root.yaml_get_str("nonexistent") {
                Err(_) => {
                    # Expected: missing key should produce Err
                },
                Ok(v) => {
                    println("FAIL test_yaml_get_str_missing_key: expected Err, got Ok({v})")
                    R 1
                },
            }
        },
    }

    println("PASS test_yaml_get_str_missing_key")
    0
}

F test_yaml_get_nested_missing_path() -> i64 {
    content := "server:\n  host: localhost"

    M parse_yaml(content) {
        Err(e) => {
            println("FAIL test_yaml_get_nested_missing_path: parse error: {e}")
            R 1
        },
        Ok(root) => {
            M root.yaml_get_nested("server.port") {
                Err(_) => {
                    # Expected: missing nested key should produce Err
                },
                Ok(node) => {
                    println("FAIL test_yaml_get_nested_missing_path: expected Err, got Ok(int_val={node.int_val})")
                    R 1
                },
            }
        },
    }

    println("PASS test_yaml_get_nested_missing_path")
    0
}

F test_bool_values() -> i64 {
    content := "flag_a: true\nflag_b: false"

    M parse_yaml(content) {
        Err(e) => {
            println("FAIL test_bool_values: parse error: {e}")
            R 1
        },
        Ok(root) => {
            idx_a := yaml_node_find_key(root.keys, "flag_a", 0, root.keys.len())
            I idx_a < 0 {
                println("FAIL test_bool_values: key flag_a not found")
                R 1
            }
            node_a := root.values.get(idx_a)
            I !node_a.bool_val {
                println("FAIL test_bool_values: expected flag_a=true")
                R 1
            }

            idx_b := yaml_node_find_key(root.keys, "flag_b", 0, root.keys.len())
            I idx_b < 0 {
                println("FAIL test_bool_values: key flag_b not found")
                R 1
            }
            node_b := root.values.get(idx_b)
            I node_b.bool_val {
                println("FAIL test_bool_values: expected flag_b=false")
                R 1
            }
        },
    }

    println("PASS test_bool_values")
    0
}

# ============================================================================
# ServerConfig.load_from_file — tested via parse_yaml on inline YAML string
#
# Because yaml_read_file is a runtime stub we test the config builder logic
# indirectly: construct a YamlNode tree that mirrors what load_from_file
# would produce after a successful parse_yaml call, then assert field values.
# ============================================================================

F test_config_load_from_parsed_yaml() -> i64 {
    # Simulate the YAML content that load_from_file reads
    yaml_content := "server:\n  port: 9090\n  host: 127.0.0.1\n  env: prod\n  max_connections: 500\n  read_timeout_ms: 3000\n  write_timeout_ms: 3000\n  log_level: warn"

    M parse_yaml(yaml_content) {
        Err(e) => {
            println("FAIL test_config_load_from_parsed_yaml: parse error: {e}")
            R 1
        },
        Ok(root) => {
            server_node := M root.yaml_get_nested("server") {
                Ok(n)  => { n },
                Err(e) => {
                    println("FAIL test_config_load_from_parsed_yaml: missing server block: {e}")
                    R 1
                },
            }

            port := M server_node.yaml_get_int("port") {
                Ok(v)  => { v },
                Err(e) => {
                    println("FAIL test_config_load_from_parsed_yaml: port: {e}")
                    R 1
                },
            }
            I port != 9090 {
                println("FAIL test_config_load_from_parsed_yaml: expected port=9090, got {port}")
                R 1
            }

            host := M server_node.yaml_get_str("host") {
                Ok(v)  => { v },
                Err(e) => {
                    println("FAIL test_config_load_from_parsed_yaml: host: {e}")
                    R 1
                },
            }
            I host != "127.0.0.1" {
                println("FAIL test_config_load_from_parsed_yaml: expected host=127.0.0.1, got {host}")
                R 1
            }

            env_val := M server_node.yaml_get_str("env") {
                Ok(v)  => { v },
                Err(e) => {
                    println("FAIL test_config_load_from_parsed_yaml: env: {e}")
                    R 1
                },
            }
            I env_val != "prod" {
                println("FAIL test_config_load_from_parsed_yaml: expected env=prod, got {env_val}")
                R 1
            }

            log_level := M server_node.yaml_get_str("log_level") {
                Ok(v)  => { v },
                Err(e) => {
                    println("FAIL test_config_load_from_parsed_yaml: log_level: {e}")
                    R 1
                },
            }
            I log_level != "warn" {
                println("FAIL test_config_load_from_parsed_yaml: expected log_level=warn, got {log_level}")
                R 1
            }
        },
    }

    println("PASS test_config_load_from_parsed_yaml")
    0
}

# ============================================================================
# ServerConfig.load_with_env_override — env vars shadow YAML file values.
#
# Because both yaml_read_file and env_get are runtime stubs, we validate the
# merging logic by constructing two configs manually and verifying the override
# semantics with explicit field inspection.
# ============================================================================

F test_config_env_override_logic() -> i64 {
    # Baseline: file config
    file_config := ServerConfig {
        port:             8080,
        host:             "0.0.0.0",
        env:              "dev",
        max_connections:  1000,
        read_timeout_ms:  5000,
        write_timeout_ms: 5000,
        log_level:        "info",
    }

    # Simulate an env override: SERVER_PORT=443, SERVER_ENV=prod, SERVER_LOG_LEVEL=error
    # Apply overrides manually the same way load_with_env_override does
    port_env := "443"
    env_env   := "prod"
    log_env   := "error"

    port := I str_len(port_env) > 0 {
        str_to_i64(port_env)
    } EL {
        file_config.port
    }

    env_val := I str_len(env_env) > 0 {
        env_env
    } EL {
        file_config.env
    }

    log_level := I str_len(log_env) > 0 {
        log_env
    } EL {
        file_config.log_level
    }

    merged := ServerConfig {
        port:             port,
        host:             file_config.host,
        env:              env_val,
        max_connections:  file_config.max_connections,
        read_timeout_ms:  file_config.read_timeout_ms,
        write_timeout_ms: file_config.write_timeout_ms,
        log_level:        log_level,
    }

    I merged.port != 443 {
        println("FAIL test_config_env_override_logic: expected port=443, got {merged.port}")
        R 1
    }
    I merged.env != "prod" {
        println("FAIL test_config_env_override_logic: expected env=prod, got {merged.env}")
        R 1
    }
    I merged.log_level != "error" {
        println("FAIL test_config_env_override_logic: expected log_level=error, got {merged.log_level}")
        R 1
    }
    # Host should remain from the file config
    I merged.host != "0.0.0.0" {
        println("FAIL test_config_env_override_logic: expected host=0.0.0.0, got {merged.host}")
        R 1
    }

    println("PASS test_config_env_override_logic")
    0
}

F test_config_env_no_override_when_empty() -> i64 {
    # When env vars are empty strings, file values are kept unchanged
    file_config := ServerConfig.default()

    port_env := ""
    port := I str_len(port_env) > 0 {
        str_to_i64(port_env)
    } EL {
        file_config.port
    }

    I port != 8080 {
        println("FAIL test_config_env_no_override_when_empty: expected port=8080 (unchanged), got {port}")
        R 1
    }

    println("PASS test_config_env_no_override_when_empty")
    0
}

F test_inline_comment_stripped() -> i64 {
    # Values should have inline comments stripped
    content := "app: myservice # this is the app name\nport: 7070 # default port"

    M parse_yaml(content) {
        Err(e) => {
            println("FAIL test_inline_comment_stripped: parse error: {e}")
            R 1
        },
        Ok(root) => {
            M root.yaml_get_str("app") {
                Err(e) => {
                    println("FAIL test_inline_comment_stripped: yaml_get_str app: {e}")
                    R 1
                },
                Ok(v) => {
                    I v != "myservice" {
                        println("FAIL test_inline_comment_stripped: expected app=myservice, got '{v}'")
                        R 1
                    }
                },
            }

            M root.yaml_get_int("port") {
                Err(e) => {
                    println("FAIL test_inline_comment_stripped: yaml_get_int port: {e}")
                    R 1
                },
                Ok(v) => {
                    I v != 7070 {
                        println("FAIL test_inline_comment_stripped: expected port=7070, got {v}")
                        R 1
                    }
                },
            }
        },
    }

    println("PASS test_inline_comment_stripped")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_parse_simple_key_value()
    failures += test_parse_nested_map()
    failures += test_parse_list()
    failures += test_comments_and_blank_lines()
    failures += test_yaml_get_str_missing_key()
    failures += test_yaml_get_nested_missing_path()
    failures += test_bool_values()
    failures += test_config_load_from_parsed_yaml()
    failures += test_config_env_override_logic()
    failures += test_config_env_no_override_when_empty()
    failures += test_inline_comment_stripped()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_yaml)")
    0
}

# ============================================================================
# External runtime stubs (forwarded at link time)
# ============================================================================

X F str_len(s: str) -> i64
X F str_to_i64(s: str) -> i64
