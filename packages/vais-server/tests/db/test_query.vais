# test_query.vais — Unit tests for QueryBuilder SQL generation

U db/query

# ============================================================================
# Tests
# ============================================================================

F test_query_select_all() -> i64 {
    qb  := QueryBuilder.new().select("users")
    sql := qb.build()
    I sql != "SELECT * FROM users" {
        println("FAIL test_query_select_all: got '{sql}'")
        R 1
    }
    println("PASS test_query_select_all")
    0
}

F test_query_select_columns() -> i64 {
    qb  := QueryBuilder.new()
        .select("users")
        .column("id")
        .column("name")
        .column("email")
    sql := qb.build()
    I sql != "SELECT id, name, email FROM users" {
        println("FAIL test_query_select_columns: got '{sql}'")
        R 1
    }
    println("PASS test_query_select_columns")
    0
}

F test_query_select_with_where() -> i64 {
    qb  := QueryBuilder.new()
        .select("users")
        .column("id")
        .column("name")
        .where_clause("id = 42")
    sql := qb.build()
    I sql != "SELECT id, name FROM users WHERE id = 42" {
        println("FAIL test_query_select_with_where: got '{sql}'")
        R 1
    }
    println("PASS test_query_select_with_where")
    0
}

F test_query_select_with_limit() -> i64 {
    qb  := QueryBuilder.new()
        .select("products")
        .limit(10)
    sql := qb.build()
    I sql != "SELECT * FROM products LIMIT 10" {
        println("FAIL test_query_select_with_limit: got '{sql}'")
        R 1
    }
    println("PASS test_query_select_with_limit")
    0
}

F test_query_select_order_by() -> i64 {
    qb  := QueryBuilder.new()
        .select("items")
        .order_by("name", SortDirection.Asc)
    sql := qb.build()
    I sql != "SELECT * FROM items ORDER BY name ASC" {
        println("FAIL test_query_select_order_by: got '{sql}'")
        R 1
    }
    println("PASS test_query_select_order_by")
    0
}

F test_query_insert() -> i64 {
    fields := Vec.new()
    fields.push("name")
    fields.push("email")

    qb  := QueryBuilder.new().insert("users", fields)
    sql := qb.build()
    I sql != "INSERT INTO users (name, email) VALUES (?, ?)" {
        println("FAIL test_query_insert: got '{sql}'")
        R 1
    }
    println("PASS test_query_insert")
    0
}

F test_query_update() -> i64 {
    fields := Vec.new()
    fields.push("name")
    fields.push("email")

    qb  := QueryBuilder.new()
        .update("users", fields)
        .where_clause("id = 1")
    sql := qb.build()
    I sql != "UPDATE users SET name = ?, email = ? WHERE id = 1" {
        println("FAIL test_query_update: got '{sql}'")
        R 1
    }
    println("PASS test_query_update")
    0
}

F test_query_delete() -> i64 {
    qb  := QueryBuilder.new()
        .delete("users")
        .where_clause("id = 5")
    sql := qb.build()
    I sql != "DELETE FROM users WHERE id = 5" {
        println("FAIL test_query_delete: got '{sql}'")
        R 1
    }
    println("PASS test_query_delete")
    0
}

F test_query_multiple_where() -> i64 {
    qb  := QueryBuilder.new()
        .select("orders")
        .where_clause("user_id = 1")
        .where_clause("status = 'active'")
    sql := qb.build()
    I sql != "SELECT * FROM orders WHERE user_id = 1 AND status = 'active'" {
        println("FAIL test_query_multiple_where: got '{sql}'")
        R 1
    }
    println("PASS test_query_multiple_where")
    0
}

F test_query_join() -> i64 {
    qb  := QueryBuilder.new()
        .select("orders")
        .column("orders.id")
        .column("users.name")
        .join("users", "users.id = orders.user_id")
    sql := qb.build()
    I sql != "SELECT orders.id, users.name FROM orders JOIN users ON users.id = orders.user_id" {
        println("FAIL test_query_join: got '{sql}'")
        R 1
    }
    println("PASS test_query_join")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_query_select_all()
    failures += test_query_select_columns()
    failures += test_query_select_with_where()
    failures += test_query_select_with_limit()
    failures += test_query_select_order_by()
    failures += test_query_insert()
    failures += test_query_update()
    failures += test_query_delete()
    failures += test_query_multiple_where()
    failures += test_query_join()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_query)")
    0
}
