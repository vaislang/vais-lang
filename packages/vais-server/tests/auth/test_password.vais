# test_password.vais — Unit tests for password hashing and policy validation

U auth/password

# ============================================================================
# Tests
# ============================================================================

F test_hash_password_format() -> i64 {
    h := hash_password("mypassword")

    # Hash must start with $vais$
    first6 := str_slice(h, 0, 6)
    I first6 != "$vais$" {
        println("FAIL test_hash_password_format: expected prefix $vais$, got {first6}")
        R 1
    }
    # Hash must contain at least two '$' separators beyond the prefix
    I str_len(h) < 10 {
        println("FAIL test_hash_password_format: hash is suspiciously short")
        R 1
    }

    println("PASS test_hash_password_format")
    0
}

F test_verify_password_correct() -> i64 {
    password := "correct-horse-battery"
    h        := hash_password(password)
    ok       := verify_password(password, h)
    I !ok {
        println("FAIL test_verify_password_correct: correct password should verify")
        R 1
    }
    println("PASS test_verify_password_correct")
    0
}

F test_verify_password_wrong() -> i64 {
    h    := hash_password("original")
    ok   := verify_password("different", h)
    I ok {
        println("FAIL test_verify_password_wrong: wrong password should NOT verify")
        R 1
    }
    println("PASS test_verify_password_wrong")
    0
}

F test_verify_password_invalid_hash() -> i64 {
    ok := verify_password("anything", "not-a-valid-hash")
    I ok {
        println("FAIL test_verify_password_invalid_hash: malformed hash should not verify")
        R 1
    }
    println("PASS test_verify_password_invalid_hash")
    0
}

F test_password_hasher_struct() -> i64 {
    hasher   := PasswordHasher.new()
    password := "struct-test-pw"
    h        := hasher.hash_password(password)
    ok       := hasher.verify_password(password, h)
    I !ok {
        println("FAIL test_password_hasher_struct: PasswordHasher verify should succeed")
        R 1
    }
    println("PASS test_password_hasher_struct")
    0
}

F test_validate_password_ok() -> i64 {
    policy := PasswordPolicy.default()
    # Meets all requirements: >= 8 chars, has uppercase, has digit
    result := validate_password("Secret42", policy)
    M result {
        Err(e) => {
            println("FAIL test_validate_password_ok: unexpected error: {e.message}")
            R 1
        },
        Ok(_) => {},
    }
    println("PASS test_validate_password_ok")
    0
}

F test_validate_password_too_short() -> i64 {
    policy := PasswordPolicy.default()
    result := validate_password("Ab1", policy)
    M result {
        Ok(_) => {
            println("FAIL test_validate_password_too_short: should fail for short password")
            R 1
        },
        Err(e) => {
            I e.code != 400 {
                println("FAIL test_validate_password_too_short: expected code=400, got {e.code}")
                R 1
            }
        },
    }
    println("PASS test_validate_password_too_short")
    0
}

F test_validate_password_no_uppercase() -> i64 {
    policy := PasswordPolicy.default()
    result := validate_password("lowercase1", policy)
    M result {
        Ok(_) => {
            println("FAIL test_validate_password_no_uppercase: should fail without uppercase")
            R 1
        },
        Err(_) => {},
    }
    println("PASS test_validate_password_no_uppercase")
    0
}

F test_validate_password_no_digit() -> i64 {
    policy := PasswordPolicy.default()
    result := validate_password("NoDigitHere", policy)
    M result {
        Ok(_) => {
            println("FAIL test_validate_password_no_digit: should fail without digit")
            R 1
        },
        Err(_) => {},
    }
    println("PASS test_validate_password_no_digit")
    0
}

F test_validate_password_minimal_policy() -> i64 {
    policy := PasswordPolicy.minimal()
    # Minimal: 4 chars, no uppercase/digit required
    result := validate_password("abcd", policy)
    M result {
        Err(e) => {
            println("FAIL test_validate_password_minimal_policy: unexpected error: {e.message}")
            R 1
        },
        Ok(_) => {},
    }
    println("PASS test_validate_password_minimal_policy")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_hash_password_format()
    failures += test_verify_password_correct()
    failures += test_verify_password_wrong()
    failures += test_verify_password_invalid_hash()
    failures += test_password_hasher_struct()
    failures += test_validate_password_ok()
    failures += test_validate_password_too_short()
    failures += test_validate_password_no_uppercase()
    failures += test_validate_password_no_digit()
    failures += test_validate_password_minimal_policy()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_password)")
    0
}

# ============================================================================
# External runtime stubs (needed by pw_extract_salt helpers)
# ============================================================================

X F str_len(s: str) -> i64
X F str_slice(s: str, start: i64, end: i64) -> str
X F str_char_at(s: str, i: i64) -> str
