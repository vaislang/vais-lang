# test_pipeline.vais — Unit tests for middleware Pipeline execution order

U middleware/pipeline
U core/context

# ============================================================================
# Tests
# ============================================================================

F test_pipeline_empty() -> i64 {
    p   := Pipeline.new()
    ctx := Context.new("GET", "/")

    output := p.run_before(ctx)

    I output.short_circuit {
        println("FAIL test_pipeline_empty: empty pipeline should not short-circuit")
        R 1
    }
    println("PASS test_pipeline_empty")
    0
}

F test_pipeline_add_entries() -> i64 {
    p := mut Pipeline.new()
    p = p.add("logger")
    p = p.add("cors")
    p = p.add("auth")

    I p.len() != 3 {
        println("FAIL test_pipeline_add_entries: expected 3 entries, got {p.len()}")
        R 1
    }
    I p.name_at(0) != "logger" {
        println("FAIL test_pipeline_add_entries: entry[0] expected logger, got {p.name_at(0)}")
        R 1
    }
    I p.name_at(1) != "cors" {
        println("FAIL test_pipeline_add_entries: entry[1] expected cors, got {p.name_at(1)}")
        R 1
    }
    I p.name_at(2) != "auth" {
        println("FAIL test_pipeline_add_entries: entry[2] expected auth, got {p.name_at(2)}")
        R 1
    }
    println("PASS test_pipeline_add_entries")
    0
}

F test_pipeline_before_no_short_circuit() -> i64 {
    # Default dispatch_before returns BeforeResult.next(), so no short-circuit.
    p := mut Pipeline.new()
    p = p.add("logger")
    p = p.add("cors")

    ctx    := Context.new("GET", "/test")
    output := p.run_before(ctx)

    I output.short_circuit {
        println("FAIL test_pipeline_before_no_short_circuit: should not short-circuit with pass-through middleware")
        R 1
    }
    println("PASS test_pipeline_before_no_short_circuit")
    0
}

F test_pipeline_after_passthrough() -> i64 {
    p   := mut Pipeline.new()
    p   = p.add("logger")
    ctx := Context.new("GET", "/")
    res := Response.empty()

    final_res := p.run_after(ctx, res)

    # Default dispatch_after returns response unchanged.
    I final_res.status != 200 {
        println("FAIL test_pipeline_after_passthrough: expected status=200, got {final_res.status}")
        R 1
    }
    println("PASS test_pipeline_after_passthrough")
    0
}

F test_pipeline_before_result_next() -> i64 {
    r := BeforeResult.next()
    I !r.is_next() {
        println("FAIL test_pipeline_before_result_next: expected is_next=true")
        R 1
    }
    println("PASS test_pipeline_before_result_next")
    0
}

F test_pipeline_before_result_respond() -> i64 {
    res := Response.empty()
    r   := BeforeResult.respond(res)
    I r.is_next() {
        println("FAIL test_pipeline_before_result_respond: expected is_next=false for Respond")
        R 1
    }
    println("PASS test_pipeline_before_result_respond")
    0
}

F test_pipeline_output_continue() -> i64 {
    ctx    := Context.new("POST", "/login")
    output := PipelineBeforeOutput.continue_with(ctx)
    I output.short_circuit {
        println("FAIL test_pipeline_output_continue: expected short_circuit=false")
        R 1
    }
    println("PASS test_pipeline_output_continue")
    0
}

F test_pipeline_output_stop() -> i64 {
    ctx := Context.new("POST", "/login")
    res := Response.empty()
    output := PipelineBeforeOutput.stop_with(res, ctx)
    I !output.short_circuit {
        println("FAIL test_pipeline_output_stop: expected short_circuit=true")
        R 1
    }
    println("PASS test_pipeline_output_stop")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_pipeline_empty()
    failures += test_pipeline_add_entries()
    failures += test_pipeline_before_no_short_circuit()
    failures += test_pipeline_after_passthrough()
    failures += test_pipeline_before_result_next()
    failures += test_pipeline_before_result_respond()
    failures += test_pipeline_output_continue()
    failures += test_pipeline_output_stop()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_pipeline)")
    0
}
