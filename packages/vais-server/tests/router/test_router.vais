# test_router.vais — Unit tests for Router (route registration + matching)

U router/router
U router/params

# ============================================================================
# Tests
# ============================================================================

F test_router_get_found() -> i64 {
    router := mut Router.new()
    router.get("/", 1)
    router.get("/users", 2)

    result := router.match_route(METHOD_GET, "/")
    I !result.is_found() {
        println("FAIL test_router_get_found: expected Found for GET /")
        R 1
    }
    I result.handler_id != 1 {
        println("FAIL test_router_get_found: expected handler_id=1, got {result.handler_id}")
        R 1
    }

    result2 := router.match_route(METHOD_GET, "/users")
    I !result2.is_found() {
        println("FAIL test_router_get_found: expected Found for GET /users")
        R 1
    }
    I result2.handler_id != 2 {
        println("FAIL test_router_get_found: expected handler_id=2, got {result2.handler_id}")
        R 1
    }

    println("PASS test_router_get_found")
    0
}

F test_router_not_found() -> i64 {
    router := mut Router.new()
    router.get("/users", 1)

    result := router.match_route(METHOD_GET, "/posts")
    I !result.is_not_found() {
        println("FAIL test_router_not_found: expected NotFound for GET /posts")
        R 1
    }
    println("PASS test_router_not_found")
    0
}

F test_router_method_not_allowed() -> i64 {
    router := mut Router.new()
    router.get("/users", 1)

    # POST /users is not registered → should return MethodNotAllowed
    result := router.match_route(METHOD_POST, "/users")
    I !result.is_method_not_allowed() {
        println("FAIL test_router_method_not_allowed: expected MethodNotAllowed for POST /users")
        R 1
    }
    I result.allowed_methods.len() == 0 {
        println("FAIL test_router_method_not_allowed: expected allowed_methods to be non-empty")
        R 1
    }
    println("PASS test_router_method_not_allowed")
    0
}

F test_router_param_route() -> i64 {
    router := mut Router.new()
    router.get("/users/:id", 10)

    result := router.match_route(METHOD_GET, "/users/42")
    I !result.is_found() {
        println("FAIL test_router_param_route: expected Found for GET /users/42")
        R 1
    }
    I result.handler_id != 10 {
        println("FAIL test_router_param_route: expected handler_id=10, got {result.handler_id}")
        R 1
    }
    println("PASS test_router_param_route")
    0
}

F test_router_multiple_methods() -> i64 {
    router := mut Router.new()
    router.get("/items",    1)
    router.post("/items",   2)
    router.put("/items/:id", 3)
    router.delete("/items/:id", 4)

    get_result    := router.match_route(METHOD_GET,    "/items")
    post_result   := router.match_route(METHOD_POST,   "/items")
    put_result    := router.match_route(METHOD_PUT,    "/items/7")
    delete_result := router.match_route(METHOD_DELETE, "/items/7")

    I !get_result.is_found()    { println("FAIL test_router_multiple_methods: GET");    R 1 }
    I !post_result.is_found()   { println("FAIL test_router_multiple_methods: POST");   R 1 }
    I !put_result.is_found()    { println("FAIL test_router_multiple_methods: PUT");    R 1 }
    I !delete_result.is_found() { println("FAIL test_router_multiple_methods: DELETE"); R 1 }

    I get_result.handler_id    != 1 { println("FAIL test_router_multiple_methods: GET id"); R 1 }
    I post_result.handler_id   != 2 { println("FAIL test_router_multiple_methods: POST id"); R 1 }
    I put_result.handler_id    != 3 { println("FAIL test_router_multiple_methods: PUT id"); R 1 }
    I delete_result.handler_id != 4 { println("FAIL test_router_multiple_methods: DELETE id"); R 1 }

    println("PASS test_router_multiple_methods")
    0
}

F test_router_empty() -> i64 {
    router := Router.new()
    result := router.match_route(METHOD_GET, "/anything")
    I !result.is_not_found() {
        println("FAIL test_router_empty: expected NotFound on empty router")
        R 1
    }
    println("PASS test_router_empty")
    0
}

F test_router_invalid_method() -> i64 {
    router := mut Router.new()
    router.get("/", 1)
    # Pass an out-of-range method index
    result := router.match_route(99, "/")
    I !result.is_not_found() {
        println("FAIL test_router_invalid_method: expected NotFound for invalid method")
        R 1
    }
    println("PASS test_router_invalid_method")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_router_get_found()
    failures += test_router_not_found()
    failures += test_router_method_not_allowed()
    failures += test_router_param_route()
    failures += test_router_multiple_methods()
    failures += test_router_empty()
    failures += test_router_invalid_method()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_router)")
    0
}
