# test_middleware.vais — Integration tests: Pipeline execution, CORS, Logger, RateLimit

U middleware/pipeline
U middleware/cors
U middleware/logger
U middleware/rate_limit
U core/context

# ============================================================================
# Tests
# ============================================================================

# Test 1: Pipeline with multiple entries runs before-hooks without short-circuit
F test_pipeline_multi_entry_no_short_circuit() -> i64 {
    p := mut Pipeline.new()
    p = p.add("logger")
    p = p.add("cors")
    p = p.add("rate_limit")

    I p.len() != 3 {
        println("FAIL test_pipeline_multi_entry_no_short_circuit: expected 3 entries, got {p.len()}")
        R 1
    }

    ctx    := Context.new("GET", "/api/users")
    output := p.run_before(ctx)

    I output.short_circuit {
        println("FAIL test_pipeline_multi_entry_no_short_circuit: should not short-circuit with passthrough middleware")
        R 1
    }
    println("PASS test_pipeline_multi_entry_no_short_circuit")
    0
}

# Test 2: CorsConfig.default() produces wildcard origin and standard methods
F test_cors_config_default() -> i64 {
    cfg := CorsConfig.default()

    I cfg.allowed_origins.len() == 0 {
        println("FAIL test_cors_config_default: expected at least one allowed_origin")
        R 1
    }
    first_origin := cfg.allowed_origins.get(0)
    I first_origin != "*" {
        println("FAIL test_cors_config_default: expected wildcard origin '*', got {first_origin}")
        R 1
    }
    I cfg.max_age != 86400 {
        println("FAIL test_cors_config_default: expected max_age=86400, got {cfg.max_age}")
        R 1
    }
    I cfg.allowed_methods.len() == 0 {
        println("FAIL test_cors_config_default: expected non-empty allowed_methods")
        R 1
    }
    println("PASS test_cors_config_default")
    0
}

# Test 3: LoggerConfig variants — default is Text, json() is Json format
F test_logger_config_variants() -> i64 {
    default_cfg := LoggerConfig.default()
    json_cfg    := LoggerConfig.json()

    M default_cfg.format {
        LogFormat.Text => {
            println("  ok: default is Text")
        },
        LogFormat.Json => {
            println("FAIL test_logger_config_variants: default should be Text, got Json")
            R 1
        },
    }

    M json_cfg.format {
        LogFormat.Json => {
            println("  ok: json() is Json")
        },
        LogFormat.Text => {
            println("FAIL test_logger_config_variants: json() should be Json, got Text")
            R 1
        },
    }

    println("PASS test_logger_config_variants")
    0
}

# Test 4: RateLimitConfig.default() has expected max_requests and window_ms
F test_rate_limit_config_default() -> i64 {
    cfg := RateLimitConfig.default()

    I cfg.max_requests != 100 {
        println("FAIL test_rate_limit_config_default: expected max_requests=100, got {cfg.max_requests}")
        R 1
    }
    I cfg.window_ms != 60000 {
        println("FAIL test_rate_limit_config_default: expected window_ms=60000, got {cfg.window_ms}")
        R 1
    }
    println("PASS test_rate_limit_config_default")
    0
}

# Test 5: RateLimitStore respects window — first request in window returns count=1
F test_rate_limit_store_first_request() -> i64 {
    store  := mut RateLimitStore.new()
    now_ms := 1000000
    count  := store.check_and_increment("192.168.1.1", now_ms, 60000)

    I count != 1 {
        println("FAIL test_rate_limit_store_first_request: expected count=1 for first request, got {count}")
        R 1
    }
    println("PASS test_rate_limit_store_first_request")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    println("=== Integration Tests: Middleware (Pipeline, CORS, Logger, RateLimit) ===")

    failures := mut 0
    failures += test_pipeline_multi_entry_no_short_circuit()
    failures += test_cors_config_default()
    failures += test_logger_config_variants()
    failures += test_rate_limit_config_default()
    failures += test_rate_limit_store_first_request()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_middleware)")
    0
}
