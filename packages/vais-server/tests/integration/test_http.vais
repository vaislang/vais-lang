# test_http.vais — Integration tests: Request/Response builders, Header/Cookie handling

U core/context
U http/header
U http/cookie

# ============================================================================
# Tests
# ============================================================================

# Test 1: Request builder — text response has correct content-type and body
F test_request_text_response() -> i64 {
    ctx := Context.new("GET", "/hello")
    res := ctx.text(200, "Hello, World!")

    I res.status != 200 {
        println("FAIL test_request_text_response: expected status=200, got {res.status}")
        R 1
    }
    I res.body != "Hello, World!" {
        println("FAIL test_request_text_response: unexpected body: {res.body}")
        R 1
    }
    I res.content_type != "text/plain; charset=utf-8" {
        println("FAIL test_request_text_response: unexpected content_type: {res.content_type}")
        R 1
    }
    println("PASS test_request_text_response")
    0
}

# Test 2: Response builder — JSON response carries correct content-type
F test_response_json_builder() -> i64 {
    ctx  := Context.new("POST", "/api/users")
    body := "{\"id\":\"1\",\"name\":\"Alice\"}"
    res  := ctx.json(201, body)

    I res.status != 201 {
        println("FAIL test_response_json_builder: expected status=201, got {res.status}")
        R 1
    }
    I res.body != body {
        println("FAIL test_response_json_builder: unexpected body: {res.body}")
        R 1
    }
    I res.content_type != "application/json; charset=utf-8" {
        println("FAIL test_response_json_builder: unexpected content_type: {res.content_type}")
        R 1
    }
    println("PASS test_response_json_builder")
    0
}

# Test 3: Header manipulation via Context.set_header
F test_header_set_get() -> i64 {
    headers := mut Headers.new()
    headers = headers.set("X-Request-Id", "abc-123")
    headers = headers.set("Content-Type", "application/json")

    val := headers.get("X-Request-Id")
    I val != "abc-123" {
        println("FAIL test_header_set_get: expected abc-123, got {val}")
        R 1
    }
    I !headers.has("Content-Type") {
        println("FAIL test_header_set_get: Content-Type header missing")
        R 1
    }
    println("PASS test_header_set_get")
    0
}

# Test 4: Cookie construction and serialization
F test_cookie_new_and_header_string() -> i64 {
    c := Cookie.new("session", "tok123")
    c2 := c.with_path("/api").with_http_only(1).with_secure(1)

    header_str := c2.to_header_string()

    # Should contain name=value pair
    I header_str == "" {
        println("FAIL test_cookie_new_and_header_string: to_header_string returned empty")
        R 1
    }
    println("PASS test_cookie_new_and_header_string: {header_str}")
    0
}

# Test 5: Context set_header produces non-empty response_headers field
F test_context_set_header_propagates() -> i64 {
    ctx  := Context.new("GET", "/")
    ctx2 := ctx.set_header("Authorization", "Bearer tok")
    ctx3 := ctx2.set_header("X-Custom", "value")

    I ctx3.response_headers == "" {
        println("FAIL test_context_set_header_propagates: response_headers must not be empty")
        R 1
    }

    # Headers should be embedded in the produced response
    res := ctx3.json(200, "[]")
    I res.headers == "" {
        println("FAIL test_context_set_header_propagates: response headers must not be empty")
        R 1
    }
    println("PASS test_context_set_header_propagates")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    println("=== Integration Tests: HTTP (Request/Response, Header, Cookie) ===")

    failures := mut 0
    failures += test_request_text_response()
    failures += test_response_json_builder()
    failures += test_header_set_get()
    failures += test_cookie_new_and_header_string()
    failures += test_context_set_header_propagates()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_http)")
    0
}
