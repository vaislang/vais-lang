# test_router.vais — Integration tests: Route registration, PathParams, RouteGroup

U router/router
U router/params
U router/group

# ============================================================================
# Tests
# ============================================================================

# Test 1: Route registration and match — GET route found with correct handler_id
F test_route_registration_found() -> i64 {
    router := mut Router.new()
    router.get("/",       1)
    router.get("/health", 2)
    router.get("/api",    3)

    r := router.match_route(METHOD_GET, "/health")
    I !r.is_found() {
        println("FAIL test_route_registration_found: expected Found for GET /health")
        R 1
    }
    I r.handler_id != 2 {
        println("FAIL test_route_registration_found: expected handler_id=2, got {r.handler_id}")
        R 1
    }
    println("PASS test_route_registration_found")
    0
}

# Test 2: PathParams extraction from :param route segment
F test_path_params_extraction() -> i64 {
    router := mut Router.new()
    router.get("/users/:id", 10)

    r := router.match_route(METHOD_GET, "/users/42")
    I !r.is_found() {
        println("FAIL test_path_params_extraction: expected Found for GET /users/42")
        R 1
    }
    I r.handler_id != 10 {
        println("FAIL test_path_params_extraction: expected handler_id=10, got {r.handler_id}")
        R 1
    }

    # Verify param extraction via Params API
    id_val := r.params.get_or("id", "")
    I id_val != "42" {
        println("FAIL test_path_params_extraction: expected id=42, got {id_val}")
        R 1
    }
    println("PASS test_path_params_extraction")
    0
}

# Test 3: RouteGroup applies prefix to all registered routes
F test_route_group_prefix() -> i64 {
    router := mut Router.new()
    group  := mut RouteGroup.new(router, "/api/v1")
    group.get("/users", 20)
    group.post("/users", 21)

    # Routes should be registered under the full prefixed path
    r_get  := router.match_route(METHOD_GET,  "/api/v1/users")
    r_post := router.match_route(METHOD_POST, "/api/v1/users")

    I !r_get.is_found() {
        println("FAIL test_route_group_prefix: GET /api/v1/users not found")
        R 1
    }
    I r_get.handler_id != 20 {
        println("FAIL test_route_group_prefix: expected handler_id=20, got {r_get.handler_id}")
        R 1
    }
    I !r_post.is_found() {
        println("FAIL test_route_group_prefix: POST /api/v1/users not found")
        R 1
    }
    I r_post.handler_id != 21 {
        println("FAIL test_route_group_prefix: expected handler_id=21, got {r_post.handler_id}")
        R 1
    }
    println("PASS test_route_group_prefix")
    0
}

# Test 4: Unregistered path returns NotFound
F test_route_not_found() -> i64 {
    router := mut Router.new()
    router.get("/known", 1)

    r := router.match_route(METHOD_GET, "/unknown")
    I !r.is_not_found() {
        println("FAIL test_route_not_found: expected NotFound for GET /unknown")
        R 1
    }
    println("PASS test_route_not_found")
    0
}

# Test 5: Wrong HTTP method returns MethodNotAllowed with allowed methods list
F test_route_method_not_allowed() -> i64 {
    router := mut Router.new()
    router.get("/items", 1)
    router.put("/items", 2)

    # POST /items is not registered
    r := router.match_route(METHOD_POST, "/items")
    I !r.is_method_not_allowed() {
        println("FAIL test_route_method_not_allowed: expected MethodNotAllowed for POST /items")
        R 1
    }
    I r.allowed_methods.len() == 0 {
        println("FAIL test_route_method_not_allowed: allowed_methods should be non-empty")
        R 1
    }
    println("PASS test_route_method_not_allowed")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    println("=== Integration Tests: Router (Registration, PathParams, RouteGroup) ===")

    failures := mut 0
    failures += test_route_registration_found()
    failures += test_path_params_extraction()
    failures += test_route_group_prefix()
    failures += test_route_not_found()
    failures += test_route_method_not_allowed()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_router)")
    0
}
