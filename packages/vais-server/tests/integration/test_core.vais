# test_core.vais — Integration tests: App init, Config load, Error handling

U core/app
U core/config
U core/context
U core/error

# ============================================================================
# Tests
# ============================================================================

# Test 1: App initializes with default config and zero routes/middlewares
F test_app_init_defaults() -> i64 {
    config := ServerConfig.default()
    app    := App.new(config)

    I app.route_count() != 0 {
        println("FAIL test_app_init_defaults: expected 0 routes, got {app.route_count()}")
        R 1
    }
    I app.middleware_count() != 0 {
        println("FAIL test_app_init_defaults: expected 0 middlewares, got {app.middleware_count()}")
        R 1
    }
    println("PASS test_app_init_defaults")
    0
}

# Test 2: App registers routes and counts them correctly
F test_app_route_count() -> i64 {
    config := ServerConfig.default()
    app    := mut App.new(config)

    app.get("/",           "handle_home")
    app.post("/users",     "handle_create")
    app.get("/users/:id",  "handle_get")
    app.put("/users/:id",  "handle_update")
    app.delete("/users/:id", "handle_delete")

    I app.route_count() != 5 {
        println("FAIL test_app_route_count: expected 5 routes, got {app.route_count()}")
        R 1
    }
    println("PASS test_app_route_count")
    0
}

# Test 3: App registers middlewares and counts them correctly
F test_app_middleware_count() -> i64 {
    config := ServerConfig.default()
    app    := mut App.new(config)

    app.use_mw("logger")
    app.use_mw("cors")
    app.use_mw("rate_limit")

    I app.middleware_count() != 3 {
        println("FAIL test_app_middleware_count: expected 3 middlewares, got {app.middleware_count()}")
        R 1
    }
    println("PASS test_app_middleware_count")
    0
}

# Test 4: Config validation rejects port=0 with status 400
F test_config_load_invalid_port() -> i64 {
    bad_config := ServerConfig {
        port:             0,
        host:             "0.0.0.0",
        env:              "dev",
        max_connections:  1000,
        read_timeout_ms:  5000,
        write_timeout_ms: 5000,
        log_level:        "info",
    }
    M bad_config.validate() {
        Err(e) => {
            I e.status != 400 {
                println("FAIL test_config_load_invalid_port: expected status=400, got {e.status}")
                R 1
            }
            println("PASS test_config_load_invalid_port")
            R 0
        },
        Ok(_) => {
            println("FAIL test_config_load_invalid_port: expected error for port=0")
            R 1
        },
    }
}

# Test 5: VaisServerError variants produce correct HTTP status codes
F test_error_status_codes() -> i64 {
    e400 := VaisServerError.bad_request("bad input")
    e401 := VaisServerError.unauthorized("token missing")
    e404 := VaisServerError.not_found("resource gone")
    e500 := VaisServerError.internal("crash")

    I e400.status != 400 {
        println("FAIL test_error_status_codes: expected 400, got {e400.status}")
        R 1
    }
    I e401.status != 401 {
        println("FAIL test_error_status_codes: expected 401, got {e401.status}")
        R 1
    }
    I e404.status != 404 {
        println("FAIL test_error_status_codes: expected 404, got {e404.status}")
        R 1
    }
    I e500.status != 500 {
        println("FAIL test_error_status_codes: expected 500, got {e500.status}")
        R 1
    }
    println("PASS test_error_status_codes")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    println("=== Integration Tests: Core (App, Config, Error) ===")

    failures := mut 0
    failures += test_app_init_defaults()
    failures += test_app_route_count()
    failures += test_app_middleware_count()
    failures += test_config_load_invalid_port()
    failures += test_error_status_codes()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_core)")
    0
}
