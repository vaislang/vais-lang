# test_error.vais — Unit tests for VaisServerError

U core/error

# ============================================================================
# Tests
# ============================================================================

F test_error_not_found() -> i64 {
    e := VaisServerError.not_found("resource not found")
    I e.status != 404 {
        println("FAIL test_error_not_found: expected status=404, got {e.status}")
        R 1
    }
    I e.code != 404 {
        println("FAIL test_error_not_found: expected code=404, got {e.code}")
        R 1
    }
    I e.message != "resource not found" {
        println("FAIL test_error_not_found: unexpected message: {e.message}")
        R 1
    }
    println("PASS test_error_not_found")
    0
}

F test_error_bad_request() -> i64 {
    e := VaisServerError.bad_request("invalid input")
    I e.status != 400 {
        println("FAIL test_error_bad_request: expected status=400, got {e.status}")
        R 1
    }
    println("PASS test_error_bad_request")
    0
}

F test_error_unauthorized() -> i64 {
    e := VaisServerError.unauthorized("token required")
    I e.status != 401 {
        println("FAIL test_error_unauthorized: expected status=401, got {e.status}")
        R 1
    }
    println("PASS test_error_unauthorized")
    0
}

F test_error_internal() -> i64 {
    e := VaisServerError.internal("unexpected crash")
    I e.status != 500 {
        println("FAIL test_error_internal: expected status=500, got {e.status}")
        R 1
    }
    println("PASS test_error_internal")
    0
}

F test_is_client_error() -> i64 {
    e400 := VaisServerError.bad_request("bad")
    e401 := VaisServerError.unauthorized("unauth")
    e404 := VaisServerError.not_found("nf")
    e500 := VaisServerError.internal("oops")

    I !e400.is_client_error() {
        println("FAIL test_is_client_error: 400 should be client error")
        R 1
    }
    I !e401.is_client_error() {
        println("FAIL test_is_client_error: 401 should be client error")
        R 1
    }
    I !e404.is_client_error() {
        println("FAIL test_is_client_error: 404 should be client error")
        R 1
    }
    I e500.is_client_error() {
        println("FAIL test_is_client_error: 500 should NOT be client error")
        R 1
    }
    println("PASS test_is_client_error")
    0
}

F test_is_server_error() -> i64 {
    e500 := VaisServerError.internal("crash")
    e404 := VaisServerError.not_found("nf")
    e503 := VaisServerError.new(503, "service unavailable", 503)

    I !e500.is_server_error() {
        println("FAIL test_is_server_error: 500 should be server error")
        R 1
    }
    I !e503.is_server_error() {
        println("FAIL test_is_server_error: 503 should be server error")
        R 1
    }
    I e404.is_server_error() {
        println("FAIL test_is_server_error: 404 should NOT be server error")
        R 1
    }
    println("PASS test_is_server_error")
    0
}

F test_error_to_string() -> i64 {
    e := VaisServerError.bad_request("invalid port")
    s := e.to_string()
    # Should contain "[400]" and the message
    I s == "" {
        println("FAIL test_error_to_string: to_string returned empty string")
        R 1
    }
    println("PASS test_error_to_string: {s}")
    0
}

F test_error_new_custom() -> i64 {
    e := VaisServerError.new(409, "conflict detected", 409)
    I e.status != 409 {
        println("FAIL test_error_new_custom: expected status=409, got {e.status}")
        R 1
    }
    I e.code != 409 {
        println("FAIL test_error_new_custom: expected code=409, got {e.code}")
        R 1
    }
    println("PASS test_error_new_custom")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_error_not_found()
    failures += test_error_bad_request()
    failures += test_error_unauthorized()
    failures += test_error_internal()
    failures += test_is_client_error()
    failures += test_is_server_error()
    failures += test_error_to_string()
    failures += test_error_new_custom()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_error)")
    0
}
