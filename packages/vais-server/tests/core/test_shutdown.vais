# test_shutdown.vais — Unit tests for ShutdownCoordinator

U core/shutdown

# ============================================================================
# Tests
# ============================================================================

# Initial state: shutdown_flag=0, active_connections=0
F test_shutdown_initial_state() -> i64 {
    coord := ShutdownCoordinator.new()

    I coord.shutdown_flag != 0 {
        println("FAIL test_shutdown_initial_state: expected shutdown_flag=0, got {coord.shutdown_flag}")
        R 1
    }
    I coord.active_connections != 0 {
        println("FAIL test_shutdown_initial_state: expected active_connections=0, got {coord.active_connections}")
        R 1
    }
    println("PASS test_shutdown_initial_state")
    0
}

# request_shutdown sets shutdown_flag to 1
F test_request_shutdown() -> i64 {
    coord := mut ShutdownCoordinator.new()
    coord.request_shutdown()

    I coord.shutdown_flag != 1 {
        println("FAIL test_request_shutdown: expected shutdown_flag=1, got {coord.shutdown_flag}")
        R 1
    }
    println("PASS test_request_shutdown")
    0
}

# is_shutdown_requested returns false before request, true after
F test_is_shutdown_requested() -> i64 {
    coord := mut ShutdownCoordinator.new()

    I coord.is_shutdown_requested() {
        println("FAIL test_is_shutdown_requested: should be false before request_shutdown")
        R 1
    }

    coord.request_shutdown()

    I !coord.is_shutdown_requested() {
        println("FAIL test_is_shutdown_requested: should be true after request_shutdown")
        R 1
    }

    println("PASS test_is_shutdown_requested")
    0
}

# increment_connections increases active_connections by 1 each call
F test_increment_connections() -> i64 {
    coord := mut ShutdownCoordinator.new()
    coord.increment_connections()

    I coord.active_connections != 1 {
        println("FAIL test_increment_connections: expected active_connections=1, got {coord.active_connections}")
        R 1
    }

    coord.increment_connections()

    I coord.active_connections != 2 {
        println("FAIL test_increment_connections: expected active_connections=2, got {coord.active_connections}")
        R 1
    }

    println("PASS test_increment_connections")
    0
}

# decrement_connections decreases active_connections by 1 each call
F test_decrement_connections() -> i64 {
    coord := mut ShutdownCoordinator.new()
    coord.increment_connections()
    coord.increment_connections()
    coord.decrement_connections()

    I coord.active_connections != 1 {
        println("FAIL test_decrement_connections: expected active_connections=1, got {coord.active_connections}")
        R 1
    }

    coord.decrement_connections()

    I coord.active_connections != 0 {
        println("FAIL test_decrement_connections: expected active_connections=0, got {coord.active_connections}")
        R 1
    }

    println("PASS test_decrement_connections")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_shutdown_initial_state()
    failures += test_request_shutdown()
    failures += test_is_shutdown_requested()
    failures += test_increment_connections()
    failures += test_decrement_connections()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_shutdown)")
    0
}
