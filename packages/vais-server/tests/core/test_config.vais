# test_config.vais — Unit tests for ServerConfig

U core/config
U core/error

# ============================================================================
# Tests
# ============================================================================

F test_config_default() -> i64 {
    config := ServerConfig.default()

    I config.port != 8080 {
        println("FAIL test_config_default: expected port=8080, got {config.port}")
        R 1
    }
    I config.host != "0.0.0.0" {
        println("FAIL test_config_default: expected host=0.0.0.0, got {config.host}")
        R 1
    }
    I config.env != "dev" {
        println("FAIL test_config_default: expected env=dev, got {config.env}")
        R 1
    }
    I config.max_connections != 1000 {
        println("FAIL test_config_default: expected max_connections=1000, got {config.max_connections}")
        R 1
    }
    I config.log_level != "info" {
        println("FAIL test_config_default: expected log_level=info, got {config.log_level}")
        R 1
    }
    println("PASS test_config_default")
    0
}

F test_config_validate_ok() -> i64 {
    config := ServerConfig.default()
    M config.validate() {
        Ok(_) => {
            println("PASS test_config_validate_ok")
            R 0
        },
        Err(e) => {
            println("FAIL test_config_validate_ok: unexpected error: {e.message}")
            R 1
        },
    }
}

F test_config_invalid_port_zero() -> i64 {
    config := ServerConfig {
        port:              0,
        host:              "0.0.0.0",
        env:               "dev",
        max_connections:   1000,
        read_timeout_ms:   5000,
        write_timeout_ms:  5000,
        log_level:         "info",
    }
    M config.validate() {
        Err(e) => {
            I e.status != 400 {
                println("FAIL test_config_invalid_port_zero: expected status=400, got {e.status}")
                R 1
            }
            println("PASS test_config_invalid_port_zero")
            R 0
        },
        Ok(_) => {
            println("FAIL test_config_invalid_port_zero: expected validation error for port=0")
            R 1
        },
    }
}

F test_config_invalid_env() -> i64 {
    config := ServerConfig {
        port:              8080,
        host:              "0.0.0.0",
        env:               "staging",
        max_connections:   1000,
        read_timeout_ms:   5000,
        write_timeout_ms:  5000,
        log_level:         "info",
    }
    M config.validate() {
        Err(e) => {
            I e.status != 400 {
                println("FAIL test_config_invalid_env: expected status=400, got {e.status}")
                R 1
            }
            println("PASS test_config_invalid_env")
            R 0
        },
        Ok(_) => {
            println("FAIL test_config_invalid_env: expected validation error for env=staging")
            R 1
        },
    }
}

F test_config_invalid_log_level() -> i64 {
    config := ServerConfig {
        port:              8080,
        host:              "0.0.0.0",
        env:               "dev",
        max_connections:   1000,
        read_timeout_ms:   5000,
        write_timeout_ms:  5000,
        log_level:         "verbose",
    }
    M config.validate() {
        Err(e) => {
            I e.status != 400 {
                println("FAIL test_config_invalid_log_level: expected status=400, got {e.status}")
                R 1
            }
            println("PASS test_config_invalid_log_level")
            R 0
        },
        Ok(_) => {
            println("FAIL test_config_invalid_log_level: expected validation error for log_level=verbose")
            R 1
        },
    }
}

F test_config_addr() -> i64 {
    config := ServerConfig.default()
    addr   := config.addr()
    I addr != "0.0.0.0:8080" {
        println("FAIL test_config_addr: expected 0.0.0.0:8080, got {addr}")
        R 1
    }
    println("PASS test_config_addr")
    0
}

F test_config_is_prod() -> i64 {
    dev_config := ServerConfig.default()
    I dev_config.is_prod() {
        println("FAIL test_config_is_prod: dev config should not be prod")
        R 1
    }

    prod_config := ServerConfig {
        port:              443,
        host:              "0.0.0.0",
        env:               "prod",
        max_connections:   5000,
        read_timeout_ms:   3000,
        write_timeout_ms:  3000,
        log_level:         "warn",
    }
    I !prod_config.is_prod() {
        println("FAIL test_config_is_prod: prod config should be prod")
        R 1
    }

    println("PASS test_config_is_prod")
    0
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    failures := mut 0
    failures += test_config_default()
    failures += test_config_validate_ok()
    failures += test_config_invalid_port_zero()
    failures += test_config_invalid_env()
    failures += test_config_invalid_log_level()
    failures += test_config_addr()
    failures += test_config_is_prod()

    I failures > 0 {
        println("FAILED: {failures} test(s) failed")
        R 1
    }
    println("ALL TESTS PASSED (test_config)")
    0
}
