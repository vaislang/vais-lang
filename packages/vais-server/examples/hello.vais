# hello.vais — Minimal "Hello, World!" vais-server example
#
# Demonstrates:
#   - Creating an App with default configuration
#   - Registering a single GET route
#   - Starting the server with app.listen()

U core/app
U core/config
U core/context

C PORT: u16 = 8080

# ============================================================================
# Handler
# ============================================================================

# GET / — returns a plain-text "Hello, World!" response.
F handle_hello(ctx: Context) -> Response {
    ctx.text(200, "Hello, World!")
}

# ============================================================================
# main
# ============================================================================

F main() -> i64 {
    config := ServerConfig.default()
    app    := mut App.new(config)

    app.get("/", "handle_hello")

    addr := ":{PORT}"
    println("Starting hello server on {addr}")

    M app.listen(addr) {
        Ok(_) => {
            println("Server stopped gracefully.")
        },
        Err(e) => {
            println("Failed to start server: {e.message}")
            R 1
        },
    }
    0
}
