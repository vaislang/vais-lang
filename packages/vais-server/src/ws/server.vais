# WebSocket Server
# WsServer manages connections and handles the HTTP→WebSocket upgrade flow.
# WsConnection represents a single live WebSocket connection.
# WsConfig holds all tunable server parameters.

use std/string
use std/vec
use core/error
use ws/message

# ============================================================================
# WsConfig — tunable parameters for the WebSocket server
# ============================================================================

struct WsConfig {
    max_connections:  i64,   # Maximum number of concurrent WebSocket connections
    ping_interval_ms: i64,   # Interval between server-initiated pings, in milliseconds
    max_message_size: i64,   # Maximum allowed inbound message size, in bytes
}

impl WsConfig {
    # Returns a sensible out-of-the-box configuration
    fn default() -> WsConfig {
        WsConfig {
            max_connections:  1000,
            ping_interval_ms: 30000,
            max_message_size: 65536,
        }
    }

    # Validate all config fields; returns Err on the first violation found
    fn validate(self) -> Result<(), VaisServerError> {
        I self.max_connections <= 0 {
            return Err(VaisServerError.bad_request("max_connections must be greater than 0"))
        }
        I self.ping_interval_ms < 0 {
            return Err(VaisServerError.bad_request("ping_interval_ms must be >= 0"))
        }
        I self.max_message_size <= 0 {
            return Err(VaisServerError.bad_request("max_message_size must be greater than 0"))
        }
        Ok(())
    }

    # Returns true when heartbeat pings are enabled (interval > 0)
    fn heartbeat_enabled(self) -> bool {
        self.ping_interval_ms > 0
    }
}

# ============================================================================
# ConnectionState — lifecycle state of a single WebSocket connection
# ============================================================================

enum ConnectionState {
    Connected,   # Handshake complete; frames may flow in both directions
    Closing,     # Close handshake initiated; waiting for peer close frame
    Closed,      # Connection fully closed; no further I/O
}

# ============================================================================
# WsConnection — a single live WebSocket connection
# ============================================================================

struct WsConnection {
    conn_id:     i64,
    state:       ConnectionState,
    remote_addr: str,
}

impl WsConnection {
    # Create a new connection in the Connected state
    fn new(conn_id: i64, remote_addr: str) -> WsConnection {
        WsConnection {
            conn_id:     conn_id,
            state:       ConnectionState.Connected,
            remote_addr: remote_addr,
        }
    }

    # Send a message to this connection.
    # Returns Err when the connection is not in the Connected state.
    fn send(self, msg: WsMessage) -> Result<(), VaisServerError> {
        match self.state {
            ConnectionState.Connected => {
                # FUTURE(std/ws_runtime): hand off msg to the I/O runtime
                Ok(())
            },
            ConnectionState.Closing => {
                Err(VaisServerError.new(1001, "Connection is closing", 400))
            },
            ConnectionState.Closed => {
                Err(VaisServerError.new(1002, "Connection is closed", 400))
            },
        }
    }

    # Initiate a graceful close handshake.
    # code:   WebSocket close status code (e.g. 1000 = normal closure)
    # reason: human-readable reason string
    fn close(mut self, code: i64, reason: str) -> Result<(), VaisServerError> {
        match self.state {
            ConnectionState.Connected => {
                self.state = ConnectionState.Closing
                close_msg := WsMessage.close(reason)
                # FUTURE(std/ws_runtime): deliver close frame with code
                Ok(())
            },
            ConnectionState.Closing => {
                # Already closing — no-op
                Ok(())
            },
            ConnectionState.Closed => {
                Err(VaisServerError.new(1003, "Connection already closed", 400))
            },
        }
    }

    # Send a ping frame to the peer (heartbeat)
    fn ping(self, payload: str) -> Result<(), VaisServerError> {
        self.send(WsMessage.ping(payload))
    }

    # Send a pong frame in response to a ping
    fn pong(self, payload: str) -> Result<(), VaisServerError> {
        self.send(WsMessage.pong(payload))
    }

    # Returns true when the connection is in the Connected state
    fn is_connected(self) -> bool {
        self.state == ConnectionState.Connected
    }

    # Returns true when the connection has been fully closed
    fn is_closed(self) -> bool {
        self.state == ConnectionState.Closed
    }
}

# ============================================================================
# ConnectionEntry — internal conn_id→connection record stored in WsServer
# ============================================================================

struct ConnectionEntry {
    conn_id:    i64,
    connection: WsConnection,
}

impl ConnectionEntry {
    fn new(conn: WsConnection) -> ConnectionEntry {
        ConnectionEntry {
            conn_id:    conn.conn_id,
            connection: conn,
        }
    }
}

# ============================================================================
# WsServer — manages all WebSocket connections and the upgrade protocol
# ============================================================================

struct WsServer {
    config:      WsConfig,
    connections: Vec<ConnectionEntry>,
    next_id:     i64,
}

impl WsServer {
    # Create a new WsServer with the given configuration
    fn new(config: WsConfig) -> WsServer {
        WsServer {
            config:      config,
            connections: Vec.new(),
            next_id:     1,
        }
    }

    # Create a WsServer with default configuration
    fn default() -> WsServer {
        WsServer.new(WsConfig.default())
    }

    # -------------------------------------------------------------------------
    # Connection lifecycle
    # -------------------------------------------------------------------------

    # Perform the HTTP→WebSocket upgrade for an incoming request.
    # Allocates a new WsConnection, registers it, and returns it.
    # Returns Err when the connection limit has been reached.
    fn upgrade_request(mut self, remote_addr: str) -> Result<WsConnection, VaisServerError> {
        active := self._active_count()
        I active >= self.config.max_connections {
            return Err(VaisServerError.new(1008, "Connection limit reached", 503))
        }

        conn_id := self.next_id
        self.next_id += 1

        conn  := WsConnection.new(conn_id, remote_addr)
        entry := ConnectionEntry.new(conn)
        self.connections.push(entry)

        # FUTURE(std/ws_runtime): send 101 Switching Protocols response with
        # required headers (Upgrade, Connection, Sec-WebSocket-Accept).

        return Ok(conn)
    }

    # Mark a connection as Closed and remove it from the active pool.
    fn remove_connection(mut self, conn_id: i64) {
        new_conns := mut Vec.new()
        i := mut 0
        LW i < self.connections.len() {
            entry := self.connections.get(i)
            I entry.conn_id != conn_id {
                new_conns.push(entry)
            }
            i += 1
        }
        self.connections = new_conns
    }

    # Retrieve a connection by conn_id.
    # Returns a default closed connection when the id is not found.
    fn get_connection(self, conn_id: i64) -> WsConnection {
        i := mut 0
        LW i < self.connections.len() {
            entry := self.connections.get(i)
            I entry.conn_id == conn_id {
                return entry.connection
            }
            i += 1
        }
        # Return a sentinel closed connection
        closed := mut WsConnection.new(conn_id, "")
        closed.state = ConnectionState.Closed
        closed
    }

    # Returns true when a connection with the given id exists in the pool
    fn has_connection(self, conn_id: i64) -> bool {
        i := mut 0
        LW i < self.connections.len() {
            entry := self.connections.get(i)
            I entry.conn_id == conn_id {
                return true
            }
            i += 1
        }
        false
    }

    # -------------------------------------------------------------------------
    # Heartbeat (ping/pong)
    # -------------------------------------------------------------------------

    # Send a ping to all currently Connected peers.
    # Intended to be called on a timer at config.ping_interval_ms intervals.
    # Returns the number of connections pinged.
    fn broadcast_ping(self, payload: str) -> i64 {
        count := mut 0
        i := mut 0
        LW i < self.connections.len() {
            entry := self.connections.get(i)
            I entry.connection.is_connected() {
                entry.connection.ping(payload)
                count += 1
            }
            i += 1
        }
        count
    }

    # -------------------------------------------------------------------------
    # Diagnostics
    # -------------------------------------------------------------------------

    # Total number of tracked connection entries (including closing/closed)
    fn connection_count(self) -> i64 {
        self.connections.len()
    }

    # -------------------------------------------------------------------------
    # Internal helpers
    # -------------------------------------------------------------------------

    # Count connections that are in the Connected state
    fn _active_count(self) -> i64 {
        count := mut 0
        i := mut 0
        LW i < self.connections.len() {
            entry := self.connections.get(i)
            I entry.connection.is_connected() {
                count += 1
            }
            i += 1
        }
        count
    }
}
