# vaisdb Query Builder
# Hybrid query builder covering SQL, VECTOR_SEARCH, GRAPH_TRAVERSE, FULLTEXT_MATCH

use std/string
use std/vec

# ============================================================================
# SortDirection — ORDER BY direction
# ============================================================================

enum SortDirection {
    Asc,
    Desc,
}

# ============================================================================
# QueryKind — tracks what type of specialised clause is active
# ============================================================================

enum QueryKind {
    Standard,
    VectorSearch,
    GraphTraverse,
    FulltextMatch,
    BeginTransaction,
    Commit,
    Rollback,
}

# ============================================================================
# JoinEntry — a single JOIN clause
# ============================================================================

struct JoinEntry {
    table: str,
    on_clause: str,
}

impl JoinEntry {
    fn new(table: str, on_clause: str) -> JoinEntry {
        JoinEntry { table: table, on_clause: on_clause }
    }
}

# ============================================================================
# OrderEntry — a single ORDER BY term
# ============================================================================

struct OrderEntry {
    field: str,
    direction: SortDirection,
}

impl OrderEntry {
    fn new(field: str, direction: SortDirection) -> OrderEntry {
        OrderEntry { field: field, direction: direction }
    }

    fn to_string(self) -> str {
        match self.direction {
            SortDirection.Asc  => { "{self.field} ASC" },
            SortDirection.Desc => { "{self.field} DESC" },
        }
    }
}

# ============================================================================
# QueryBuilder — fluent builder producing vaisdb SQL / hybrid query strings
# ============================================================================

struct QueryBuilder {
    kind: QueryKind,

    # SELECT state
    from_table: str,
    columns: Vec<str>,
    where_conditions: Vec<str>,
    joins: Vec<JoinEntry>,
    order_entries: Vec<OrderEntry>,
    limit_val: i64,    # -1 = no limit

    # INSERT / UPDATE / DELETE state
    dml_table: str,
    dml_fields: Vec<str>,   # "col=val" pairs for INSERT/UPDATE

    # VECTOR_SEARCH state
    vector_column: str,
    vector_literal: str,   # "[0.1, 0.2, ...]"
    vector_top_k: i64,

    # GRAPH_TRAVERSE state
    graph_start: str,
    graph_depth: i64,
    graph_direction: str,   # "outbound" | "inbound" | "any"

    # FULLTEXT_MATCH state
    fulltext_column: str,
    fulltext_query: str,
}

impl QueryBuilder {
    # Create a blank builder
    fn new() -> QueryBuilder {
        QueryBuilder {
            kind: QueryKind.Standard,

            from_table: "",
            columns: Vec.new(),
            where_conditions: Vec.new(),
            joins: Vec.new(),
            order_entries: Vec.new(),
            limit_val: -1,

            dml_table: "",
            dml_fields: Vec.new(),

            vector_column: "",
            vector_literal: "",
            vector_top_k: 10,

            graph_start: "",
            graph_depth: 1,
            graph_direction: "outbound",

            fulltext_column: "",
            fulltext_query: "",
        }
    }

    # -------------------------------------------------------------------------
    # SELECT helpers
    # -------------------------------------------------------------------------

    # Set the FROM table and switch to Standard SELECT mode
    fn select(mut self, table: str) -> QueryBuilder {
        self.kind = QueryKind.Standard
        self.from_table = table
        self
    }

    # Append a column to the SELECT list
    fn column(mut self, col: str) -> QueryBuilder {
        self.columns.push(col)
        self
    }

    # Add a WHERE condition (ANDed together at build time)
    fn where_clause(mut self, condition: str) -> QueryBuilder {
        self.where_conditions.push(condition)
        self
    }

    # Add a JOIN clause
    fn join(mut self, table: str, on: str) -> QueryBuilder {
        entry := JoinEntry.new(table, on)
        self.joins.push(entry)
        self
    }

    # Add an ORDER BY term
    fn order_by(mut self, field: str, direction: SortDirection) -> QueryBuilder {
        entry := OrderEntry.new(field, direction)
        self.order_entries.push(entry)
        self
    }

    # Set a LIMIT
    fn limit(mut self, n: i64) -> QueryBuilder {
        self.limit_val = n
        self
    }

    # -------------------------------------------------------------------------
    # DML helpers
    # -------------------------------------------------------------------------

    # Prepare an INSERT statement
    fn insert(mut self, table: str, fields: Vec<str>) -> QueryBuilder {
        self.dml_table = table
        self.dml_fields = fields
        self.kind = QueryKind.Standard
        self
    }

    # Prepare an UPDATE statement
    fn update(mut self, table: str, fields: Vec<str>) -> QueryBuilder {
        self.dml_table = table
        self.dml_fields = fields
        self.kind = QueryKind.Standard
        self
    }

    # Prepare a DELETE statement
    fn delete(mut self, table: str) -> QueryBuilder {
        self.dml_table = table
        self.kind = QueryKind.Standard
        self
    }

    # -------------------------------------------------------------------------
    # Specialised vaisdb query helpers
    # -------------------------------------------------------------------------

    # Configure a VECTOR_SEARCH clause
    fn vector_search(mut self, column: str, vector: str, top_k: i64) -> QueryBuilder {
        self.kind = QueryKind.VectorSearch
        self.vector_column = column
        self.vector_literal = vector
        self.vector_top_k = top_k
        self
    }

    # Configure a GRAPH_TRAVERSE clause
    fn graph_traverse(mut self, start: str, depth: i64, direction: str) -> QueryBuilder {
        self.kind = QueryKind.GraphTraverse
        self.graph_start = start
        self.graph_depth = depth
        self.graph_direction = direction
        self
    }

    # Configure a FULLTEXT_MATCH clause
    fn fulltext_match(mut self, column: str, query: str) -> QueryBuilder {
        self.kind = QueryKind.FulltextMatch
        self.fulltext_column = column
        self.fulltext_query = query
        self
    }

    # -------------------------------------------------------------------------
    # Transaction helpers
    # -------------------------------------------------------------------------

    # Begin a new transaction — produces "BEGIN"
    fn begin_transaction(mut self) -> QueryBuilder {
        self.kind = QueryKind.BeginTransaction
        self
    }

    # Commit the current transaction — produces "COMMIT"
    fn commit(mut self) -> QueryBuilder {
        self.kind = QueryKind.Commit
        self
    }

    # Roll back the current transaction — produces "ROLLBACK"
    fn rollback(mut self) -> QueryBuilder {
        self.kind = QueryKind.Rollback
        self
    }

    # -------------------------------------------------------------------------
    # Internal helpers
    # -------------------------------------------------------------------------

    fn _build_column_list(self) -> str {
        I self.columns.len() == 0 {
            return "*"
        }
        result := mut ""
        I i = 0; i < self.columns.len(); i = i + 1 {
            I i > 0 {
                result = result + ", "
            }
            result = result + self.columns.get(i)
        }
        result
    }

    fn _build_where(self) -> str {
        I self.where_conditions.len() == 0 {
            return ""
        }
        clause := mut "WHERE "
        I i = 0; i < self.where_conditions.len(); i = i + 1 {
            I i > 0 {
                clause = clause + " AND "
            }
            clause = clause + self.where_conditions.get(i)
        }
        clause
    }

    fn _build_joins(self) -> str {
        result := mut ""
        I i = 0; i < self.joins.len(); i = i + 1 {
            entry := self.joins.get(i)
            result = result + " JOIN " + entry.table + " ON " + entry.on_clause
        }
        result
    }

    fn _build_order(self) -> str {
        I self.order_entries.len() == 0 {
            return ""
        }
        clause := mut "ORDER BY "
        I i = 0; i < self.order_entries.len(); i = i + 1 {
            I i > 0 {
                clause = clause + ", "
            }
            clause = clause + self.order_entries.get(i).to_string()
        }
        clause
    }

    fn _build_limit(self) -> str {
        I self.limit_val >= 0 {
            "LIMIT {self.limit_val}"
        } else {
            ""
        }
    }

    fn _build_select(self) -> str {
        sql := mut "SELECT "
        sql = sql + self._build_column_list()
        sql = sql + " FROM " + self.from_table
        sql = sql + self._build_joins()
        where_str := self._build_where()
        I where_str != "" {
            sql = sql + " " + where_str
        }
        order_str := self._build_order()
        I order_str != "" {
            sql = sql + " " + order_str
        }
        limit_str := self._build_limit()
        I limit_str != "" {
            sql = sql + " " + limit_str
        }
        sql
    }

    fn _build_insert(self) -> str {
        cols := mut ""
        vals := mut ""
        I i = 0; i < self.dml_fields.len(); i = i + 1 {
            I i > 0 {
                cols = cols + ", "
                vals = vals + ", "
            }
            cols = cols + self.dml_fields.get(i)
            vals = vals + "?"
        }
        "INSERT INTO {self.dml_table} ({cols}) VALUES ({vals})"
    }

    fn _build_update(self) -> str {
        sets := mut ""
        I i = 0; i < self.dml_fields.len(); i = i + 1 {
            I i > 0 {
                sets = sets + ", "
            }
            sets = sets + self.dml_fields.get(i) + " = ?"
        }
        sql := mut "UPDATE {self.dml_table} SET {sets}"
        where_str := self._build_where()
        I where_str != "" {
            sql = sql + " " + where_str
        }
        sql
    }

    fn _build_delete(self) -> str {
        sql := mut "DELETE FROM {self.dml_table}"
        where_str := self._build_where()
        I where_str != "" {
            sql = sql + " " + where_str
        }
        sql
    }

    fn _build_vector_search(self) -> str {
        sql := mut "SELECT "
        sql = sql + self._build_column_list()
        sql = sql + " FROM " + self.from_table
        sql = sql + " WHERE VECTOR_SEARCH({self.vector_column}, {self.vector_literal}, {self.vector_top_k})"
        where_str := self._build_where()
        # Append additional WHERE conditions if present
        I where_str != "" {
            sql = sql + " AND " + self.where_conditions.get(0)
        }
        limit_str := self._build_limit()
        I limit_str != "" {
            sql = sql + " " + limit_str
        }
        sql
    }

    fn _build_graph_traverse(self) -> str {
        sql := mut "SELECT "
        sql = sql + self._build_column_list()
        sql = sql + " FROM GRAPH_TRAVERSE('{self.graph_start}', {self.graph_depth}, '{self.graph_direction}')"
        where_str := self._build_where()
        I where_str != "" {
            sql = sql + " " + where_str
        }
        order_str := self._build_order()
        I order_str != "" {
            sql = sql + " " + order_str
        }
        limit_str := self._build_limit()
        I limit_str != "" {
            sql = sql + " " + limit_str
        }
        sql
    }

    fn _build_fulltext_match(self) -> str {
        sql := mut "SELECT "
        sql = sql + self._build_column_list()
        sql = sql + " FROM " + self.from_table
        sql = sql + " WHERE FULLTEXT_MATCH({self.fulltext_column}, '{self.fulltext_query}')"
        where_str := self._build_where()
        I where_str != "" {
            sql = sql + " AND " + self.where_conditions.get(0)
        }
        order_str := self._build_order()
        I order_str != "" {
            sql = sql + " " + order_str
        }
        limit_str := self._build_limit()
        I limit_str != "" {
            sql = sql + " " + limit_str
        }
        sql
    }

    # -------------------------------------------------------------------------
    # Build — produce the final query string
    # -------------------------------------------------------------------------

    fn build(self) -> str {
        match self.kind {
            QueryKind.BeginTransaction => { "BEGIN" },
            QueryKind.Commit           => { "COMMIT" },
            QueryKind.Rollback         => { "ROLLBACK" },
            QueryKind.VectorSearch  => { self._build_vector_search() },
            QueryKind.GraphTraverse => { self._build_graph_traverse() },
            QueryKind.FulltextMatch => { self._build_fulltext_match() },
            QueryKind.Standard => {
                # Decide DML vs SELECT by inspecting which table is set
                I self.dml_table != "" && self.from_table == "" {
                    I self.dml_fields.len() > 0 {
                        # INSERT or UPDATE — distinguish by checking for WHERE
                        I self.where_conditions.len() > 0 {
                            self._build_update()
                        } else {
                            self._build_insert()
                        }
                    } else {
                        # DELETE
                        self._build_delete()
                    }
                } else {
                    self._build_select()
                }
            },
        }
    }
}
